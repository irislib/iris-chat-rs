# Shared build metadata. Leave git SHA and timestamp empty to derive them from HEAD.
IRIS_APP_VERSION_NAME=0.1.0
IRIS_APP_VERSION_CODE=1
IRIS_BUILD_GIT_SHA=
IRIS_BUILD_TIMESTAMP_UTC=

# Shared Rust relay defaults compiled into mobile release builds.
IRIS_RELEASE_RELAY_SET_ID=public-release
IRIS_RELEASE_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.primal.net,wss://relay.snort.social,wss://temp.iris.to

# Optional beta relay overrides.
IRIS_BETA_RELAY_SET_ID=beta-fallback
IRIS_BETA_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.primal.net,wss://relay.snort.social,wss://temp.iris.to

# Android signing for Play/Test releases.
IRIS_RELEASE_KEYSTORE_PATH=
IRIS_RELEASE_KEYSTORE_PASSWORD=
IRIS_RELEASE_KEY_ALIAS=
IRIS_RELEASE_KEY_PASSWORD=

# Optional dedicated beta signing. If omitted, beta falls back to release signing, then debug signing.
IRIS_BETA_KEYSTORE_PATH=
IRIS_BETA_KEYSTORE_PASSWORD=
IRIS_BETA_KEY_ALIAS=
IRIS_BETA_KEY_PASSWORD=

# iOS TestFlight / App Store distribution.
IRIS_IOS_BUNDLE_ID=fi.siriusbusiness.irischat
IRIS_IOS_DEVELOPMENT_TEAM=
IRIS_IOS_SIGNING_STYLE=automatic
IRIS_IOS_EXPORT_METHOD=app-store-connect
IRIS_IOS_INTERNAL_ONLY=false
IRIS_IOS_ALLOW_PROVISIONING_UPDATES=false
IRIS_IOS_CODE_SIGN_IDENTITY=
IRIS_IOS_PROVISIONING_PROFILE_UUID=
IRIS_IOS_NOTIFICATION_PROVISIONING_PROFILE_UUID=
IRIS_IOS_SHARE_PROVISIONING_PROFILE_UUID=

# Optional App Store Connect authentication key for scripted archive/export/upload.
IRIS_ASC_AUTH_KEY_PATH=
IRIS_ASC_AUTH_KEY_ID=
IRIS_ASC_AUTH_KEY_ISSUER_ID=

# Optional macOS Developer ID signing profiles for App Groups entitlements.
IRIS_MACOS_PROVISIONING_PROFILE_SPECIFIER=
IRIS_MACOS_SHARE_PROVISIONING_PROFILE_SPECIFIER=

# Optional Homebrew tap overrides for the iris CLI release.
IRIS_RELEASE_SKIP_HOMEBREW_TAP=false
IRIS_HOMEBREW_TAP_REPO=homebrew-iris
IRIS_HOMEBREW_TAP_NAME=sirius/iris
IRIS_HOMEBREW_TAP_PUSH_URL=

# Optional release-publish toggles.
# `./scripts/release --publish` publishes Zapstore by default; set this to skip it.
IRIS_RELEASE_PUBLISH_ZAPSTORE=false
IRIS_RELEASE_SKIP_ZAPSTORE=false
