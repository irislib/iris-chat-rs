<UserControl x:Class="IrisChat.Views.NearbyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource Background}">
        <StackPanel Margin="32" MaxWidth="560" HorizontalAlignment="Stretch">
            <TextBlock Text="Nearby"
                       Style="{StaticResource SectionTitleText}"
                       Margin="0,0,0,14" />

            <Border Background="{StaticResource Panel}"
                    CornerRadius="{StaticResource SectionRadius}"
                    Padding="18"
                    Margin="0,0,0,14">
                <StackPanel>
                    <CheckBox x:Name="NearbyEnabledToggle"
                              Content="Nearby"
                              Checked="OnNearbyEnabledChanged"
                              Unchecked="OnNearbyEnabledChanged"
                              Margin="0,0,0,10" />
                    <CheckBox x:Name="LanToggle"
                              Content="Wi-Fi"
                              Checked="OnLanChanged"
                              Unchecked="OnLanChanged"
                              Margin="0,0,0,10" />
                    <CheckBox x:Name="MailbagToggle"
                              Content="Mailbag"
                              Checked="OnMailbagChanged"
                              Unchecked="OnMailbagChanged" />
                    <TextBlock x:Name="StatusText"
                               Style="{StaticResource MutedText}"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <ItemsControl x:Name="PeersList" />
        </StackPanel>
    </Grid>
</UserControl>
