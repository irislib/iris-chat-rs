<UserControl x:Class="IrisChat.Views.NewChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:chrome="clr-namespace:IrisChat.Chrome">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource Background}">
        <StackPanel Margin="32" MaxWidth="540" HorizontalAlignment="Center">

            <!-- New Chat: invite share (auto-creates) -->
            <Border Background="{StaticResource Panel}"
                    CornerRadius="{StaticResource SectionRadius}"
                    Padding="22,20"
                    Margin="0,0,0,16">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="New Chat"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="22"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,6" />
                    <TextBlock x:Name="NewChatHint"
                               Text="Share an invite to start a chat"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,18" />

                    <Grid x:Name="ReadyBlock" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Style="{StaticResource SecondaryButton}"
                                Padding="22,10"
                                Click="OnCopyInvite">
                            <TextBlock Text="Copy" />
                        </Button>
                        <Button Grid.Column="1"
                                Style="{StaticResource SecondaryButton}"
                                Padding="14,10"
                                Margin="10,0,0,0"
                                ToolTip="Show code"
                                Click="OnShowQr">
                            <TextBlock Text="Code" FontWeight="Bold" />
                        </Button>
                    </Grid>

                    <TextBlock x:Name="LoadingText"
                               Text="Preparing invite…"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="12"
                               HorizontalAlignment="Center" />

                    <Border x:Name="QrPanel"
                            Margin="0,18,0,0"
                            HorizontalAlignment="Center"
                            Visibility="Collapsed">
                        <StackPanel HorizontalAlignment="Center">
                            <chrome:QrCodeView x:Name="InviteQr" />
                            <TextBlock Text="Scan this code to start a chat"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       Margin="0,10,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Join Chat: paste invite -->
            <Border Background="{StaticResource Panel}"
                    CornerRadius="{StaticResource SectionRadius}"
                    Padding="22,20"
                    Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Join Chat"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="22"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12" />
                    <TextBox x:Name="PeerInput"
                             TextChanged="OnPeerInputChanged" />
                    <TextBlock Style="{StaticResource MutedText}"
                               Text="Paste a user ID or invite."
                               Margin="2,8,2,0" />
                </StackPanel>
            </Border>

            <!-- Create group row -->
            <Button Style="{StaticResource SecondaryButton}"
                    Click="OnCreateGroup"
                    HorizontalContentAlignment="Stretch"
                    Padding="14,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="👥"
                               FontSize="16"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0" />
                    <TextBlock Grid.Column="1"
                               Text="Create group"
                               Foreground="{StaticResource TextPrimary}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left" />
                    <TextBlock Grid.Column="2"
                               Text="›"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="16"
                               VerticalAlignment="Center" />
                </Grid>
            </Button>

        </StackPanel>
    </ScrollViewer>
</UserControl>
