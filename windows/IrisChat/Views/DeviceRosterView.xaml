<UserControl x:Class="IrisChat.Views.DeviceRosterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32" MaxWidth="640" HorizontalAlignment="Stretch">
            <TextBlock Text="Linked devices"
                       Style="{StaticResource HeadingText}"
                       Margin="0,0,0,8" />
            <TextBlock x:Name="HeaderHint"
                       Style="{StaticResource MutedText}"
                       Text=""
                       TextWrapping="Wrap"
                       Margin="0,0,0,16" />

            <ItemsControl x:Name="DevicesList" />

            <Border x:Name="AddBlock"
                    Background="{StaticResource Panel}"
                    CornerRadius="{StaticResource SectionRadius}"
                    Padding="16"
                    Margin="0,16,0,0"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleText}"
                               Text="Link another device"
                               Margin="0,0,0,8" />
                    <TextBlock Style="{StaticResource MutedText}"
                               Text="Paste the link code from the device you want to link."
                               TextWrapping="Wrap"
                               Margin="0,0,0,8" />
                    <TextBox x:Name="DeviceInput"
                             TextChanged="OnDeviceInputChanged" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
