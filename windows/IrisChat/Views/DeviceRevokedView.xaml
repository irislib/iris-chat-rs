<UserControl x:Class="IrisChat.Views.DeviceRevokedView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource Background}">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="420" Margin="20">
            <TextBlock Text="Device removed"
                       Style="{StaticResource HeadingText}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,12" />
            <TextBlock Foreground="{StaticResource TextMuted}"
                       Text="This device no longer has access. Sign in again to keep using Iris Chat here."
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="0,0,0,20" />
            <Button Style="{StaticResource PrimaryButton}"
                    Click="OnAcknowledge"
                    Margin="0,0,0,10">
                <TextBlock Text="Sign in again" />
            </Button>
            <Button Style="{StaticResource DangerButton}"
                    Click="OnReset">
                <TextBlock Text="Reset and sign out" />
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
