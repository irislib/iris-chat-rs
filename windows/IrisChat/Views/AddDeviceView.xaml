<UserControl x:Class="IrisChat.Views.AddDeviceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32" MaxWidth="560" HorizontalAlignment="Center">
            <TextBlock x:Name="TitleText"
                       Text="Link this device"
                       Style="{StaticResource HeadingText}"
                       Margin="0,0,0,12" />
            <TextBlock x:Name="SubtitleText"
                       Style="{StaticResource MutedText}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,16" />

            <StackPanel x:Name="LinkInputBlock">
                <TextBlock Text="User ID from your signed-in device" Margin="0,0,0,4" />
                <TextBox x:Name="OwnerInput" />
                <Button x:Name="LinkButton"
                        Style="{StaticResource PrimaryButton}"
                        Click="OnLink"
                        Margin="0,16,0,0">
                    <TextBlock Text="Continue" />
                </Button>
            </StackPanel>

            <StackPanel x:Name="WaitingBlock" Visibility="Collapsed">
                <TextBlock Text="Use your signed-in device to approve this one."
                           Foreground="{StaticResource TextMuted}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,16" />
                <Button Style="{StaticResource SecondaryButton}"
                        Click="OnCancel">
                    <TextBlock Text="Back" />
                </Button>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
