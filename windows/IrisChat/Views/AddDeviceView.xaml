<UserControl x:Class="IrisChat.Views.AddDeviceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:chrome="clr-namespace:IrisChat.Chrome">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32" MaxWidth="560" HorizontalAlignment="Center">
            <TextBlock x:Name="TitleText"
                       Text="Link this device"
                       Style="{StaticResource HeadingText}"
                       Margin="0,0,0,12" />
            <TextBlock x:Name="SubtitleText"
                       Style="{StaticResource MutedText}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,16" />

            <StackPanel x:Name="LinkCodeBlock" HorizontalAlignment="Center">
                <ProgressBar x:Name="LoadingIndicator"
                             IsIndeterminate="True"
                             Width="120"
                             Height="4"
                             HorizontalAlignment="Center" />
                <Button x:Name="RetryButton"
                        Style="{StaticResource SecondaryButton}"
                        Click="OnNewCode"
                        HorizontalAlignment="Center"
                        Visibility="Collapsed">
                    <TextBlock Text="Try again" />
                </Button>
                <chrome:QrCodeView x:Name="LinkQr"
                                   Visibility="Collapsed" />
                <StackPanel x:Name="LinkButtons"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,16,0,0"
                            Visibility="Collapsed">
                    <Button Style="{StaticResource SecondaryButton}"
                            Click="OnCopy">
                        <TextBlock Text="Copy link code" />
                    </Button>
                    <Button x:Name="NewCodeButton"
                            Style="{StaticResource PrimaryButton}"
                            Click="OnNewCode"
                            Margin="10,0,0,0">
                        <TextBlock Text="New code" />
                    </Button>
                </StackPanel>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
