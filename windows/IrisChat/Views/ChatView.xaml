<UserControl x:Class="IrisChat.Views.ChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:chrome="clr-namespace:IrisChat.Chrome">
    <Grid Background="{StaticResource Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource Toolbar}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="0,0,0,1"
                Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Background="Transparent"
                        Cursor="Hand"
                        MouseLeftButtonUp="OnHeaderTap">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <chrome:Avatar x:Name="HeaderAvatar" Grid.Column="0" Size="36" />
                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="HeaderTitle"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock x:Name="HeaderSubtitle"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis" />
                    <StackPanel x:Name="HeaderMutedStatus"
                                Orientation="Horizontal"
                                Visibility="Collapsed">
                        <TextBlock Text="&#xE7ED;"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Margin="0,0,4,0" />
                        <TextBlock Text="muted"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <StackPanel x:Name="HeaderDisappearingStatus"
                                Orientation="Horizontal"
                                Visibility="Collapsed">
                        <TextBlock Text="&#xE823;"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Margin="0,0,4,0" />
                        <TextBlock x:Name="HeaderDisappearingText"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </StackPanel>
                    </Grid>
                </Border>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource GhostButton}"
                            Click="OnToggleMute"
                            x:Name="MuteChatButton"
                            Visibility="Collapsed">
                        <TextBlock x:Name="MuteChatText" Text="Mute chat" />
                    </Button>
                    <Button Style="{StaticResource GhostButton}"
                            Click="OnGroupDetails"
                            x:Name="GroupDetailsButton"
                            Margin="6,0,0,0"
                            Visibility="Collapsed">
                        <TextBlock Text="Details" />
                    </Button>
                    <Button Style="{StaticResource GhostButton}"
                            Click="OnDeleteChat"
                            x:Name="DeleteChatButton"
                            Margin="6,0,0,0"
                            Visibility="Collapsed">
                        <TextBlock Text="Delete chat"
                                   Foreground="{StaticResource Danger}" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer x:Name="ScrollHost" Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="14,10"
                      VerticalContentAlignment="Bottom"
                      HorizontalContentAlignment="Stretch">
            <ItemsControl x:Name="MessagesList" VerticalAlignment="Bottom" />
        </ScrollViewer>

        <TextBlock x:Name="TypingText"
                   Grid.Row="2"
                   Foreground="{StaticResource TextMuted}"
                   FontSize="12"
                   FontStyle="Italic"
                   Margin="20,2,0,4"
                   Visibility="Collapsed" />

        <Grid Grid.Row="3">
            <StackPanel x:Name="BlockedPanel"
                        Visibility="Collapsed"
                        Background="{StaticResource Toolbar}"
                        Margin="14,10">
                <TextBlock Text="User blocked"
                           Foreground="{StaticResource TextPrimary}"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource GhostButton}"
                            Click="OnBlockedDeleteChat"
                            Margin="0,0,8,0">
                        <TextBlock Text="Delete chat"
                                   Foreground="{StaticResource Danger}" />
                    </Button>
                    <Button Style="{StaticResource GhostButton}"
                            Click="OnBlockedUnblock">
                        <TextBlock Text="Unblock" />
                    </Button>
                </StackPanel>
            </StackPanel>

            <StackPanel x:Name="MessageRequestPanel"
                        Visibility="Collapsed"
                        Background="{StaticResource Toolbar}"
                        Margin="14,10">
                <TextBlock x:Name="MessageRequestText"
                           Foreground="{StaticResource TextMuted}"
                           FontSize="12"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,8" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Style="{StaticResource GhostButton}"
                            Click="OnMessageRequestBlock"
                            Margin="0,0,6,0">
                        <TextBlock Text="Block"
                                   Foreground="{StaticResource Danger}" />
                    </Button>
                    <Button Grid.Column="1"
                            Style="{StaticResource GhostButton}"
                            Click="OnMessageRequestReport"
                            Margin="0,0,6,0">
                        <TextBlock Text="Block and report"
                                   Foreground="{StaticResource Danger}" />
                    </Button>
                    <Button Grid.Column="2"
                            Style="{StaticResource PrimaryButton}"
                            Click="OnMessageRequestAccept">
                        <TextBlock Text="Accept" />
                    </Button>
                </Grid>
            </StackPanel>

            <chrome:ComposerBar x:Name="Composer" />
        </Grid>
    </Grid>
</UserControl>
