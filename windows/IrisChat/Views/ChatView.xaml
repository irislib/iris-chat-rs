<UserControl x:Class="IrisChat.Views.ChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:chrome="clr-namespace:IrisChat.Chrome">
    <Grid Background="{StaticResource Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource Toolbar}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="0,0,0,1"
                Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <chrome:Avatar x:Name="HeaderAvatar" Grid.Column="0" Size="36" />
                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="HeaderTitle"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock x:Name="HeaderSubtitle"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis" />
                    <StackPanel x:Name="HeaderMutedStatus"
                                Orientation="Horizontal"
                                Visibility="Collapsed">
                        <TextBlock Text="&#xE7ED;"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Margin="0,0,4,0" />
                        <TextBlock Text="muted"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <StackPanel x:Name="HeaderDisappearingStatus"
                                Orientation="Horizontal"
                                Visibility="Collapsed">
                        <TextBlock Text="&#xE823;"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Margin="0,0,4,0" />
                        <TextBlock x:Name="HeaderDisappearingText"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource GhostButton}"
                            Click="OnToggleMute"
                            x:Name="MuteChatButton"
                            Visibility="Collapsed">
                        <TextBlock x:Name="MuteChatText" Text="Mute chat" />
                    </Button>
                    <Button Style="{StaticResource GhostButton}"
                            Click="OnGroupDetails"
                            x:Name="GroupDetailsButton"
                            Margin="6,0,0,0"
                            Visibility="Collapsed">
                        <TextBlock Text="Details" />
                    </Button>
                    <Button Style="{StaticResource GhostButton}"
                            Click="OnDeleteChat"
                            x:Name="DeleteChatButton"
                            Margin="6,0,0,0"
                            Visibility="Collapsed">
                        <TextBlock Text="Delete chat"
                                   Foreground="{StaticResource Danger}" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer x:Name="ScrollHost" Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="14,10"
                      VerticalContentAlignment="Bottom"
                      HorizontalContentAlignment="Stretch">
            <ItemsControl x:Name="MessagesList" VerticalAlignment="Bottom" />
        </ScrollViewer>

        <TextBlock x:Name="TypingText"
                   Grid.Row="2"
                   Foreground="{StaticResource TextMuted}"
                   FontSize="12"
                   FontStyle="Italic"
                   Margin="20,2,0,4"
                   Visibility="Collapsed" />

        <chrome:ComposerBar x:Name="Composer" Grid.Row="3" />
    </Grid>
</UserControl>
