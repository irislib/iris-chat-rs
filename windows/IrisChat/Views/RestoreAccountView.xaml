<UserControl x:Class="IrisChat.Views.RestoreAccountView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32" MaxWidth="520" HorizontalAlignment="Center">
            <TextBlock Text="Restore profile"
                       Style="{StaticResource HeadingText}"
                       Margin="0,0,0,12" />
            <TextBlock Style="{StaticResource MutedText}"
                       Text="Paste your secret key."
                       TextWrapping="Wrap"
                       Margin="0,0,0,16" />

            <TextBlock Text="Secret key" Margin="0,0,0,4" />
            <PasswordBox x:Name="NsecInput"
                         PasswordChanged="OnSecretChanged" />
            <TextBlock Style="{StaticResource MutedText}"
                       Text="Secret key = nostr nsec"
                       Margin="0,6,0,0" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
