<UserControl x:Class="IrisChat.Views.WelcomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource Background}">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="320" Margin="20">
            <Image Source="/Resources/IrisLogo.png"
                   Width="132"
                   Height="132"
                   Stretch="Uniform"
                   Margin="0,0,0,18" />
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,28">
                <TextBlock Text="iris"
                           Foreground="{StaticResource Accent}"
                           FontSize="36"
                           FontWeight="Bold" />
                <TextBlock Text=" chat"
                           Foreground="{StaticResource TextPrimary}"
                           FontSize="36"
                           FontWeight="Bold" />
            </StackPanel>
            <Button x:Name="CreateButton"
                    Style="{StaticResource PrimaryButton}"
                    Click="OnCreate"
                    Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE710;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="16"
                               Margin="0,0,8,0" />
                    <TextBlock Text="Create profile" />
                </StackPanel>
            </Button>

            <Button Style="{StaticResource SecondaryButton}"
                    Click="OnRestore">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE192;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="16"
                               Margin="0,0,8,0" />
                    <TextBlock Text="Restore profile" />
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
