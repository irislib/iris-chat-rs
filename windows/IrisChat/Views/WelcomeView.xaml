<UserControl x:Class="IrisChat.Views.WelcomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource Background}">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="380" Margin="20">
            <TextBlock Text="Iris Chat"
                       Foreground="{StaticResource TextPrimary}"
                       FontSize="36"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,28" />
            <Button Style="{StaticResource PrimaryButton}"
                    Click="OnCreate"
                    Margin="0,0,0,10">
                <TextBlock Text="Create account" />
            </Button>

            <Button Style="{StaticResource SecondaryButton}"
                    Click="OnRestore"
                    Margin="0,0,0,10">
                <TextBlock Text="Restore account" />
            </Button>

            <Button Style="{StaticResource SecondaryButton}"
                    Click="OnLink">
                <TextBlock Text="Link this device" />
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
