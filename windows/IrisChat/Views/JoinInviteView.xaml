<UserControl x:Class="IrisChat.Views.JoinInviteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32" MaxWidth="560" HorizontalAlignment="Center">
            <TextBlock Text="Accept invite"
                       Style="{StaticResource HeadingText}"
                       Margin="0,0,0,8" />
            <TextBlock Style="{StaticResource MutedText}"
                       Text="Paste an invite to join."
                       TextWrapping="Wrap"
                       Margin="0,0,0,16" />

            <TextBlock Text="Invite" Margin="0,0,0,4" />
            <TextBox x:Name="InviteInput" />

            <Button x:Name="AcceptButton"
                    Style="{StaticResource PrimaryButton}"
                    Click="OnAccept"
                    Margin="0,16,0,0">
                <TextBlock Text="Join chat" />
            </Button>
        </StackPanel>
    </ScrollViewer>
</UserControl>
