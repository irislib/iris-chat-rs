<UserControl x:Class="IrisChat.Chrome.ComposerBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{StaticResource Toolbar}"
            BorderBrush="{StaticResource Border}"
            BorderThickness="0,1,0,0"
            Padding="14,10">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button x:Name="AttachButton"
                    Grid.Column="0"
                    Style="{StaticResource IconButton}"
                    Margin="0,0,6,0"
                    ToolTip="Send file"
                    Click="OnAttach">
                <TextBlock Text="📎" FontSize="20" Foreground="{StaticResource TextMuted}" />
            </Button>

            <TextBox x:Name="Input"
                     Grid.Column="1"
                     AcceptsReturn="False"
                     KeyDown="OnInputKeyDown"
                     TextChanged="OnInputTextChanged"
                     FontSize="14" />

            <Button x:Name="SendButton"
                    Grid.Column="2"
                    Style="{StaticResource PrimaryButton}"
                    Margin="8,0,0,0"
                    Padding="16,8"
                    Click="OnSend">
                <TextBlock Text="Send" />
            </Button>
        </Grid>
    </Border>
</UserControl>
