#!/usr/bin/env bash

set -Eeuo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
MAX_LINES="${IRIS_RUST_FILE_LINE_LIMIT:-3000}"

if ! [[ "$MAX_LINES" =~ ^[0-9]+$ ]] || [[ "$MAX_LINES" -eq 0 ]]; then
  echo "IRIS_RUST_FILE_LINE_LIMIT must be a positive integer" >&2
  exit 2
fi

cd "$ROOT_DIR"

failed=0
while IFS= read -r file; do
  lines="$(wc -l < "$file" | tr -d ' ')"
  if [[ "$lines" -gt "$MAX_LINES" ]]; then
    printf 'Rust file too large: %s has %s lines, limit is %s\n' "$file" "$lines" "$MAX_LINES" >&2
    failed=1
  fi
done < <(git ls-files '*.rs')

if [[ "$failed" -ne 0 ]]; then
  echo "Split oversized Rust files before committing." >&2
  exit 1
fi
