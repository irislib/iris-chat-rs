#!/usr/bin/env bash

set -Eeuo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
source "${ROOT_DIR}/scripts/release_common.sh"
# shellcheck disable=SC1091
source "${ROOT_DIR}/scripts/parallel_steps.sh"

MODE="${IRIS_TEST_GATE_MODE:-local}"
RUN_NATIVE_CONTRACT="${IRIS_TEST_GATE_NATIVE_CONTRACT:-1}"
RUN_INTEROP="${IRIS_TEST_GATE_INTEROP:-0}"
RUN_PRODUCTION_CLI="${IRIS_TEST_GATE_PRODUCTION_CLI:-0}"
RUN_APP_STORE_REVIEW="${IRIS_TEST_GATE_APP_STORE_REVIEW:-0}"
RUN_ONDEVICE="${IRIS_TEST_GATE_ONDEVICE:-0}"
RUN_NOTIFICATIONS="${IRIS_TEST_GATE_NOTIFICATIONS:-0}"
RUN_LAN_AVAILABLE="${IRIS_TEST_GATE_LAN_AVAILABLE:-0}"
RUN_RELIABILITY_LAB="${IRIS_TEST_GATE_RELIABILITY_LAB:-0}"
RUN_MACOS_VM_E2E="${IRIS_TEST_GATE_MACOS_VM_E2E:-0}"
RUN_FAST="${IRIS_TEST_GATE_RUN_FAST:-1}"
RUN_IDLE_CPU="${IRIS_TEST_GATE_IDLE_CPU:-0}"
FORCE_RERUN="${IRIS_RELEASE_GATE_FORCE_RERUN:-0}"

usage() {
  cat <<'EOF'
usage: ./scripts/test-release-gate [options]

Runs the release gate from one top-level command.

Options:
  --local              Fast local gate. Default.
  --full               Include interop confidence checks.
  --interop            Include mixed-platform interop confidence checks.
  --production-cli     Include Docker CLI test against production message servers.
  --app-store-review   Include iOS App Store block/report simulator e2e.
  --reliability-lab    Include long simulator/emulator messaging reliability lab.
  --macos-vm-e2e       Include macOS VM public-relay prerelease E2E.
  --on-device          Require Android + iPhone + Mac LAN visibility.
  --lan-available      Run LAN visibility if at least two participants are available.
  --notifications      Require production-server APNs + FCM delivery on physical devices.
  --no-native-contract Skip Android native contract UI lane.
  --skip-fast          Reuse a fast tier that already passed in this invocation.
  --idle-cpu           Run available platform idle CPU gates.
  --no-idle-cpu        Skip platform idle CPU gates (sampler tests still run).
  --force-rerun        Ignore a matching recent receipt and run every gate again.
  -h, --help           Show this help

Environment:
  IRIS_TEST_GATE_INTEROP=1
  IRIS_TEST_GATE_PRODUCTION_CLI=1
  IRIS_TEST_GATE_APP_STORE_REVIEW=1
  IRIS_TEST_GATE_RELIABILITY_LAB=1
  IRIS_TEST_GATE_MACOS_VM_E2E=1
  IRIS_TEST_GATE_ONDEVICE=1
  IRIS_TEST_GATE_NOTIFICATIONS=1
  IRIS_TEST_GATE_LAN_AVAILABLE=1
  IRIS_TEST_GATE_IDLE_CPU=1
  IRIS_RELEASE_GATE_FORCE_RERUN=1
  IRIS_RELEASE_GATE_RECEIPT_TTL_SECONDS=43200
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --local)
      MODE=local
      shift
      ;;
    --full)
      MODE=full
      RUN_INTEROP=1
      RUN_PRODUCTION_CLI=1
      RUN_APP_STORE_REVIEW=1
      RUN_NOTIFICATIONS=1
      if [[ "${IRIS_TEST_GATE_IDLE_CPU:-1}" != "0" ]]; then
        RUN_IDLE_CPU=1
      fi
      shift
      ;;
    --idle-cpu)
      RUN_IDLE_CPU=1
      shift
      ;;
    --no-idle-cpu)
      RUN_IDLE_CPU=0
      shift
      ;;
    --interop)
      RUN_INTEROP=1
      shift
      ;;
    --production-cli)
      RUN_PRODUCTION_CLI=1
      shift
      ;;
    --app-store-review)
      RUN_APP_STORE_REVIEW=1
      shift
      ;;
    --reliability-lab)
      RUN_RELIABILITY_LAB=1
      shift
      ;;
    --macos-vm-e2e)
      RUN_MACOS_VM_E2E=1
      shift
      ;;
    --on-device)
      RUN_ONDEVICE=1
      shift
      ;;
    --lan-available)
      RUN_LAN_AVAILABLE=1
      shift
      ;;
    --notifications)
      RUN_NOTIFICATIONS=1
      shift
      ;;
    --no-native-contract)
      RUN_NATIVE_CONTRACT=0
      shift
      ;;
    --skip-fast)
      RUN_FAST=0
      shift
      ;;
    --force-rerun)
      FORCE_RERUN=1
      shift
      ;;
    -h|--help|help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

GATE_CONFIG="$(printf '%s\n' \
  "receipt_version=1" \
  "mode=$MODE" \
  "native_contract=$RUN_NATIVE_CONTRACT" \
  "interop=$RUN_INTEROP" \
  "production_cli=$RUN_PRODUCTION_CLI" \
  "app_store_review=$RUN_APP_STORE_REVIEW" \
  "on_device=$RUN_ONDEVICE" \
  "notifications=$RUN_NOTIFICATIONS" \
  "lan_available=$RUN_LAN_AVAILABLE" \
  "reliability_lab=$RUN_RELIABILITY_LAB" \
  "macos_vm_e2e=$RUN_MACOS_VM_E2E" \
  "fast=$RUN_FAST" \
  "idle_cpu=$RUN_IDLE_CPU" \
  "system=$(uname -s)" \
  "architecture=$(uname -m)" \
  "android_device=${IRIS_ANDROID_SERIAL:-${ANDROID_SERIAL:-auto}}" \
  "ios_workers=${IRIS_IOS_TEST_PARALLEL_WORKERS:-auto}" \
  "windows_hosts=${IRIS_WINDOWS_SSH_HOST:-${IRIS_WINDOWS_SSH_HOSTS:-auto}}")"

receipt_command() {
  IRIS_RELEASE_GATE_ROOT_DIR="$ROOT_DIR" \
    IRIS_RELEASE_GATE_CONFIG="$GATE_CONFIG" \
    "$ROOT_DIR/scripts/release_gate_receipt.sh" "$1"
}

if ! bool_is_true "$FORCE_RERUN" && receipt_command check; then
  echo "Release gate already passed for this exact clean commit and configuration."
  echo "Reusing the recent receipt; pass --force-rerun to run it again."
  exit 0
fi

run_step() {
  local name="$1"
  shift
  echo
  echo "=== ${name} ==="
  "$@"
}

windows_build_host_available() {
  local candidates="${IRIS_WINDOWS_SSH_HOST:-${IRIS_WINDOWS_SSH_HOSTS:-windows-build win11-dev}}"
  local host
  for host in $candidates; do
    if ssh -o BatchMode=yes -o ConnectTimeout=5 "$host" hostname >/dev/null 2>&1; then
      return 0
    fi
  done
  return 1
}

crate_manifest_field() {
  local manifest="$1"
  local field="$2"
  sed -nE "s/^${field}[[:space:]]*=[[:space:]]*\"([^\"]+)\".*/\\1/p" "$manifest" | head -n 1
}

crates_io_has_version() {
  local name="$1"
  local version="$2"
  python3 - "$name" "$version" <<'PY'
import sys
import urllib.error
import urllib.parse
import urllib.request

name, version = sys.argv[1:3]
url = "https://crates.io/api/v1/crates/{}/{}".format(
    urllib.parse.quote(name, safe=""),
    urllib.parse.quote(version, safe=""),
)
try:
    with urllib.request.urlopen(url, timeout=20) as response:
        sys.exit(0 if 200 <= response.status < 300 else 2)
except urllib.error.HTTPError as error:
    if error.code == 404:
        sys.exit(1)
    print(f"crates.io lookup failed: HTTP {error.code}", file=sys.stderr)
    sys.exit(2)
except Exception as error:
    print(f"crates.io lookup failed: {error}", file=sys.stderr)
    sys.exit(2)
PY
}

run_core_package_check() {
  local protocol_name protocol_version
  protocol_name="$(crate_manifest_field "${ROOT_DIR}/chat-protocol/Cargo.toml" name)"
  protocol_version="$(crate_manifest_field "${ROOT_DIR}/chat-protocol/Cargo.toml" version)"
  set +e
  crates_io_has_version "$protocol_name" "$protocol_version"
  local lookup_status=$?
  set -e
  case "$lookup_status" in
    0)
      cargo package --manifest-path "${ROOT_DIR}/core/Cargo.toml" --locked --allow-dirty
      ;;
    1)
      echo "Skipping core cargo package verification because ${protocol_name} ${protocol_version} is not on crates.io yet."
      echo "The release script publishes ${protocol_name} first, then publishes core."
      ;;
    *)
      return "$lookup_status"
      ;;
  esac
}

run_exclusive_device_checks() {
  if [[ "${RUN_NATIVE_CONTRACT}" == "1" ]]; then
    run_step "Android native contract/UI tests" \
      env IRIS_SKIP_FAST=1 "${ROOT_DIR}/scripts/test_native_contract.sh"
  fi

  if [[ "${RUN_LAN_AVAILABLE}" == "1" ]]; then
    run_step "LAN nearby visibility where available" \
      "${ROOT_DIR}/scripts/nearby_lan_visibility_matrix.sh" --allow-skip
  fi

  if [[ "${RUN_INTEROP}" == "1" ]]; then
    run_step "interop confidence" "${ROOT_DIR}/scripts/test_interop_confidence.sh"
  fi

  if [[ "${RUN_APP_STORE_REVIEW}" == "1" ]]; then
    if [[ "$(uname -s)" != "Darwin" ]]; then
      echo "iOS App Store review e2e requires macOS." >&2
      return 1
    fi
    run_step "iOS App Store review block/report e2e" \
      "${ROOT_DIR}/scripts/e2e_ios_app_store_review_block_report.sh"
  fi

  if [[ "${RUN_RELIABILITY_LAB}" == "1" ]]; then
    if [[ "$(uname -s)" != "Darwin" ]]; then
      echo "Simulator/emulator reliability lab requires macOS for iOS simulators." >&2
      return 1
    fi
    run_step "simulator/emulator reliability lab" \
      "${ROOT_DIR}/scripts/e2e_reliability_lab.sh" --tier daily --tier soak --headless
  fi

  if [[ "${RUN_ONDEVICE}" == "1" ]]; then
    run_step "on-device LAN visibility" \
      "${ROOT_DIR}/scripts/nearby_lan_visibility_matrix.sh" --on-device
  fi

  if [[ "${RUN_NOTIFICATIONS}" == "1" ]]; then
    run_step "production mobile push server E2E (iOS APNs + Android FCM)" \
      "${ROOT_DIR}/scripts/mobile_push_server_e2e.sh"
  fi
}

run_macos_vm_check() {
  if [[ "$(uname -s)" != "Darwin" ]]; then
    echo "macOS VM prerelease E2E requires macOS." >&2
    return 1
  fi
  "${ROOT_DIR}/scripts/e2e_macos_vm_prerelease.sh"
}

run_local_darwin_idle_cpu_checks() {
  run_step "macOS logged-in direct/group idle CPU" \
    "${ROOT_DIR}/scripts/idle-cpu-platform-gate.sh" --platform macos
  run_step "iOS logged-in direct/group idle CPU" \
    "${ROOT_DIR}/scripts/idle-cpu-platform-gate.sh" --platform ios
  if command -v adb >/dev/null 2>&1 \
    && { [[ -n "${IRIS_ANDROID_SERIAL:-${ANDROID_SERIAL:-}}" ]] \
      || adb devices 2>/dev/null | awk 'NR > 1 && $2 == "device" && $1 ~ /^emulator-/ { found = 1 } END { exit !found }'; }; then
    run_step "Android logged-in direct/group idle CPU" \
      "${ROOT_DIR}/scripts/idle-cpu-platform-gate.sh" --platform android
  else
    echo "Skipping Android idle CPU gate because no emulator is online and no physical device was explicitly authorized."
  fi
  if command -v docker >/dev/null 2>&1; then
    run_step "Linux logged-in direct/group idle CPU" \
      "${ROOT_DIR}/scripts/linux-idle-cpu-gate-docker.sh"
  else
    echo "Skipping Linux idle CPU gate because Docker is unavailable."
  fi
}

run_windows_idle_cpu_check() {
  if windows_build_host_available; then
    "${ROOT_DIR}/scripts/windows-build" windows-idle-cpu
  else
    echo "Skipping Windows idle CPU gate because the configured Windows host is unreachable."
  fi
}

echo "iris chat release gate (${MODE})"

parallel_step_start "release publish guard" "${ROOT_DIR}/scripts/test_release_publish_guard"
parallel_step_start "Homebrew tap packaging" "${ROOT_DIR}/scripts/test_homebrew_tap"

fast_status=0
prereq_status=0
if [[ "$RUN_FAST" == "1" ]]; then
  run_step "fast local tests" "${ROOT_DIR}/scripts/test_fast.sh" || fast_status=$?
else
  echo "Skipping fast local tests; caller supplied an already-passed fast tier."
fi
parallel_step_wait || prereq_status=$?
if [[ "$fast_status" -ne 0 || "$prereq_status" -ne 0 ]]; then
  exit 1
fi

# Package verification uses crate-local targets. The Android lane uses its
# worktree-specific Cargo target, while Docker and VM checks are isolated.
parallel_step_start "Rust protocol crate package check" \
  cargo package --manifest-path "${ROOT_DIR}/chat-protocol/Cargo.toml" --locked --allow-dirty
parallel_step_start "Rust core crate package check" run_core_package_check
parallel_step_start "exclusive device and simulator checks" run_exclusive_device_checks
if [[ "${RUN_PRODUCTION_CLI}" == "1" ]]; then
  parallel_step_start "production relay CLI Docker e2e" \
    "${ROOT_DIR}/scripts/cli_production_relay_e2e_docker"
fi
if [[ "${RUN_MACOS_VM_E2E}" == "1" ]]; then
  parallel_step_start "macOS VM prerelease E2E" run_macos_vm_check
fi
parallel_step_wait

if [[ "$RUN_IDLE_CPU" == "1" ]]; then
  case "$(uname -s)" in
    Darwin)
      # Windows samples on a separate host and can safely overlap the local
      # macOS/iOS/Android/Linux sequence.
      parallel_step_start "local platform idle CPU checks" run_local_darwin_idle_cpu_checks
      parallel_step_start "Windows logged-in direct/group idle CPU" run_windows_idle_cpu_check
      parallel_step_wait
      ;;
    Linux)
      run_step "Linux logged-in direct/group idle CPU" \
        "${ROOT_DIR}/scripts/idle-cpu-platform-gate.sh" --platform linux
      ;;
    *)
      echo "No platform idle CPU launcher for $(uname -s)." >&2
      exit 1
      ;;
  esac
fi

echo
echo "Release gate passed."
if receipt_command write; then
  echo "Saved a reusable receipt for this exact clean commit and configuration."
else
  echo "Receipt not saved because the worktree is not clean or Git metadata is unavailable."
fi
