#!/usr/bin/env bash

set -Eeuo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
source "$ROOT/scripts/release_common.sh"

load_release_env "$ROOT"
resolve_shared_build_metadata "$ROOT"

IOS_PROJECT="$ROOT/ios/IrisChat.xcodeproj"
IOS_SCHEME="IrisChat"
IOS_DIST_DIR="$ROOT/dist/ios"
IOS_EXPORT_METHOD="${IRIS_IOS_EXPORT_METHOD:-app-store-connect}"
IOS_SIGNING_STYLE="${IRIS_IOS_SIGNING_STYLE:-automatic}"
IOS_BUNDLE_ID="${IRIS_IOS_BUNDLE_ID:-to.iris.chat}"
IOS_DEVELOPMENT_TEAM="${IRIS_IOS_DEVELOPMENT_TEAM:-J8PPJKD7TA}"
IOS_INTERNAL_ONLY="${IRIS_IOS_INTERNAL_ONLY:-false}"
IOS_ARCHIVE_BASENAME="${IRIS_IOS_ARCHIVE_BASENAME:-$(release_slug ios)}"
IOS_ARCHIVE_PATH="${IRIS_IOS_ARCHIVE_PATH:-$IOS_DIST_DIR/${IOS_ARCHIVE_BASENAME}.xcarchive}"
IOS_EXPORT_PATH="${IRIS_IOS_EXPORT_PATH:-$IOS_DIST_DIR/${IOS_ARCHIVE_BASENAME}}"
IOS_UPLOAD_LOG_PATH="${IRIS_IOS_UPLOAD_LOG_PATH:-$IOS_DIST_DIR/${IOS_ARCHIVE_BASENAME}-upload}"

AUTH_ARGS=()

usage() {
  cat <<'EOF'
usage: ./scripts/ios-release <print-config|prepare|archive|export|upload>
EOF
}

normalize_signing_style() {
  case "$IOS_SIGNING_STYLE" in
    automatic|Automatic)
      IOS_SIGNING_STYLE="automatic"
      IOS_CODE_SIGN_STYLE="Automatic"
      ;;
    manual|Manual)
      IOS_SIGNING_STYLE="manual"
      IOS_CODE_SIGN_STYLE="Manual"
      ;;
    *)
      echo "Unsupported IRIS_IOS_SIGNING_STYLE: $IOS_SIGNING_STYLE" >&2
      exit 2
      ;;
  esac
}

configure_auth_args() {
  AUTH_ARGS=()
  # Passing -authenticationKey* + -allowProvisioningUpdates to xcodebuild forces
  # Apple's "cloud signing" path on every build step. That requires an
  # Admin-class API key with cert/profile management rights; most keys lack it
  # and fail with "Cloud signing permission error". For manual signing (where
  # we manage profiles + cert ourselves) skip these entirely.
  if [[ "$IOS_SIGNING_STYLE" == "manual" ]]; then
    return 0
  fi

  if [[ -n "${IRIS_ASC_AUTH_KEY_PATH:-}" || -n "${IRIS_ASC_AUTH_KEY_ID:-}" || -n "${IRIS_ASC_AUTH_KEY_ISSUER_ID:-}" ]]; then
    require_var IRIS_ASC_AUTH_KEY_PATH
    require_var IRIS_ASC_AUTH_KEY_ID
    require_var IRIS_ASC_AUTH_KEY_ISSUER_ID
    AUTH_ARGS+=(
      -authenticationKeyPath "$IRIS_ASC_AUTH_KEY_PATH"
      -authenticationKeyID "$IRIS_ASC_AUTH_KEY_ID"
      -authenticationKeyIssuerID "$IRIS_ASC_AUTH_KEY_ISSUER_ID"
    )
  fi
  if bool_is_true "${IRIS_IOS_ALLOW_PROVISIONING_UPDATES:-false}"; then
    AUTH_ARGS+=(-allowProvisioningUpdates)
  fi
}

require_automatic_signing() {
  if [[ "$IOS_SIGNING_STYLE" != "automatic" ]]; then
    echo "ios-release currently automates only automatic signing. Set IRIS_IOS_SIGNING_STYLE=automatic." >&2
    exit 1
  fi
}

require_manual_signing_inputs() {
  if [[ "$IOS_SIGNING_STYLE" != "manual" ]]; then
    return 0
  fi
  require_var IRIS_IOS_PROVISIONING_PROFILE_UUID
  require_var IRIS_IOS_CODE_SIGN_IDENTITY
}

# For export/upload, prefer manual signing when the inputs are present —
# archive can use automatic signing fine, but xcodebuild's exportArchive +
# auth-key combo always tries cloud signing and fails without an Admin key.
prefer_manual_signing_if_inputs_present() {
  if [[ "$IOS_SIGNING_STYLE" == "manual" ]]; then
    return 0
  fi
  if [[ -n "${IRIS_IOS_PROVISIONING_PROFILE_UUID:-}" && -n "${IRIS_IOS_CODE_SIGN_IDENTITY:-}" ]]; then
    IOS_SIGNING_STYLE="manual"
    IOS_CODE_SIGN_STYLE="Manual"
  fi
}

print_config() {
  cat <<EOF
ios.project=$IOS_PROJECT
ios.scheme=$IOS_SCHEME
ios.bundle.id=$IOS_BUNDLE_ID
ios.development.team=${IOS_DEVELOPMENT_TEAM:-<unset>}
ios.signing.style=$IOS_SIGNING_STYLE
ios.export.method=$IOS_EXPORT_METHOD
ios.internal.only=$IOS_INTERNAL_ONLY
ios.archive.path=$IOS_ARCHIVE_PATH
ios.export.path=$IOS_EXPORT_PATH
app.version.name=$IRIS_APP_VERSION_NAME
app.version.code=$IRIS_APP_VERSION_CODE
build.git.sha=$IRIS_BUILD_GIT_SHA
build.timestamp.utc=$IRIS_BUILD_TIMESTAMP_UTC
asc.auth.key.configured=$([[ -n "${IRIS_ASC_AUTH_KEY_PATH:-}" && -n "${IRIS_ASC_AUTH_KEY_ID:-}" && -n "${IRIS_ASC_AUTH_KEY_ISSUER_ID:-}" ]] && printf true || printf false)
EOF
}

prepare_release_inputs() {
  export IRIS_IOS_RUST_PROFILE=release
  export IRIS_APP_VERSION="$IRIS_APP_VERSION_NAME"
  export IRIS_BUILD_GIT_SHA
  export IRIS_BUILD_TIMESTAMP_UTC

  "$ROOT/scripts/ios-build" ios-xcframework
  "$ROOT/scripts/ios-build" ios-xcodeproj
}

archive_app() {
  normalize_signing_style
  configure_auth_args
  require_automatic_signing
  require_var IOS_DEVELOPMENT_TEAM
  ensure_dir "$IOS_DIST_DIR"
  prepare_release_inputs
  rm -rf "$IOS_ARCHIVE_PATH"

  # PRODUCT_BUNDLE_IDENTIFIER is intentionally NOT passed on the command line:
  # CLI build settings apply to all targets, which would clobber the
  # NotificationService extension's per-target ID (`to.iris.chat.NotificationService`)
  # and produce a CFBundleIdentifier collision rejected by App Store Connect.
  xcodebuild \
    -project "$IOS_PROJECT" \
    -scheme "$IOS_SCHEME" \
    -configuration Release \
    -destination generic/platform=iOS \
    -archivePath "$IOS_ARCHIVE_PATH" \
    "${AUTH_ARGS[@]}" \
    MARKETING_VERSION="$IRIS_APP_VERSION_NAME" \
    CURRENT_PROJECT_VERSION="$IRIS_APP_VERSION_CODE" \
    DEVELOPMENT_TEAM="$IOS_DEVELOPMENT_TEAM" \
    CODE_SIGN_STYLE="$IOS_CODE_SIGN_STYLE" \
    archive

  write_manifest "$IOS_DIST_DIR/${IOS_ARCHIVE_BASENAME}.env" \
    archive_path "$IOS_ARCHIVE_PATH" \
    bundle_id "$IOS_BUNDLE_ID" \
    app_version_name "$IRIS_APP_VERSION_NAME" \
    app_version_code "$IRIS_APP_VERSION_CODE" \
    build_git_sha "$IRIS_BUILD_GIT_SHA" \
    build_timestamp_utc "$IRIS_BUILD_TIMESTAMP_UTC"
}

write_export_options() {
  local destination="$1"
  local output_path="$2"
  local internal_testing_only_tag="false"
  local manual_block=""

  if bool_is_true "$IOS_INTERNAL_ONLY"; then
    internal_testing_only_tag="true"
  fi

  if [[ "$IOS_SIGNING_STYLE" == "manual" ]]; then
    local profile_entries="    <key>${IOS_BUNDLE_ID}</key>
    <string>${IRIS_IOS_PROVISIONING_PROFILE_UUID}</string>"
    if [[ -n "${IRIS_IOS_NOTIFICATION_PROVISIONING_PROFILE_UUID:-}" ]]; then
      profile_entries+="
    <key>${IOS_BUNDLE_ID}.NotificationService</key>
    <string>${IRIS_IOS_NOTIFICATION_PROVISIONING_PROFILE_UUID}</string>"
    fi
    manual_block="
  <key>signingCertificate</key>
  <string>${IRIS_IOS_CODE_SIGN_IDENTITY}</string>
  <key>provisioningProfiles</key>
  <dict>
${profile_entries}
  </dict>"
  fi

  cat > "$output_path" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>destination</key>
  <string>${destination}</string>
  <key>method</key>
  <string>${IOS_EXPORT_METHOD}</string>
  <key>manageAppVersionAndBuildNumber</key>
  <false/>
  <key>signingStyle</key>
  <string>${IOS_SIGNING_STYLE}</string>
  <key>stripSwiftSymbols</key>
  <true/>
  <key>teamID</key>
  <string>${IOS_DEVELOPMENT_TEAM}</string>
  <key>testFlightInternalTestingOnly</key>
  <${internal_testing_only_tag}/>
  <key>uploadSymbols</key>
  <true/>${manual_block}
</dict>
</plist>
EOF
}

export_archive() {
  local export_options_plist
  local ipa_path

  normalize_signing_style
  prefer_manual_signing_if_inputs_present
  configure_auth_args
  require_manual_signing_inputs
  require_var IOS_DEVELOPMENT_TEAM
  if [[ ! -d "$IOS_ARCHIVE_PATH" ]]; then
    echo "Archive not found at $IOS_ARCHIVE_PATH. Run ./scripts/ios-release archive first." >&2
    exit 1
  fi

  # macOS BSD mktemp does not substitute `XXXXXX` when a suffix follows it,
  # so build the path with a unique name first then rename to .plist.
  export_options_plist="$(mktemp "${TMPDIR:-/tmp}/ndr-ios-export-options.XXXXXX")"
  mv "$export_options_plist" "${export_options_plist}.plist"
  export_options_plist="${export_options_plist}.plist"
  trap 'rm -f "$export_options_plist"' EXIT
  write_export_options export "$export_options_plist"

  rm -rf "$IOS_EXPORT_PATH"
  ensure_dir "$IOS_EXPORT_PATH"
  xcodebuild \
    -exportArchive \
    -archivePath "$IOS_ARCHIVE_PATH" \
    -exportPath "$IOS_EXPORT_PATH" \
    -exportOptionsPlist "$export_options_plist" \
    "${AUTH_ARGS[@]}"

  ipa_path="$(find "$IOS_EXPORT_PATH" -maxdepth 1 -type f -name '*.ipa' | sort | head -n 1)"
  if [[ -z "${ipa_path:-}" ]]; then
    echo "iOS export did not produce an IPA in $IOS_EXPORT_PATH" >&2
    exit 1
  fi

  write_manifest "$IOS_DIST_DIR/${IOS_ARCHIVE_BASENAME}.ipa.env" \
    ipa_path "$ipa_path" \
    archive_path "$IOS_ARCHIVE_PATH" \
    bundle_id "$IOS_BUNDLE_ID" \
    app_version_name "$IRIS_APP_VERSION_NAME" \
    app_version_code "$IRIS_APP_VERSION_CODE" \
    build_git_sha "$IRIS_BUILD_GIT_SHA" \
    build_timestamp_utc "$IRIS_BUILD_TIMESTAMP_UTC"

  printf '%s\n' "$ipa_path"
}

upload_archive() {
  # Two-step flow: produce a manually-signed .ipa via `export`, then upload via
  # `xcrun altool`. We avoid xcodebuild's `destination=upload` because that
  # path forces cloud signing (see configure_auth_args).
  local ipa_path
  ipa_path="$(export_archive)"

  require_var IRIS_ASC_AUTH_KEY_ID
  require_var IRIS_ASC_AUTH_KEY_ISSUER_ID
  if [[ -n "${IRIS_ASC_AUTH_KEY_PATH:-}" && ! -f "$IRIS_ASC_AUTH_KEY_PATH" ]]; then
    echo "ASC API key file not found: $IRIS_ASC_AUTH_KEY_PATH" >&2
    exit 1
  fi

  ensure_dir "$IOS_UPLOAD_LOG_PATH"
  xcrun altool --upload-app \
    --type ios \
    --file "$ipa_path" \
    --apiKey "$IRIS_ASC_AUTH_KEY_ID" \
    --apiIssuer "$IRIS_ASC_AUTH_KEY_ISSUER_ID" \
    | tee "$IOS_UPLOAD_LOG_PATH/altool-upload.log"
}

case "${1:-}" in
  print-config)
    print_config
    ;;
  prepare)
    prepare_release_inputs
    ;;
  archive)
    archive_app
    ;;
  export)
    export_archive
    ;;
  upload)
    upload_archive
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
