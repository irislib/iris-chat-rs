#!/usr/bin/env bash

set -Eeuo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
source "$ROOT/scripts/release_common.sh"

load_release_env "$ROOT"
resolve_shared_build_metadata "$ROOT"

(
  cd "$ROOT/ios"
  xcodegen generate --spec project.yml
)
(
  cd "$ROOT/macos"
  xcodegen generate --spec project.yml
)

cat <<EOF
Synced app version metadata:
  version: $IRIS_APP_VERSION_NAME ($IRIS_APP_VERSION_CODE)
  git sha: $IRIS_BUILD_GIT_SHA
  ios: $ROOT/ios/IrisChat.xcodeproj
  macos: $ROOT/macos/IrisChatMac.xcodeproj
  android: reads $ROOT/release.env when present
EOF
