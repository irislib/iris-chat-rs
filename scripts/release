#!/usr/bin/env bash
#
# iris-chat-rs local release orchestrator.
#
# Builds whatever this host can build (macOS DMG, Windows x86_64 NSIS installer
# via Parallels, Android APK/AAB, Linux x86_64 deb/tarball via Docker, optional
# iOS xcarchive) and stages a hashtree release tree under dist/release/<tag>/.
# With --publish it runs `htree add` + `htree release publish releases/iris-chat-rs`.
#
# This mirrors the spirit of nostr-vpn's scripts/local-release.mjs but is a bash
# script for parity with the rest of scripts/ in this repo.

set -Eeuo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
source "$ROOT/scripts/release_common.sh"
# shellcheck disable=SC1091
source "$ROOT/scripts/docker_stage_common.sh"

load_release_env "$ROOT"
resolve_shared_build_metadata "$ROOT"

DIST_DIR="$ROOT/dist"
STAGE_ROOT="$DIST_DIR/release"
RELEASE_TREE_DEFAULT="releases/iris-chat-rs"
RELEASE_OWNER_NPUB_DEFAULT="npub1xdhnr9mrv47kkrn95k6cwecearydeh8e895990n3acntwvmgk2dsdeeycm"

PUBLISH=0
DRY_RUN=0
PUBLISH_ZAPSTORE=""
SKIP_ZAPSTORE=0
PUBLISH_CARGO_CRATE=""
TESTFLIGHT_MODE=""
SKIP_HOMEBREW_TAP=0
RELEASE_GATE=1
RELEASE_GATE_ARGS=()
RELEASE_TREE=""
TAG_OVERRIDE=""
ONLY_RAW=""
SKIP_RAW=""
ALLOW_PARTIAL_LATEST=0
REQUIRED_LATEST_STEPS_RAW="${IRIS_RELEASE_REQUIRED_LATEST_STEPS:-macos,windows,android,linux,cli}"
HOMEBREW_TAP_REPO="${IRIS_HOMEBREW_TAP_REPO:-homebrew-iris}"
HOMEBREW_TAP_NAME="${IRIS_HOMEBREW_TAP_NAME:-sirius/iris}"
HOMEBREW_TAP_PUSH_URL="${IRIS_HOMEBREW_TAP_PUSH_URL:-}"

usage() {
  cat <<'EOF'
usage: ./scripts/release [options]

Build all locally-buildable platforms, stage a hashtree release directory under
dist/release/<tag>/, and optionally publish it via htree.

Options:
  --publish                Publish the staged tree and repoint the htree latest release
  --allow-partial-latest   Allow --publish to repoint latest even if required steps are missing
  --skip-zapstore          Do not publish the signed Android APK to Zapstore during --publish
  --publish-zapstore       Publish the signed Android APK to Zapstore, even without --publish
  --publish-cargo-crate    Publish the iris-chat Rust crate if this version is new
  --skip-cargo-crate       Do not publish the iris-chat Rust crate
  --skip-homebrew-tap      Do not update the Homebrew tap during --publish
  --homebrew-tap-repo <n>  htree tap repo name (default: homebrew-iris)
  --homebrew-tap-name <n>  brew tap name shown to users (default: sirius/iris)
  --homebrew-tap-push-url <url>
                           Override Homebrew tap publish destination
  --testflight             Upload iOS and attach internal + public TestFlight groups
  --testflight-internal    Upload iOS and attach internal TestFlight groups
  --testflight-public      Upload iOS and submit/attach public TestFlight groups
  --skip-testflight        Do not send the iOS build to TestFlight
  --gate <mode>            Release gate mode: local, full, on-device, none
  --skip-gate              Do not run the release gate
  --tag <vX.Y.Z>           Override release tag (defaults to v$IRIS_APP_VERSION_NAME)
  --release-tree <name>    htree release tree name (default: releases/iris-chat-rs)
  --only <csv>             Only run named steps (macos,windows,android,linux,cli,ios)
  --skip <csv>             Skip named steps
  --dry-run                Print the plan without running build commands
  -h, --help               Show this help

Environment:
  IRIS_RELEASE_TREE         Default for --release-tree
  IRIS_CLI_TARGETS          Comma-separated CLI targets for the iris binary
  IRIS_RELEASE_ALLOW_DIRTY  Allow building from a dirty git tree
  IRIS_RELEASE_ALLOW_PARTIAL_LATEST
                            Allow partial releases to repoint latest
  IRIS_RELEASE_REQUIRED_LATEST_STEPS
                            Required steps for --publish latest (default: macos,windows,android,linux,cli)
  IRIS_RELEASE_GATE_ARGS    Extra/default args for scripts/test-release-gate
  IRIS_RELEASE_TESTFLIGHT   both, internal, public, or 0
  IRIS_RELEASE_PUBLISH_ZAPSTORE
  IRIS_RELEASE_SKIP_ZAPSTORE
  IRIS_RELEASE_SKIP_HOMEBREW_TAP
  IRIS_HOMEBREW_TAP_REPO    Default Homebrew tap repo (default: homebrew-iris)
  IRIS_HOMEBREW_TAP_NAME    Default brew tap name (default: sirius/iris)
  IRIS_HOMEBREW_TAP_PUSH_URL
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --publish) PUBLISH=1 ;;
    --allow-partial-latest) ALLOW_PARTIAL_LATEST=1 ;;
    --publish-zapstore) PUBLISH_ZAPSTORE=1 ;;
    --skip-zapstore) SKIP_ZAPSTORE=1 ;;
    --publish-cargo-crate) PUBLISH_CARGO_CRATE=1 ;;
    --skip-cargo-crate) PUBLISH_CARGO_CRATE=0 ;;
    --skip-homebrew-tap) SKIP_HOMEBREW_TAP=1 ;;
    --homebrew-tap-repo) HOMEBREW_TAP_REPO="$2"; shift ;;
    --homebrew-tap-name) HOMEBREW_TAP_NAME="$2"; shift ;;
    --homebrew-tap-push-url) HOMEBREW_TAP_PUSH_URL="$2"; shift ;;
    --testflight) TESTFLIGHT_MODE="both" ;;
    --testflight-internal) TESTFLIGHT_MODE="internal" ;;
    --testflight-public) TESTFLIGHT_MODE="public" ;;
    --skip-testflight) TESTFLIGHT_MODE="none" ;;
    --gate)
      case "$2" in
        local) RELEASE_GATE=1; RELEASE_GATE_ARGS=(--local) ;;
        full) RELEASE_GATE=1; RELEASE_GATE_ARGS=(--full) ;;
        on-device) RELEASE_GATE=1; RELEASE_GATE_ARGS=(--full --on-device) ;;
        none) RELEASE_GATE=0; RELEASE_GATE_ARGS=() ;;
        *) echo "Unsupported --gate mode: $2" >&2; usage >&2; exit 2 ;;
      esac
      shift
      ;;
    --skip-gate) RELEASE_GATE=0 ;;
    --dry-run) DRY_RUN=1 ;;
    --tag) TAG_OVERRIDE="$2"; shift ;;
    --release-tree) RELEASE_TREE="$2"; shift ;;
    --only) ONLY_RAW="$2"; shift ;;
    --skip) SKIP_RAW="$2"; shift ;;
    -h|--help|help) usage; exit 0 ;;
    *) echo "Unknown arg: $1" >&2; usage >&2; exit 2 ;;
  esac
  shift
done

if bool_is_true "${IRIS_RELEASE_ALLOW_PARTIAL_LATEST:-false}"; then
  ALLOW_PARTIAL_LATEST=1
fi

if bool_is_true "${IRIS_RELEASE_SKIP_HOMEBREW_TAP:-false}"; then
  SKIP_HOMEBREW_TAP=1
fi

if [[ "${#RELEASE_GATE_ARGS[@]}" -eq 0 && -n "${IRIS_RELEASE_GATE_ARGS:-}" ]]; then
  # shellcheck disable=SC2206
  RELEASE_GATE_ARGS=(${IRIS_RELEASE_GATE_ARGS})
fi
if [[ "${#RELEASE_GATE_ARGS[@]}" -eq 0 ]]; then
  if [[ "$PUBLISH" -eq 1 ]]; then
    RELEASE_GATE_ARGS=(--full)
  else
    RELEASE_GATE_ARGS=(--local)
  fi
fi
if bool_is_true "${IRIS_RELEASE_SKIP_GATE:-false}"; then
  RELEASE_GATE=0
fi

if [[ -z "${PUBLISH_ZAPSTORE}" ]]; then
  PUBLISH_ZAPSTORE=0
  if [[ "$PUBLISH" -eq 1 ]]; then
    PUBLISH_ZAPSTORE=1
  fi
  if bool_is_true "${IRIS_RELEASE_PUBLISH_ZAPSTORE:-false}"; then
    PUBLISH_ZAPSTORE=1
  fi
fi
if bool_is_true "${IRIS_RELEASE_SKIP_ZAPSTORE:-false}"; then
  SKIP_ZAPSTORE=1
fi
if [[ "$SKIP_ZAPSTORE" -eq 1 ]]; then
  PUBLISH_ZAPSTORE=0
fi

if [[ -z "${PUBLISH_CARGO_CRATE}" ]]; then
  PUBLISH_CARGO_CRATE=0
  if bool_is_true "${IRIS_RELEASE_PUBLISH_CARGO_CRATE:-false}"; then
    PUBLISH_CARGO_CRATE=1
  elif [[ "$PUBLISH" -eq 1 ]] && ! bool_is_true "${IRIS_RELEASE_SKIP_CARGO_CRATE:-false}"; then
    PUBLISH_CARGO_CRATE=1
  fi
fi

if [[ -z "${TESTFLIGHT_MODE}" ]]; then
  case "${IRIS_RELEASE_TESTFLIGHT:-}" in
    both|internal|public|none)
      TESTFLIGHT_MODE="${IRIS_RELEASE_TESTFLIGHT}"
      ;;
    0|false|FALSE|False|no|NO|No|off|OFF|Off)
      TESTFLIGHT_MODE="none"
      ;;
    "")
      if [[ "$PUBLISH" -eq 1 ]]; then
        TESTFLIGHT_MODE="both"
      else
        TESTFLIGHT_MODE="none"
      fi
      ;;
    *)
      echo "Unsupported IRIS_RELEASE_TESTFLIGHT: ${IRIS_RELEASE_TESTFLIGHT}" >&2
      exit 2
      ;;
  esac
fi

normalize_tag() {
  local v="$1"
  if [[ -z "$v" ]]; then echo "Empty tag" >&2; exit 2; fi
  if [[ "$v" == v* ]]; then echo "$v"; else echo "v$v"; fi
}

TAG="$(normalize_tag "${TAG_OVERRIDE:-$IRIS_APP_VERSION_NAME}")"
RELEASE_TREE="${RELEASE_TREE:-${IRIS_RELEASE_TREE:-$RELEASE_TREE_DEFAULT}}"
RELEASE_OWNER_NPUB="${IRIS_RELEASE_OWNER_NPUB:-$RELEASE_OWNER_NPUB_DEFAULT}"
STAGE_DIR="$STAGE_ROOT/$TAG"

ONLY_SET=""
SKIP_SET=""
csv_to_set() {
  local csv="$1"
  echo "$csv" | tr ',' '\n' | sed '/^$/d'
}
[[ -n "$ONLY_RAW" ]] && ONLY_SET="$(csv_to_set "$ONLY_RAW")"
[[ -n "$SKIP_RAW" ]] && SKIP_SET="$(csv_to_set "$SKIP_RAW")"

REQUIRED_LATEST_STEPS=()
parse_required_latest_steps() {
  local old_ifs="$IFS"
  local step

  IFS=','
  for step in $REQUIRED_LATEST_STEPS_RAW; do
    step="${step//[[:space:]]/}"
    [[ -n "$step" ]] && REQUIRED_LATEST_STEPS+=("$step")
  done
  IFS="$old_ifs"
}
parse_required_latest_steps

step_enabled() {
  local step="$1"
  if [[ -n "$ONLY_SET" ]]; then
    grep -qx "$step" <<<"$ONLY_SET" || return 1
  fi
  if [[ -n "$SKIP_SET" ]]; then
    grep -qx "$step" <<<"$SKIP_SET" && return 1
  fi
  return 0
}

BUILT_LINES=()
SKIPPED_LINES=()
ASSET_PATHS=()
BUILT_STEPS=()

note_built() { BUILT_LINES+=("$1"); echo "[built] $1"; }
note_skipped() { SKIPPED_LINES+=("$1"); echo "[skip] $1" >&2; }

mark_step_built() { BUILT_STEPS+=("$1"); }

step_was_built() {
  local needle="$1"
  local built

  for built in "${BUILT_STEPS[@]}"; do
    [[ "$built" == "$needle" ]] && return 0
  done
  return 1
}

required_step_disabled_by_scope() {
  local step="$1"

  if [[ -n "$ONLY_SET" ]]; then
    grep -qx "$step" <<<"$ONLY_SET" || return 0
  fi
  if [[ -n "$SKIP_SET" ]]; then
    grep -qx "$step" <<<"$SKIP_SET" && return 0
  fi
  return 1
}

assert_latest_publish_scope() {
  [[ "$PUBLISH" -eq 1 ]] || return 0
  [[ "$ALLOW_PARTIAL_LATEST" -eq 0 ]] || {
    echo "WARNING: --allow-partial-latest is set; --publish may repoint latest to an incomplete release." >&2
    return 0
  }

  local missing=()
  local step
  for step in "${REQUIRED_LATEST_STEPS[@]}"; do
    if required_step_disabled_by_scope "$step"; then
      missing+=("$step")
    fi
  done

  if [[ "${#missing[@]}" -gt 0 ]]; then
    echo "Refusing to publish a partial htree latest release." >&2
    echo "--publish repoints ${RELEASE_TREE}/latest, but this run excludes required step(s): ${missing[*]}." >&2
    echo "Build partial artifacts without --publish, or run a complete release. Use --allow-partial-latest only for an intentional emergency override." >&2
    exit 1
  fi
}

assert_latest_publish_assets_complete() {
  [[ "$PUBLISH" -eq 1 ]] || return 0
  [[ "$ALLOW_PARTIAL_LATEST" -eq 0 ]] || return 0

  local missing=()
  local step
  for step in "${REQUIRED_LATEST_STEPS[@]}"; do
    if ! step_was_built "$step"; then
      missing+=("$step")
    fi
  done

  if [[ "${#missing[@]}" -gt 0 ]]; then
    echo "Refusing to publish a partial htree latest release." >&2
    echo "--publish repoints ${RELEASE_TREE}/latest, but required step(s) did not produce artifacts: ${missing[*]}." >&2
    echo "Fix the failed/skipped builds before publishing latest, or use --allow-partial-latest only for an intentional emergency override." >&2
    exit 1
  fi
}

run_step() {
  local name="$1"; shift
  if ! step_enabled "$name"; then
    note_skipped "$name skipped by --only/--skip"
    return 0
  fi
  if [[ "$DRY_RUN" -eq 1 ]]; then
    echo "[dry-run] would run step: $name $*"
    return 0
  fi
  local built_before="${#ASSET_PATHS[@]}"
  if "$@"; then
    if [[ "${#ASSET_PATHS[@]}" -gt "$built_before" ]]; then
      mark_step_built "$name"
    fi
    return 0
  else
    local ec=$?
    note_skipped "$name build failed (exit $ec)"
    return 0
  fi
}

# ---------- macOS ----------
build_macos() {
  if [[ "$(uname -s)" != "Darwin" ]]; then
    note_skipped "macos: host is not Darwin"
    return 0
  fi
  IRIS_RELEASE_TAG="$TAG" "$ROOT/scripts/macos-build" macos-dmg >/dev/null
  IRIS_RELEASE_TAG="$TAG" IRIS_MACOS_FORCE_REBUILD_APP=0 "$ROOT/scripts/macos-build" macos-updater-archive >/dev/null
  local dmg updater
  dmg="$(ls -1t "$ROOT/dist/macos/iris-chat-${TAG}-macos-arm64.dmg" 2>/dev/null | head -n 1)"
  updater="$(ls -1t "$ROOT/dist/macos/iris-chat-${TAG}-macos-arm64.app.tar.gz" 2>/dev/null | head -n 1)"
  if [[ -z "${dmg:-}" || ! -f "$dmg" ]]; then
    note_skipped "macos: dmg was not produced"
    return 0
  fi
  if [[ -z "${updater:-}" || ! -f "$updater" ]]; then
    note_skipped "macos: updater archive was not produced"
    return 0
  fi
  ASSET_PATHS+=("$dmg")
  note_built "macOS Apple Silicon DMG: $(basename "$dmg")"
  ASSET_PATHS+=("$updater")
  note_built "macOS Apple Silicon updater archive: $(basename "$updater")"
}

# ---------- Windows ----------
build_windows() {
  if [[ "$(uname -s)" != "Darwin" ]]; then
    note_skipped "windows: only wired for macOS hosts driving a Windows build host over SSH"
    return 0
  fi
  local ssh_host=""
  local ssh_candidates
  local ssh_attempts="${IRIS_WINDOWS_SSH_RETRIES:-8}"
  local ssh_delay="${IRIS_WINDOWS_SSH_RETRY_DELAY_SECS:-10}"
  local attempt
  ssh_candidates="$(windows_ssh_host_candidates_text)"
  for ((attempt = 1; attempt <= ssh_attempts; attempt++)); do
    if ssh_host="$(select_windows_ssh_host 10)"; then
      break
    fi
    if [[ "$attempt" -lt "$ssh_attempts" ]]; then
      echo "[wait] windows: ssh unreachable (tried: ${ssh_candidates:-<none>}), retrying in ${ssh_delay}s ($attempt/$ssh_attempts)" >&2
      sleep "$ssh_delay"
    fi
  done
  if [[ -z "${ssh_host:-}" ]]; then
    note_skipped "windows: ssh unreachable (tried: ${ssh_candidates:-<none>}; bring the VM up, or set IRIS_WINDOWS_SSH_HOST)"
    return 0
  fi
  export IRIS_WINDOWS_SSH_HOST="$ssh_host"
  echo "[info] windows: using SSH host $IRIS_WINDOWS_SSH_HOST" >&2

  IRIS_WINDOWS_RUST_PROFILE=release \
  IRIS_WINDOWS_DOTNET_CONFIG=Release \
    "$ROOT/scripts/windows-build" windows-build

  local installer_basename="iris-chat-${TAG}-windows-x64-setup"
  local zip_basename="iris-chat-${TAG}-windows-x64"

  IRIS_WINDOWS_INSTALLER_BASENAME="$installer_basename" \
  IRIS_WINDOWS_DOTNET_CONFIG=Release \
    "$ROOT/scripts/windows-build" windows-installer

  IRIS_WINDOWS_ZIP_BASENAME="$zip_basename" \
  IRIS_WINDOWS_DOTNET_CONFIG=Release \
    "$ROOT/scripts/windows-build" windows-zip

  local installer="$ROOT/dist/windows/${installer_basename}.exe"
  local zip="$ROOT/dist/windows/${zip_basename}.zip"
  [[ -f "$installer" ]] && { ASSET_PATHS+=("$installer"); note_built "Windows x86_64 installer: $(basename "$installer")"; }
  [[ -f "$zip"       ]] && { ASSET_PATHS+=("$zip");       note_built "Windows x86_64 portable zip: $(basename "$zip")"; }
}

# ---------- Android ----------
build_android() {
  if [[ -z "${IRIS_RELEASE_KEYSTORE_PATH:-}" || -z "${IRIS_RELEASE_KEY_ALIAS:-}" ]]; then
    note_skipped "android: release signing not configured (IRIS_RELEASE_KEYSTORE_PATH/IRIS_RELEASE_KEY_ALIAS)"
    return 0
  fi

  "$ROOT/scripts/android-release" release-artifacts >/dev/null

  local sha="$IRIS_BUILD_GIT_SHA"
  local base="IrisChat-release-${IRIS_APP_VERSION_NAME}+${IRIS_APP_VERSION_CODE}-${sha}"
  local apk="$ROOT/dist/android/${base}.apk"
  local aab="$ROOT/dist/android/${base}.aab"

  if [[ -f "$apk" ]]; then
    local renamed_apk="$ROOT/dist/android/iris-chat-${TAG}-android-arm64.apk"
    cp "$apk" "$renamed_apk"
    ASSET_PATHS+=("$renamed_apk")
    note_built "Android APK: $(basename "$renamed_apk")"
  fi
  if [[ -f "$aab" ]]; then
    local renamed_aab="$ROOT/dist/android/iris-chat-${TAG}-android-arm64.aab"
    cp "$aab" "$renamed_aab"
    ASSET_PATHS+=("$renamed_aab")
    note_built "Android AAB: $(basename "$renamed_aab")"
  fi
}

# ---------- Linux ----------
build_linux() {
  if [[ "${IRIS_LINUX_REUSE_EXISTING:-0}" == "1" ]]; then
    local tar
    local deb
    tar="$(ls -1t "$ROOT"/dist/linux/iris-chat-"${TAG}"-linux-*.tar.gz 2>/dev/null | head -n 1 || true)"
    deb="$(ls -1t "$ROOT"/dist/linux/iris-chat-"${TAG}"-linux-*.deb 2>/dev/null | head -n 1 || true)"
    if [[ -z "$tar" || ! -f "$tar" ]]; then
      note_skipped "linux: IRIS_LINUX_REUSE_EXISTING set but no prebuilt Linux tarball found"
      return 1
    fi
    ASSET_PATHS+=("$tar")
    note_built "Linux tarball: $(basename "$tar")"
    [[ -n "$deb" && -f "$deb" ]] && { ASSET_PATHS+=("$deb"); note_built "Linux .deb: $(basename "$deb")"; }
    return 0
  fi
  if ! command -v docker >/dev/null 2>&1; then
    note_skipped "linux: docker not available"
    return 0
  fi
  "$ROOT/scripts/linux-release"
  local tar
  local deb
  tar="$(ls -1t "$ROOT"/dist/linux/iris-chat-"${TAG}"-linux-*.tar.gz 2>/dev/null | head -n 1 || true)"
  deb="$(ls -1t "$ROOT"/dist/linux/iris-chat-"${TAG}"-linux-*.deb 2>/dev/null | head -n 1 || true)"
  [[ -n "$tar" && -f "$tar" ]] && { ASSET_PATHS+=("$tar"); note_built "Linux tarball: $(basename "$tar")"; }
  [[ -n "$deb" && -f "$deb" ]] && { ASSET_PATHS+=("$deb"); note_built "Linux .deb: $(basename "$deb")"; }
}

# ---------- iOS (opt-in) ----------
build_ios() {
  if [[ "$(uname -s)" != "Darwin" ]]; then
    note_skipped "ios: host is not Darwin"
    return 0
  fi
  if [[ -z "${IRIS_IOS_DEVELOPMENT_TEAM:-}" ]]; then
    note_skipped "ios: IRIS_IOS_DEVELOPMENT_TEAM not set; skipping archive"
    return 0
  fi
  "$ROOT/scripts/ios-release" archive
  local archive_basename
  archive_basename="$(release_slug ios)"
  local xcarchive="$ROOT/dist/ios/${archive_basename}.xcarchive"
  if [[ -d "$xcarchive" ]]; then
    local zipped="$ROOT/dist/ios/iris-chat-${TAG}-ios.xcarchive.zip"
    rm -f "$zipped"
    (cd "$(dirname "$xcarchive")" && zip -qr "$zipped" "$(basename "$xcarchive")")
    ASSET_PATHS+=("$zipped")
    note_built "iOS xcarchive: $(basename "$zipped")"
  fi
}

# ---------- Command line ----------
release_tree_url_path() {
  printf '%s\n' "${RELEASE_TREE//\//%2F}"
}

release_gateway_base_url() {
  printf 'https://upload.iris.to/%s/%s/%s\n' \
    "$RELEASE_OWNER_NPUB" \
    "$(release_tree_url_path)" \
    "$TAG"
}

homebrew_tap_required_archives=(
  "iris-aarch64-apple-darwin.tar.gz"
  "iris-x86_64-apple-darwin.tar.gz"
  "iris-x86_64-unknown-linux-gnu.tar.gz"
)

missing_homebrew_tap_archives() {
  local name
  for name in "${homebrew_tap_required_archives[@]}"; do
    [[ -f "$STAGE_DIR/assets/$name" ]] || printf '%s\n' "$name"
  done
}

assert_homebrew_tap_assets_complete() {
  [[ "$PUBLISH" -eq 1 ]] || return 0
  [[ "$SKIP_HOMEBREW_TAP" -eq 0 ]] || return 0
  [[ "$ALLOW_PARTIAL_LATEST" -eq 0 ]] || return 0
  required_step_disabled_by_scope cli && return 0

  local missing=()
  local name
  while IFS= read -r name; do
    [[ -n "$name" ]] && missing+=("$name")
  done < <(missing_homebrew_tap_archives)

  if [[ "${#missing[@]}" -gt 0 ]]; then
    echo "Refusing to publish with an incomplete Homebrew CLI archive set." >&2
    echo "Missing: ${missing[*]}" >&2
    echo "Build a complete CLI release or pass --skip-homebrew-tap." >&2
    exit 1
  fi
}

publish_homebrew_tap() {
  if [[ "$PUBLISH" -ne 1 ]]; then
    echo "Homebrew tap: skipped"
    return 0
  fi
  if [[ "$SKIP_HOMEBREW_TAP" -eq 1 ]]; then
    echo "Homebrew tap: skipped"
    return 0
  fi

  local missing=()
  local name
  while IFS= read -r name; do
    [[ -n "$name" ]] && missing+=("$name")
  done < <(missing_homebrew_tap_archives)
  if [[ "${#missing[@]}" -gt 0 ]]; then
    echo "Homebrew tap: skipped; missing ${missing[*]}"
    return 0
  fi

  echo
  echo "Publishing Homebrew tap..."
  local args=(
    --version "$TAG"
    --release-base-url "$(release_gateway_base_url)/assets"
    --assets-dir "$STAGE_DIR/assets"
    --tap-repo "$HOMEBREW_TAP_REPO"
    --tap-name "$HOMEBREW_TAP_NAME"
    --npub "$RELEASE_OWNER_NPUB"
  )
  if [[ -n "$HOMEBREW_TAP_PUSH_URL" ]]; then
    args+=(--push-url "$HOMEBREW_TAP_PUSH_URL")
  fi
  "$ROOT/packaging/homebrew/publish_tap.sh" "${args[@]}"
}

publish_zapstore_release() {
  local config_path="${ZAPSTORE_CONFIG:-$ROOT/zapstore.yaml}"
  local extra_flags="${ZSP_EXTRA_FLAGS:-}"
  local release_only="${IRIS_ZAPSTORE_RELEASE_ONLY:-true}"
  local release_pubkey="${IRIS_ZAPSTORE_RELEASE_PUBKEY:-$RELEASE_OWNER_NPUB}"
  local tmp_config=""
  local rc

  if bool_is_true "$release_only"; then
    tmp_config="$(mktemp "$ROOT/.zapstore-release.XXXXXX.yaml")"
    sed "s#^pubkey: .*#pubkey: $release_pubkey#" "$config_path" > "$tmp_config"
    config_path="$tmp_config"
    case " $extra_flags " in
      *" --skip-app-event "*) ;;
      *) extra_flags="${extra_flags:+$extra_flags }--skip-app-event" ;;
    esac
    echo "Zapstore release-only publish: skipping app metadata event; signer $release_pubkey"
  fi

  set +e
  ZAPSTORE_CONFIG="$config_path" \
    ZSP_EXTRA_FLAGS="$extra_flags" \
    "$ROOT/scripts/publish-zapstore-android.sh" publish
  rc=$?
  set -e

  [[ -n "$tmp_config" ]] && rm -f "$tmp_config"
  return "$rc"
}

USED_NOTE_ASSETS=()

asset_link() {
  local name="$1"
  printf '[%s](assets/%s)' "$name" "$name"
}

mark_note_asset_used() {
  USED_NOTE_ASSETS+=("$1")
}

note_asset_was_used() {
  local name="$1"
  local used
  if [[ "${#USED_NOTE_ASSETS[@]}" -eq 0 ]]; then
    return 1
  fi
  for used in "${USED_NOTE_ASSETS[@]}"; do
    [[ "$used" == "$name" ]] && return 0
  done
  return 1
}

find_staged_asset() {
  local pattern
  local asset_path
  for pattern in "$@"; do
    for asset_path in "$STAGE_DIR"/assets/$pattern; do
      [[ -e "$asset_path" ]] || continue
      basename "$asset_path"
      return 0
    done
  done
  return 1
}

download_asset_description() {
  local name="$1"
  case "$name" in
    iris-chat-*-macos-arm64.app.tar.gz) printf '%s\n' "macOS Apple Silicon updater archive" ;;
    iris-chat-*-macos-arm64.dmg) printf '%s\n' "macOS Apple Silicon disk image" ;;
    iris-chat-*-windows-x64-setup.exe) printf '%s\n' "Windows x64 installer" ;;
    iris-chat-*-windows-x64.zip) printf '%s\n' "Windows x64 portable zip" ;;
    iris-chat-*-android-arm64.apk) printf '%s\n' "Android APK" ;;
    iris-chat-*-android-arm64.aab) printf '%s\n' "Android App Bundle" ;;
    iris-chat-*-linux-x64.deb) printf '%s\n' "Linux x64 Debian package" ;;
    iris-chat-*-linux-x64.tar.gz) printf '%s\n' "Linux x64 portable tarball" ;;
    iris-chat-*-ios.xcarchive.zip) printf '%s\n' "iOS archive" ;;
    iris-aarch64-apple-darwin.tar.gz) printf '%s\n' "macOS Apple Silicon CLI" ;;
    iris-x86_64-apple-darwin.tar.gz) printf '%s\n' "macOS Intel CLI" ;;
    iris-x86_64-unknown-linux-gnu.tar.gz) printf '%s\n' "Linux x64 CLI" ;;
    iris-aarch64-unknown-linux-gnu.tar.gz) printf '%s\n' "Linux ARM64 CLI" ;;
    *) printf '%s\n' "$name" ;;
  esac
}

write_download_pick() {
  local label="$1"
  shift
  local name
  if name="$(find_staged_asset "$@")"; then
    mark_note_asset_used "$name"
    printf -- '- %s: %s\n' "$label" "$(asset_link "$name")"
  fi
}

write_download_sections() {
  echo "## Downloads"
  echo
  echo "### Most People Will Want"
  echo
  write_download_pick "Iris Chat for macOS (Apple Silicon)" "iris-chat-${TAG}-macos-arm64.dmg"
  write_download_pick "Iris Chat for Windows" "iris-chat-${TAG}-windows-x64-setup.exe"
  write_download_pick "Iris Chat for Android" "iris-chat-${TAG}-android-arm64.apk"
  write_download_pick "Iris Chat for Debian/Ubuntu (.deb)" "iris-chat-${TAG}-linux-x64.deb"

  local cli_count=0
  local cli_lines=()
  local name
  for name in \
    "iris-aarch64-apple-darwin.tar.gz" \
    "iris-x86_64-apple-darwin.tar.gz" \
    "iris-x86_64-unknown-linux-gnu.tar.gz" \
    "iris-aarch64-unknown-linux-gnu.tar.gz"; do
    if [[ -f "$STAGE_DIR/assets/$name" ]]; then
      mark_note_asset_used "$name"
      cli_lines+=("- $(download_asset_description "$name"): $(asset_link "$name")")
      cli_count=$((cli_count + 1))
    fi
  done

  if [[ "$cli_count" -gt 0 || -f "$STAGE_DIR/install.sh" ]]; then
    echo
    echo "### Command Line"
    echo
    if [[ -f "$STAGE_DIR/install.sh" ]]; then
      echo "- Install script: \`curl -fsSL $(release_gateway_base_url)/install.sh | sh\`"
    fi
    if [[ "$cli_count" -gt 0 ]]; then
      printf '%s\n' "${cli_lines[@]}"
    fi
  fi

  local other_lines=()
  local asset_path
  for asset_path in "$STAGE_DIR"/assets/*; do
    [[ -e "$asset_path" ]] || continue
    name="$(basename "$asset_path")"
    note_asset_was_used "$name" && continue
    other_lines+=("- $(download_asset_description "$name"): $(asset_link "$name")")
  done

  if [[ "${#other_lines[@]}" -gt 0 ]]; then
    echo
    echo "### Other Files"
    echo
    printf '%s\n' "${other_lines[@]}"
  fi
}

default_cli_targets() {
  case "$(uname -s)" in
    Darwin)
      printf '%s\n' "aarch64-apple-darwin,x86_64-apple-darwin,x86_64-unknown-linux-gnu"
      ;;
    Linux)
      case "$(uname -m)" in
        arm64|aarch64) printf '%s\n' "aarch64-unknown-linux-gnu" ;;
        *)             printf '%s\n' "x86_64-unknown-linux-gnu" ;;
      esac
      ;;
    *)
      printf '%s\n' ""
      ;;
  esac
}

write_cli_unix_install_script() {
  local path="$1"
  cat > "$path" <<'EOF'
#!/bin/sh
set -eu

default_install_dir() {
  if [ "$(id -u)" -eq 0 ]; then
    printf '%s\n' /usr/local/bin
  elif [ -n "${XDG_BIN_HOME:-}" ]; then
    printf '%s\n' "$XDG_BIN_HOME"
  elif [ -n "${HOME:-}" ]; then
    printf '%s\n' "$HOME/.local/bin"
  else
    printf '%s\n' /usr/local/bin
  fi
}

path_contains() {
  target="$1"
  old_ifs="$IFS"
  IFS=:
  for entry in ${PATH:-}; do
    if [ "$entry" = "$target" ]; then
      IFS="$old_ifs"
      return 0
    fi
  done
  IFS="$old_ifs"
  return 1
}

existing_parent_dir() {
  dir="$1"
  while [ ! -e "$dir" ]; do
    dir="$(dirname "$dir")"
  done
  printf '%s\n' "$dir"
}

script_dir="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
INSTALL_DIR="${1:-$(default_install_dir)}"

echo "Installing iris to $INSTALL_DIR"

if [ ! -d "$INSTALL_DIR" ]; then
  parent="$(existing_parent_dir "$INSTALL_DIR")"
  if [ -w "$parent" ]; then
    mkdir -p "$INSTALL_DIR"
  else
    echo "Need sudo to create $INSTALL_DIR"
    sudo mkdir -p "$INSTALL_DIR"
  fi
fi

if [ ! -w "$INSTALL_DIR" ]; then
  echo "Need sudo to install to $INSTALL_DIR"
  sudo install -m 755 "$script_dir/iris" "$INSTALL_DIR/"
else
  install -m 755 "$script_dir/iris" "$INSTALL_DIR/"
fi

echo "Installed iris"
if ! path_contains "$INSTALL_DIR"; then
  echo
  echo "Add $INSTALL_DIR to your PATH, for example:"
  echo "  export PATH=\"$INSTALL_DIR:\$PATH\""
fi
echo
echo "Try:"
echo "  iris --help"
EOF
  chmod +x "$path"
}

write_cli_readme() {
  local path="$1"
  cat > "$path" <<'EOF'
iris command line app
=====================

Quick install:
  ./install.sh
  ./install.sh /usr/local/bin

The iris command can create or restore a profile, send messages, search local
messages, and listen for new messages.

Examples:
  iris account create --name Alice
  iris whoami
  iris send <user-id-or-chat-id> "hello"
  iris listen

Use --json when another program is reading the output.
EOF
}

write_cli_bootstrap_installer() {
  local path="$1"
  local base_url="$2"

  cat > "$path" <<EOF
#!/bin/sh
set -eu

BASE_URL="${base_url}"
ASSET_BASE_URL="\${BASE_URL}/assets"

log() {
  printf 'iris-install: %s\n' "\$*" >&2
}

die() {
  printf 'iris-install: error: %s\n' "\$*" >&2
  exit 1
}

tmpdir=""

on_exit() {
  rc=\$?
  if [ -n "\$tmpdir" ] && [ -d "\$tmpdir" ]; then
    rm -rf "\$tmpdir"
  fi
  if [ "\$rc" -ne 0 ]; then
    printf 'iris-install: install failed.\n' >&2
  fi
}

trap on_exit EXIT HUP INT TERM

require_command() {
  if ! command -v "\$1" >/dev/null 2>&1; then
    die "missing required command: \$1"
  fi
}

detect_arch() {
  case "\$(uname -m)" in
    arm64|aarch64) printf '%s\n' aarch64 ;;
    x86_64|amd64)  printf '%s\n' x86_64 ;;
    *) die "unsupported architecture: \$(uname -m)" ;;
  esac
}

detect_os() {
  case "\$(uname -s)" in
    Darwin) printf '%s\n' apple-darwin ;;
    Linux)  printf '%s\n' unknown-linux-gnu ;;
    *) die "unsupported operating system: \$(uname -s)" ;;
  esac
}

require_command curl
require_command tar
require_command mktemp
require_command uname

target="\$(detect_arch)-\$(detect_os)"
archive="iris-\${target}.tar.gz"
tmpdir=\$(mktemp -d 2>/dev/null || mktemp -d -t iris-install) || die "failed to create temporary directory"
url="\${ASSET_BASE_URL}/\${archive}"
archive_path="\${tmpdir}/\${archive}"

log "downloading \${url}"
curl -fL "\$url" -o "\$archive_path"
[ -s "\$archive_path" ] || die "downloaded archive is empty"
tar -tzf "\$archive_path" >/dev/null 2>&1 || die "downloaded file is not a valid gzip tar archive"
tar -xzf "\$archive_path" -C "\$tmpdir"

packaged_dir="\${tmpdir}/iris"
packaged_installer="\${packaged_dir}/install.sh"
[ -d "\$packaged_dir" ] || die "expected directory 'iris/' not found in archive"
[ -x "\$packaged_installer" ] || die "packaged installer not found"

cd "\$packaged_dir"
./install.sh "\$@"
EOF
  chmod +x "$path"
}

package_cli_unix_target() {
  local target="$1"
  local binary_path="$2"
  local out_dir="$ROOT/dist/cli"
  local stage_dir
  local package_dir
  local archive

  if [[ ! -f "$binary_path" ]]; then
    note_skipped "cli ${target}: binary missing at $binary_path"
    return 1
  fi

  mkdir -p "$out_dir"
  stage_dir="$(mktemp -d)"
  package_dir="$stage_dir/iris"
  archive="$out_dir/iris-${target}.tar.gz"

  mkdir -p "$package_dir"
  install -m 755 "$binary_path" "$package_dir/iris"
  write_cli_unix_install_script "$package_dir/install.sh"
  write_cli_readme "$package_dir/README.txt"

  rm -f "$archive"
  (cd "$stage_dir" && tar -czf "$archive" iris)
  rm -rf "$stage_dir"

  ASSET_PATHS+=("$archive")
  note_built "Iris CLI ${target}: $(basename "$archive")"
}

build_cli_darwin_target() {
  local target="$1"
  local target_dir="$ROOT/target/cli-release"
  rustup target add "$target" >/dev/null
  CARGO_TARGET_DIR="$target_dir" \
    cargo build --manifest-path "$ROOT/core/Cargo.toml" --release --bin iris --target "$target" --locked
  package_cli_unix_target "$target" "$target_dir/$target/release/iris"
}

build_cli_linux_target() {
  local target="$1"
  local target_dir="$ROOT/target/cli-release/linux-x64"
  local image="${IRIS_CLI_LINUX_BUILD_IMAGE:-$(docker_rust_build_image)}"
  local platform="${IRIS_CLI_LINUX_DOCKER_PLATFORM:-$(docker_default_platform)}"
  local repo_basename
  repo_basename="$(basename "$ROOT")"

  if [[ "$target" != "x86_64-unknown-linux-gnu" ]]; then
    note_skipped "cli ${target}: only x86_64 Linux is wired for Docker builds"
    return 0
  fi
  if [[ "${IRIS_CLI_LINUX_REUSE_EXISTING:-0}" == "1" ]]; then
    local archive="$ROOT/dist/cli/iris-${target}.tar.gz"
    if [[ ! -f "$archive" ]]; then
      note_skipped "cli ${target}: IRIS_CLI_LINUX_REUSE_EXISTING set but no prebuilt archive found"
      return 1
    fi
    ASSET_PATHS+=("$archive")
    note_built "Iris CLI ${target}: $(basename "$archive")"
    return 0
  fi
  if ! command -v docker >/dev/null 2>&1; then
    note_skipped "cli ${target}: docker not available"
    return 0
  fi
  rm -rf "$target_dir"
  docker run \
    --platform "$platform" \
    --rm \
    -v "$ROOT/..:/workspace:cached" \
    -w "/workspace/$repo_basename/core" \
    -e CARGO_TARGET_DIR="/workspace/$repo_basename/target/cli-release/linux-x64" \
    -e IRIS_APP_VERSION_NAME="$IRIS_APP_VERSION_NAME" \
    -e IRIS_APP_VERSION_CODE="$IRIS_APP_VERSION_CODE" \
    -e IRIS_BUILD_GIT_SHA="$IRIS_BUILD_GIT_SHA" \
    -e IRIS_BUILD_TIMESTAMP_UTC="$IRIS_BUILD_TIMESTAMP_UTC" \
    -e PATH="/usr/local/cargo/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin" \
    --entrypoint /bin/bash \
    "$image" -c 'set -Eeuo pipefail; cargo build --release --bin iris --locked'
  package_cli_unix_target "$target" "$target_dir/release/iris"
}

build_cli() {
  local targets_csv="${IRIS_CLI_TARGETS:-$(default_cli_targets)}"
  local target
  local built_before="${#ASSET_PATHS[@]}"

  if [[ -z "$targets_csv" ]]; then
    note_skipped "cli: no default targets for this host"
    return 0
  fi

  IFS=',' read -r -a cli_targets <<< "$targets_csv"
  for target in "${cli_targets[@]}"; do
    [[ -n "$target" ]] || continue
    case "$target" in
      *-apple-darwin)
        if [[ "$(uname -s)" != "Darwin" ]]; then
          note_skipped "cli ${target}: host is not Darwin"
          continue
        fi
        if ! build_cli_darwin_target "$target"; then
          note_skipped "cli ${target}: build failed"
        fi
        ;;
      x86_64-unknown-linux-gnu)
        if ! build_cli_linux_target "$target"; then
          note_skipped "cli ${target}: build failed"
        fi
        ;;
      *)
        note_skipped "cli ${target}: unsupported target"
        ;;
    esac
  done

  if [[ "${#ASSET_PATHS[@]}" -eq "$built_before" ]]; then
    note_skipped "cli: no command line archives were produced"
  fi
}

run_release_gate() {
  if [[ "$RELEASE_GATE" -ne 1 ]]; then
    echo "Release gate: skipped"
    return 0
  fi
  if [[ "$DRY_RUN" -eq 1 ]]; then
    echo "[dry-run] would run release gate: scripts/test-release-gate ${RELEASE_GATE_ARGS[*]}"
    return 0
  fi
  echo
  echo "Running release gate..."
  "$ROOT/scripts/test-release-gate" "${RELEASE_GATE_ARGS[@]}"
}

crate_manifest_field() {
  local manifest="$1"
  local field="$2"
  sed -nE "s/^${field}[[:space:]]*=[[:space:]]*\"([^\"]+)\".*/\\1/p" "$manifest" | head -n 1
}

crates_io_has_version() {
  local name="$1"
  local version="$2"
  python3 - "$name" "$version" <<'PY'
import sys
import urllib.error
import urllib.parse
import urllib.request

name, version = sys.argv[1:3]
url = "https://crates.io/api/v1/crates/{}/{}".format(
    urllib.parse.quote(name, safe=""),
    urllib.parse.quote(version, safe=""),
)
try:
    with urllib.request.urlopen(url, timeout=20) as response:
        sys.exit(0 if 200 <= response.status < 300 else 2)
except urllib.error.HTTPError as error:
    if error.code == 404:
        sys.exit(1)
    print(f"crates.io lookup failed: HTTP {error.code}", file=sys.stderr)
    sys.exit(2)
except Exception as error:
    print(f"crates.io lookup failed: {error}", file=sys.stderr)
    sys.exit(2)
PY
}

publish_cargo_manifest() {
  local manifest="$1"
  local crate_name crate_version
  crate_name="$(crate_manifest_field "$manifest" name)"
  crate_version="$(crate_manifest_field "$manifest" version)"
  if [[ -z "$crate_name" || -z "$crate_version" ]]; then
    echo "Could not resolve crate name/version for $manifest." >&2
    return 1
  fi
  echo
  echo "Publishing Rust crate ${crate_name} ${crate_version}..."
  set +e
  crates_io_has_version "$crate_name" "$crate_version"
  local lookup_status=$?
  set -e
  if [[ "$lookup_status" -eq 0 ]]; then
    echo "crates.io already has ${crate_name} ${crate_version}; skipping."
    return 0
  fi
  [[ "$lookup_status" -eq 1 ]] || return "$lookup_status"
  (cd "$(dirname "$manifest")" && cargo publish --locked)
}
publish_cargo_crate() {
  if [[ "$PUBLISH_CARGO_CRATE" -ne 1 ]]; then
    echo "Rust crate publish: skipped"
    return 0
  fi
  publish_cargo_manifest "$ROOT/chat-protocol/Cargo.toml"
  publish_cargo_manifest "$ROOT/core/Cargo.toml"
}

publish_testflight() {
  case "$TESTFLIGHT_MODE" in
    none)
      echo "TestFlight: skipped"
      return 0
      ;;
    internal|public|both)
      ;;
    *)
      echo "Unsupported TestFlight mode: $TESTFLIGHT_MODE" >&2
      return 1
      ;;
  esac
  if ! step_enabled ios; then
    note_skipped "testflight: ios step disabled by --only/--skip"
    return 0
  fi
  echo
  echo "Uploading iOS build to TestFlight..."
  IRIS_IOS_ATTACH_INTERNAL_AFTER_UPLOAD=false "$ROOT/scripts/ios-release" upload
  case "$TESTFLIGHT_MODE" in
    internal)
      "$ROOT/scripts/testflight-internal" put
      ;;
    public)
      "$ROOT/scripts/testflight-public" put
      ;;
    both)
      "$ROOT/scripts/testflight-internal" put
      "$ROOT/scripts/testflight-public" put
      ;;
  esac
}

# ---------- Run steps ----------
echo "=== iris-chat release $TAG ==="
echo "Release tree:    $RELEASE_TREE"
echo "Stage dir:       $STAGE_DIR"
echo "Version:         $IRIS_APP_VERSION_NAME ($IRIS_APP_VERSION_CODE)"
echo "Git sha:         $IRIS_BUILD_GIT_SHA"
echo "Gate:            $([[ "$RELEASE_GATE" -eq 1 ]] && printf '%s' "${RELEASE_GATE_ARGS[*]}" || printf skipped)"
echo "Cargo crate:     $([[ "$PUBLISH_CARGO_CRATE" -eq 1 ]] && printf publish || printf skip)"
echo "TestFlight:      $TESTFLIGHT_MODE"
echo "Homebrew tap:    $([[ "$PUBLISH" -eq 1 && "$SKIP_HOMEBREW_TAP" -eq 0 ]] && printf '%s' "$HOMEBREW_TAP_REPO" || printf skip)"
echo "Latest requires: ${REQUIRED_LATEST_STEPS[*]}"
[[ "$DRY_RUN" -eq 1 ]] && echo "(dry-run; no commands executed)"

assert_latest_publish_scope

run_release_gate

run_step macos   build_macos
run_step windows build_windows
run_step android build_android
run_step linux   build_linux
run_step cli     build_cli
run_step ios     build_ios

if [[ "$DRY_RUN" -eq 1 ]]; then
  echo "Dry run complete."
  exit 0
fi

assert_latest_publish_assets_complete

if [[ "${#ASSET_PATHS[@]}" -eq 0 ]]; then
  echo "No assets were produced; nothing to stage." >&2
  exit 1
fi

# ---------- Stage ----------
rm -rf "$STAGE_DIR"
mkdir -p "$STAGE_DIR/assets"
for asset in "${ASSET_PATHS[@]}"; do
  cp "$asset" "$STAGE_DIR/assets/"
done

if compgen -G "$STAGE_DIR/assets/iris-*.tar.gz" >/dev/null; then
  write_cli_bootstrap_installer "$STAGE_DIR/install.sh" "$(release_gateway_base_url)"
fi

CREATED_AT="$(date -u +%s)"
COMMIT="$(git -C "$ROOT" rev-parse HEAD 2>/dev/null || printf '%s' "$IRIS_BUILD_GIT_SHA")"

# Build minimal release.json
{
  printf '{\n'
  printf '  "id": "%s",\n' "$TAG"
  printf '  "title": "%s",\n' "$TAG"
  printf '  "tag": "%s",\n' "$TAG"
  printf '  "commit": "%s",\n' "$COMMIT"
  printf '  "created_at": %s,\n' "$CREATED_AT"
  printf '  "published_at": %s,\n' "$CREATED_AT"
  printf '  "draft": false,\n'
  case "$TAG" in
    *-*) printf '  "prerelease": true,\n' ;;
    *)   printf '  "prerelease": false,\n' ;;
  esac
  printf '  "notes_file": "notes.md",\n'
  printf '  "assets": [\n'
  first=1
  for asset_path in "$STAGE_DIR"/assets/*; do
    [[ -e "$asset_path" ]] || continue
    name="$(basename "$asset_path")"
    size="$(stat -f%z "$asset_path" 2>/dev/null || stat -c%s "$asset_path")"
    if [[ $first -eq 1 ]]; then first=0; else printf ',\n'; fi
    # CLI tarballs (iris-<target>.tar.gz) bundle iris/iris + install.sh.
    # Setting `executable` makes hashtree-updater classify the asset as
    # `binary-archive` and extract just the named entry on install,
    # so users can run `htree install <ref>` without extra flags.
    case "$name" in
      iris-*.tar.gz)
        printf '    { "name": "%s", "path": "assets/%s", "size": %s, "executable": "iris/iris" }' "$name" "$name" "$size"
        ;;
      *)
        printf '    { "name": "%s", "path": "assets/%s", "size": %s }' "$name" "$name" "$size"
        ;;
    esac
  done
  printf '\n  ]\n'
  printf '}\n'
} > "$STAGE_DIR/release.json"

# notes.md
{
  echo "# Iris Chat $TAG"
  echo
  write_download_sections
  echo
  echo "## Release Build"
  echo
  echo "- Built from commit \`$COMMIT\`."
  if [[ "${#BUILT_LINES[@]}" -gt 0 ]]; then
    for line in "${BUILT_LINES[@]}"; do
      echo "- $line"
    done
  fi
  if [[ "${#SKIPPED_LINES[@]}" -gt 0 ]]; then
    echo
    echo "## Skipped"
    echo
    for line in "${SKIPPED_LINES[@]}"; do
      echo "- $line"
    done
  fi
} > "$STAGE_DIR/notes.md"

printf '\nStaged %s at: %s\n' "$TAG" "$STAGE_DIR"
ls -la "$STAGE_DIR/assets"

assert_homebrew_tap_assets_complete
publish_cargo_crate
publish_testflight

# ---------- Publish ----------
if [[ "$PUBLISH" -eq 1 ]]; then
  if ! command -v htree >/dev/null 2>&1; then
    echo "htree not found; cannot publish." >&2
    exit 1
  fi
  echo
  echo "Publishing to hashtree..."
  add_output="$(htree add "$STAGE_DIR")"
  echo "$add_output"
  cid="$(printf '%s\n' "$add_output" | awk '/^[[:space:]]*url:[[:space:]]/ { print $2; exit }')"
  if [[ -z "${cid:-}" ]]; then
    cid="$(printf '%s\n' "$add_output" | awk '/^[[:space:]]*cid:[[:space:]]/ { print $2; exit }')"
  fi
  if [[ -z "${cid:-}" ]]; then
    echo "Could not parse CID from htree add output." >&2
    exit 1
  fi
  htree release publish "$RELEASE_TREE" "$TAG" "$cid"
  echo "Published $TAG to $RELEASE_TREE (cid: $cid)"
  publish_homebrew_tap
fi

if [[ "$PUBLISH_ZAPSTORE" -eq 1 ]]; then
  echo
  echo "Publishing Android APK to Zapstore..."
  if [[ "$DRY_RUN" -eq 1 ]]; then
    if bool_is_true "${IRIS_ZAPSTORE_RELEASE_ONLY:-true}"; then
      echo "[dry-run] would run Zapstore release-only publish with --skip-app-event"
    else
      echo "[dry-run] would run: $ROOT/scripts/publish-zapstore-android.sh publish"
    fi
  else
    publish_zapstore_release
  fi
fi

printf '\nRelease %s complete.\n' "$TAG"
