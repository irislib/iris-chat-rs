#!/usr/bin/env bash
#
# iris-chat-rs local release orchestrator.
#
# Builds whatever this host can build (macOS DMG, Windows x86_64 NSIS installer
# via Parallels, Android APK/AAB, Linux x86_64 deb/tarball via Docker, optional
# iOS xcarchive) and stages a hashtree release tree under dist/release/<tag>/.
# With --publish it runs `htree add` + `htree release publish releases/iris-chat`.
#
# This mirrors the spirit of nostr-vpn's scripts/local-release.mjs but is a bash
# script for parity with the rest of scripts/ in this repo.

set -Eeuo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
source "$ROOT/scripts/release_common.sh"

load_release_env "$ROOT"
resolve_shared_build_metadata "$ROOT"

DIST_DIR="$ROOT/dist"
STAGE_ROOT="$DIST_DIR/release"
RELEASE_TREE_DEFAULT="releases/iris-chat-rs"
RELEASE_OWNER_NPUB_DEFAULT="npub1xdhnr9mrv47kkrn95k6cwecearydeh8e895990n3acntwvmgk2dsdeeycm"

PUBLISH=0
DRY_RUN=0
PUBLISH_ZAPSTORE=0
RELEASE_TREE=""
TAG_OVERRIDE=""
ONLY_RAW=""
SKIP_RAW=""

usage() {
  cat <<'EOF'
usage: ./scripts/release [options]

Build all locally-buildable platforms, stage a hashtree release directory under
dist/release/<tag>/, and optionally publish it via htree.

Options:
  --publish                Publish the staged tree with `htree add` + `htree release publish`
  --publish-zapstore       Also publish the signed Android APK to Zapstore
  --tag <vX.Y.Z>           Override release tag (defaults to v$IRIS_APP_VERSION_NAME)
  --release-tree <name>    htree release tree name (default: releases/iris-chat-rs)
  --only <csv>             Only run named steps (macos,windows,android,linux,cli,ios)
  --skip <csv>             Skip named steps
  --dry-run                Print the plan without running build commands
  -h, --help               Show this help

Environment:
  IRIS_RELEASE_TREE         Default for --release-tree
  IRIS_CLI_TARGETS          Comma-separated CLI targets for the iris binary
  IRIS_RELEASE_ALLOW_DIRTY  Allow building from a dirty git tree
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --publish) PUBLISH=1 ;;
    --publish-zapstore) PUBLISH_ZAPSTORE=1 ;;
    --dry-run) DRY_RUN=1 ;;
    --tag) TAG_OVERRIDE="$2"; shift ;;
    --release-tree) RELEASE_TREE="$2"; shift ;;
    --only) ONLY_RAW="$2"; shift ;;
    --skip) SKIP_RAW="$2"; shift ;;
    -h|--help|help) usage; exit 0 ;;
    *) echo "Unknown arg: $1" >&2; usage >&2; exit 2 ;;
  esac
  shift
done

normalize_tag() {
  local v="$1"
  if [[ -z "$v" ]]; then echo "Empty tag" >&2; exit 2; fi
  if [[ "$v" == v* ]]; then echo "$v"; else echo "v$v"; fi
}

TAG="$(normalize_tag "${TAG_OVERRIDE:-$IRIS_APP_VERSION_NAME}")"
RELEASE_TREE="${RELEASE_TREE:-${IRIS_RELEASE_TREE:-$RELEASE_TREE_DEFAULT}}"
RELEASE_OWNER_NPUB="${IRIS_RELEASE_OWNER_NPUB:-$RELEASE_OWNER_NPUB_DEFAULT}"
STAGE_DIR="$STAGE_ROOT/$TAG"

ONLY_SET=""
SKIP_SET=""
csv_to_set() {
  local csv="$1"
  echo "$csv" | tr ',' '\n' | sed '/^$/d'
}
[[ -n "$ONLY_RAW" ]] && ONLY_SET="$(csv_to_set "$ONLY_RAW")"
[[ -n "$SKIP_RAW" ]] && SKIP_SET="$(csv_to_set "$SKIP_RAW")"

step_enabled() {
  local step="$1"
  if [[ -n "$ONLY_SET" ]]; then
    grep -qx "$step" <<<"$ONLY_SET" || return 1
  fi
  if [[ -n "$SKIP_SET" ]]; then
    grep -qx "$step" <<<"$SKIP_SET" && return 1
  fi
  return 0
}

BUILT_LINES=()
SKIPPED_LINES=()
ASSET_PATHS=()

note_built() { BUILT_LINES+=("$1"); echo "[built] $1"; }
note_skipped() { SKIPPED_LINES+=("$1"); echo "[skip] $1" >&2; }

run_step() {
  local name="$1"; shift
  if ! step_enabled "$name"; then
    note_skipped "$name skipped by --only/--skip"
    return 0
  fi
  if [[ "$DRY_RUN" -eq 1 ]]; then
    echo "[dry-run] would run step: $name $*"
    return 0
  fi
  if "$@"; then
    return 0
  else
    local ec=$?
    note_skipped "$name build failed (exit $ec)"
    return 0
  fi
}

# ---------- macOS ----------
build_macos() {
  if [[ "$(uname -s)" != "Darwin" ]]; then
    note_skipped "macos: host is not Darwin"
    return 0
  fi
  IRIS_RELEASE_TAG="$TAG" "$ROOT/scripts/macos-build" macos-dmg >/dev/null
  local dmg
  dmg="$(ls -1t "$ROOT/dist/macos/iris-chat-${TAG}-macos-arm64.dmg" 2>/dev/null | head -n 1)"
  if [[ -z "${dmg:-}" || ! -f "$dmg" ]]; then
    note_skipped "macos: dmg was not produced"
    return 0
  fi
  ASSET_PATHS+=("$dmg")
  note_built "macOS Apple Silicon DMG: $(basename "$dmg")"
}

# ---------- Windows ----------
build_windows() {
  if [[ "$(uname -s)" != "Darwin" ]]; then
    note_skipped "windows: only wired for the macOS + Parallels workflow"
    return 0
  fi
  if ! command -v prlctl >/dev/null 2>&1; then
    note_skipped "windows: prlctl not found"
    return 0
  fi

  IRIS_WINDOWS_RUST_PROFILE=release \
  IRIS_WINDOWS_DOTNET_CONFIG=Release \
    "$ROOT/scripts/windows-build" windows-build

  local installer_basename="iris-chat-${TAG}-windows-x64-setup"
  local zip_basename="iris-chat-${TAG}-windows-x64"

  IRIS_WINDOWS_INSTALLER_BASENAME="$installer_basename" \
  IRIS_WINDOWS_DOTNET_CONFIG=Release \
    "$ROOT/scripts/windows-build" windows-installer

  IRIS_WINDOWS_ZIP_BASENAME="$zip_basename" \
  IRIS_WINDOWS_DOTNET_CONFIG=Release \
    "$ROOT/scripts/windows-build" windows-zip

  local installer="$ROOT/dist/windows/${installer_basename}.exe"
  local zip="$ROOT/dist/windows/${zip_basename}.zip"
  [[ -f "$installer" ]] && { ASSET_PATHS+=("$installer"); note_built "Windows x86_64 installer: $(basename "$installer")"; }
  [[ -f "$zip"       ]] && { ASSET_PATHS+=("$zip");       note_built "Windows x86_64 portable zip: $(basename "$zip")"; }
}

# ---------- Android ----------
build_android() {
  if [[ -z "${IRIS_RELEASE_KEYSTORE_PATH:-}" || -z "${IRIS_RELEASE_KEY_ALIAS:-}" ]]; then
    note_skipped "android: release signing not configured (IRIS_RELEASE_KEYSTORE_PATH/IRIS_RELEASE_KEY_ALIAS)"
    return 0
  fi

  "$ROOT/scripts/android-release" release-bundle >/dev/null
  "$ROOT/scripts/android-release" release-apk    >/dev/null

  local sha="$IRIS_BUILD_GIT_SHA"
  local base="IrisChat-release-${IRIS_APP_VERSION_NAME}+${IRIS_APP_VERSION_CODE}-${sha}"
  local apk="$ROOT/dist/android/${base}.apk"
  local aab="$ROOT/dist/android/${base}.aab"

  if [[ -f "$apk" ]]; then
    local renamed_apk="$ROOT/dist/android/iris-chat-${TAG}-android-arm64.apk"
    cp "$apk" "$renamed_apk"
    ASSET_PATHS+=("$renamed_apk")
    note_built "Android APK: $(basename "$renamed_apk")"
  fi
  if [[ -f "$aab" ]]; then
    local renamed_aab="$ROOT/dist/android/iris-chat-${TAG}-android-arm64.aab"
    cp "$aab" "$renamed_aab"
    ASSET_PATHS+=("$renamed_aab")
    note_built "Android AAB: $(basename "$renamed_aab")"
  fi
}

# ---------- Linux ----------
build_linux() {
  if ! command -v docker >/dev/null 2>&1; then
    note_skipped "linux: docker not available"
    return 0
  fi
  "$ROOT/scripts/linux-release"
  local tar
  local deb
  tar="$(ls -1t "$ROOT"/dist/linux/iris-chat-"${TAG}"-linux-*.tar.gz 2>/dev/null | head -n 1 || true)"
  deb="$(ls -1t "$ROOT"/dist/linux/iris-chat-"${TAG}"-linux-*.deb 2>/dev/null | head -n 1 || true)"
  [[ -n "$tar" && -f "$tar" ]] && { ASSET_PATHS+=("$tar"); note_built "Linux tarball: $(basename "$tar")"; }
  [[ -n "$deb" && -f "$deb" ]] && { ASSET_PATHS+=("$deb"); note_built "Linux .deb: $(basename "$deb")"; }
}

# ---------- iOS (opt-in) ----------
build_ios() {
  if [[ "$(uname -s)" != "Darwin" ]]; then
    note_skipped "ios: host is not Darwin"
    return 0
  fi
  if [[ -z "${IRIS_IOS_DEVELOPMENT_TEAM:-}" ]]; then
    note_skipped "ios: IRIS_IOS_DEVELOPMENT_TEAM not set; skipping archive"
    return 0
  fi
  "$ROOT/scripts/ios-release" archive
  local archive_basename
  archive_basename="$(release_slug ios)"
  local xcarchive="$ROOT/dist/ios/${archive_basename}.xcarchive"
  if [[ -d "$xcarchive" ]]; then
    local zipped="$ROOT/dist/ios/iris-chat-${TAG}-ios.xcarchive.zip"
    rm -f "$zipped"
    (cd "$(dirname "$xcarchive")" && zip -qr "$zipped" "$(basename "$xcarchive")")
    ASSET_PATHS+=("$zipped")
    note_built "iOS xcarchive: $(basename "$zipped")"
  fi
}

# ---------- Command line ----------
release_tree_url_path() {
  printf '%s\n' "${RELEASE_TREE//\//%2F}"
}

release_gateway_base_url() {
  printf 'https://upload.iris.to/%s/%s/%s\n' \
    "$RELEASE_OWNER_NPUB" \
    "$(release_tree_url_path)" \
    "$TAG"
}

default_cli_targets() {
  case "$(uname -s)" in
    Darwin)
      printf '%s\n' "aarch64-apple-darwin,x86_64-apple-darwin,x86_64-unknown-linux-gnu"
      ;;
    Linux)
      case "$(uname -m)" in
        arm64|aarch64) printf '%s\n' "aarch64-unknown-linux-gnu" ;;
        *)             printf '%s\n' "x86_64-unknown-linux-gnu" ;;
      esac
      ;;
    *)
      printf '%s\n' ""
      ;;
  esac
}

write_cli_unix_install_script() {
  local path="$1"
  cat > "$path" <<'EOF'
#!/bin/sh
set -eu

default_install_dir() {
  if [ "$(id -u)" -eq 0 ]; then
    printf '%s\n' /usr/local/bin
  elif [ -n "${XDG_BIN_HOME:-}" ]; then
    printf '%s\n' "$XDG_BIN_HOME"
  elif [ -n "${HOME:-}" ]; then
    printf '%s\n' "$HOME/.local/bin"
  else
    printf '%s\n' /usr/local/bin
  fi
}

path_contains() {
  target="$1"
  old_ifs="$IFS"
  IFS=:
  for entry in ${PATH:-}; do
    if [ "$entry" = "$target" ]; then
      IFS="$old_ifs"
      return 0
    fi
  done
  IFS="$old_ifs"
  return 1
}

existing_parent_dir() {
  dir="$1"
  while [ ! -e "$dir" ]; do
    dir="$(dirname "$dir")"
  done
  printf '%s\n' "$dir"
}

script_dir="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
INSTALL_DIR="${1:-$(default_install_dir)}"

echo "Installing iris to $INSTALL_DIR"

if [ ! -d "$INSTALL_DIR" ]; then
  parent="$(existing_parent_dir "$INSTALL_DIR")"
  if [ -w "$parent" ]; then
    mkdir -p "$INSTALL_DIR"
  else
    echo "Need sudo to create $INSTALL_DIR"
    sudo mkdir -p "$INSTALL_DIR"
  fi
fi

if [ ! -w "$INSTALL_DIR" ]; then
  echo "Need sudo to install to $INSTALL_DIR"
  sudo install -m 755 "$script_dir/iris" "$INSTALL_DIR/"
else
  install -m 755 "$script_dir/iris" "$INSTALL_DIR/"
fi

echo "Installed iris"
if ! path_contains "$INSTALL_DIR"; then
  echo
  echo "Add $INSTALL_DIR to your PATH, for example:"
  echo "  export PATH=\"$INSTALL_DIR:\$PATH\""
fi
echo
echo "Try:"
echo "  iris --help"
EOF
  chmod +x "$path"
}

write_cli_readme() {
  local path="$1"
  cat > "$path" <<'EOF'
iris command line app
=====================

Quick install:
  ./install.sh
  ./install.sh /usr/local/bin

The iris command can create or restore a profile, send messages, search local
messages, and listen for new messages.

Examples:
  iris account create --name Alice
  iris whoami
  iris send <user-id-or-chat-id> "hello"
  iris listen

Use --json when another program is reading the output.
EOF
}

write_cli_bootstrap_installer() {
  local path="$1"
  local base_url="$2"

  cat > "$path" <<EOF
#!/bin/sh
set -eu

BASE_URL="${base_url}"
ASSET_BASE_URL="\${BASE_URL}/assets"

log() {
  printf 'iris-install: %s\n' "\$*" >&2
}

die() {
  printf 'iris-install: error: %s\n' "\$*" >&2
  exit 1
}

tmpdir=""

on_exit() {
  rc=\$?
  if [ -n "\$tmpdir" ] && [ -d "\$tmpdir" ]; then
    rm -rf "\$tmpdir"
  fi
  if [ "\$rc" -ne 0 ]; then
    printf 'iris-install: install failed.\n' >&2
  fi
}

trap on_exit EXIT HUP INT TERM

require_command() {
  if ! command -v "\$1" >/dev/null 2>&1; then
    die "missing required command: \$1"
  fi
}

detect_arch() {
  case "\$(uname -m)" in
    arm64|aarch64) printf '%s\n' aarch64 ;;
    x86_64|amd64)  printf '%s\n' x86_64 ;;
    *) die "unsupported architecture: \$(uname -m)" ;;
  esac
}

detect_os() {
  case "\$(uname -s)" in
    Darwin) printf '%s\n' apple-darwin ;;
    Linux)  printf '%s\n' unknown-linux-gnu ;;
    *) die "unsupported operating system: \$(uname -s)" ;;
  esac
}

require_command curl
require_command tar
require_command mktemp
require_command uname

target="\$(detect_arch)-\$(detect_os)"
archive="iris-\${target}.tar.gz"
tmpdir=\$(mktemp -d 2>/dev/null || mktemp -d -t iris-install) || die "failed to create temporary directory"
url="\${ASSET_BASE_URL}/\${archive}"
archive_path="\${tmpdir}/\${archive}"

log "downloading \${url}"
curl -fL "\$url" -o "\$archive_path"
[ -s "\$archive_path" ] || die "downloaded archive is empty"
tar -tzf "\$archive_path" >/dev/null 2>&1 || die "downloaded file is not a valid gzip tar archive"
tar -xzf "\$archive_path" -C "\$tmpdir"

packaged_dir="\${tmpdir}/iris"
packaged_installer="\${packaged_dir}/install.sh"
[ -d "\$packaged_dir" ] || die "expected directory 'iris/' not found in archive"
[ -x "\$packaged_installer" ] || die "packaged installer not found"

cd "\$packaged_dir"
./install.sh "\$@"
EOF
  chmod +x "$path"
}

package_cli_unix_target() {
  local target="$1"
  local binary_path="$2"
  local out_dir="$ROOT/dist/cli"
  local stage_dir
  local package_dir
  local archive

  if [[ ! -f "$binary_path" ]]; then
    note_skipped "cli ${target}: binary missing at $binary_path"
    return 1
  fi

  mkdir -p "$out_dir"
  stage_dir="$(mktemp -d)"
  package_dir="$stage_dir/iris"
  archive="$out_dir/iris-${target}.tar.gz"

  mkdir -p "$package_dir"
  install -m 755 "$binary_path" "$package_dir/iris"
  write_cli_unix_install_script "$package_dir/install.sh"
  write_cli_readme "$package_dir/README.txt"

  rm -f "$archive"
  (cd "$stage_dir" && tar -czf "$archive" iris)
  rm -rf "$stage_dir"

  ASSET_PATHS+=("$archive")
  note_built "Iris CLI ${target}: $(basename "$archive")"
}

build_cli_darwin_target() {
  local target="$1"
  local target_dir="$ROOT/target/cli-release"
  rustup target add "$target" >/dev/null
  CARGO_TARGET_DIR="$target_dir" \
    cargo build --manifest-path "$ROOT/core/Cargo.toml" --release --bin iris --target "$target" --locked
  package_cli_unix_target "$target" "$target_dir/$target/release/iris"
}

build_cli_linux_target() {
  local target="$1"
  local target_dir="$ROOT/target/cli-release/linux-x64"
  local image="${IRIS_LINUX_BUILD_IMAGE:-iris-chat-linux-dev:latest}"

  if [[ "$target" != "x86_64-unknown-linux-gnu" ]]; then
    note_skipped "cli ${target}: only x86_64 Linux is wired for Docker builds"
    return 0
  fi
  if ! command -v docker >/dev/null 2>&1; then
    note_skipped "cli ${target}: docker not available"
    return 0
  fi
  if ! docker image inspect "$image" >/dev/null 2>&1; then
    docker build \
      --platform linux/amd64 \
      --build-arg INSTALL_CARGO_WATCH=0 \
      -f "$ROOT/linux/Dockerfile" \
      -t "$image" \
      "$ROOT/.."
  fi
  docker run \
    --platform linux/amd64 \
    --rm \
    -v "$ROOT/..:/workspace:cached" \
    -w /workspace/iris-chat-rs/core \
    -e CARGO_TARGET_DIR="/workspace/iris-chat-rs/target/cli-release/linux-x64" \
    --entrypoint /bin/bash \
    "$image" -lc 'set -Eeuo pipefail; cargo build --release --bin iris --locked'
  package_cli_unix_target "$target" "$target_dir/release/iris"
}

build_cli() {
  local targets_csv="${IRIS_CLI_TARGETS:-$(default_cli_targets)}"
  local target
  local built_before="${#ASSET_PATHS[@]}"

  if [[ -z "$targets_csv" ]]; then
    note_skipped "cli: no default targets for this host"
    return 0
  fi

  IFS=',' read -r -a cli_targets <<< "$targets_csv"
  for target in "${cli_targets[@]}"; do
    [[ -n "$target" ]] || continue
    case "$target" in
      *-apple-darwin)
        if [[ "$(uname -s)" != "Darwin" ]]; then
          note_skipped "cli ${target}: host is not Darwin"
          continue
        fi
        if ! build_cli_darwin_target "$target"; then
          note_skipped "cli ${target}: build failed"
        fi
        ;;
      x86_64-unknown-linux-gnu)
        if ! build_cli_linux_target "$target"; then
          note_skipped "cli ${target}: build failed"
        fi
        ;;
      *)
        note_skipped "cli ${target}: unsupported target"
        ;;
    esac
  done

  if [[ "${#ASSET_PATHS[@]}" -eq "$built_before" ]]; then
    note_skipped "cli: no command line archives were produced"
  fi
}

# ---------- Run steps ----------
echo "=== iris-chat release $TAG ==="
echo "Release tree:    $RELEASE_TREE"
echo "Stage dir:       $STAGE_DIR"
echo "Version:         $IRIS_APP_VERSION_NAME ($IRIS_APP_VERSION_CODE)"
echo "Git sha:         $IRIS_BUILD_GIT_SHA"
[[ "$DRY_RUN" -eq 1 ]] && echo "(dry-run; no commands executed)"

run_step macos   build_macos
run_step windows build_windows
run_step android build_android
run_step linux   build_linux
run_step cli     build_cli
run_step ios     build_ios

if [[ "$DRY_RUN" -eq 1 ]]; then
  echo "Dry run complete."
  exit 0
fi

if [[ "${#ASSET_PATHS[@]}" -eq 0 ]]; then
  echo "No assets were produced; nothing to stage." >&2
  exit 1
fi

# ---------- Stage ----------
rm -rf "$STAGE_DIR"
mkdir -p "$STAGE_DIR/assets"
for asset in "${ASSET_PATHS[@]}"; do
  cp "$asset" "$STAGE_DIR/assets/"
done

if compgen -G "$STAGE_DIR/assets/iris-*.tar.gz" >/dev/null; then
  write_cli_bootstrap_installer "$STAGE_DIR/install.sh" "$(release_gateway_base_url)"
fi

CREATED_AT="$(date -u +%s)"
COMMIT="$(git -C "$ROOT" rev-parse HEAD 2>/dev/null || printf '%s' "$IRIS_BUILD_GIT_SHA")"

# Build minimal release.json
{
  printf '{\n'
  printf '  "id": "%s",\n' "$TAG"
  printf '  "title": "%s",\n' "$TAG"
  printf '  "tag": "%s",\n' "$TAG"
  printf '  "commit": "%s",\n' "$COMMIT"
  printf '  "created_at": %s,\n' "$CREATED_AT"
  printf '  "published_at": %s,\n' "$CREATED_AT"
  printf '  "draft": false,\n'
  case "$TAG" in
    *-*) printf '  "prerelease": true,\n' ;;
    *)   printf '  "prerelease": false,\n' ;;
  esac
  printf '  "notes_file": "notes.md",\n'
  printf '  "assets": [\n'
  first=1
  for asset_path in "$STAGE_DIR"/assets/*; do
    [[ -e "$asset_path" ]] || continue
    name="$(basename "$asset_path")"
    size="$(stat -f%z "$asset_path" 2>/dev/null || stat -c%s "$asset_path")"
    if [[ $first -eq 1 ]]; then first=0; else printf ',\n'; fi
    printf '    { "name": "%s", "path": "assets/%s", "size": %s }' "$name" "$name" "$size"
  done
  printf '\n  ]\n'
  printf '}\n'
} > "$STAGE_DIR/release.json"

# notes.md
{
  echo "# Iris Chat $TAG"
  echo
  echo "Built from commit \`$COMMIT\`."
  if [[ -f "$STAGE_DIR/install.sh" ]]; then
    echo
    echo "Command line install:"
    echo
    echo "\`\`\`bash"
    echo "curl -fsSL $(release_gateway_base_url)/install.sh | sh"
    echo "\`\`\`"
  fi
  echo
  echo "## Downloads"
  echo
  for asset_path in "$STAGE_DIR"/assets/*; do
    [[ -e "$asset_path" ]] || continue
    name="$(basename "$asset_path")"
    echo "- \`$name\`"
  done
  if [[ "${#BUILT_LINES[@]}" -gt 0 ]]; then
    echo
    echo "## Build summary"
    echo
    for line in "${BUILT_LINES[@]}"; do
      echo "- $line"
    done
  fi
  if [[ "${#SKIPPED_LINES[@]}" -gt 0 ]]; then
    echo
    echo "## Skipped"
    echo
    for line in "${SKIPPED_LINES[@]}"; do
      echo "- $line"
    done
  fi
} > "$STAGE_DIR/notes.md"

echo
echo "Staged $TAG at: $STAGE_DIR"
ls -la "$STAGE_DIR/assets"

# ---------- Publish ----------
if [[ "$PUBLISH" -eq 1 ]]; then
  if ! command -v htree >/dev/null 2>&1; then
    echo "htree not found; cannot publish." >&2
    exit 1
  fi
  echo
  echo "Publishing to hashtree..."
  add_output="$(htree add "$STAGE_DIR")"
  echo "$add_output"
  cid="$(printf '%s\n' "$add_output" | awk '/^[[:space:]]*url:[[:space:]]/ { print $2; exit }')"
  if [[ -z "${cid:-}" ]]; then
    cid="$(printf '%s\n' "$add_output" | awk '/^[[:space:]]*cid:[[:space:]]/ { print $2; exit }')"
  fi
  if [[ -z "${cid:-}" ]]; then
    echo "Could not parse CID from htree add output." >&2
    exit 1
  fi
  htree release publish "$RELEASE_TREE" "$TAG" "$cid"
  echo "Published $TAG to $RELEASE_TREE (cid: $cid)"
fi

if [[ "$PUBLISH_ZAPSTORE" -eq 1 ]]; then
  echo
  echo "Publishing Android APK to Zapstore..."
  "$ROOT/scripts/publish-zapstore-android.sh" publish
fi

echo
echo "Release $TAG complete."
