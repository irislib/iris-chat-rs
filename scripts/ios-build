#!/usr/bin/env bash

set -Eeuo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
source "$ROOT/scripts/release_common.sh"
# shellcheck disable=SC1091
source "$ROOT/scripts/parallel_steps.sh"
load_release_env "$ROOT"
resolve_shared_build_metadata "$ROOT"
CORE_DIR="$ROOT/core"
IOS_DIR="$ROOT/ios"
IOS_BINDINGS_DIR="$IOS_DIR/Bindings"
IOS_FRAMEWORKS_DIR="$IOS_DIR/Frameworks"
IOS_BUILD_DIR="$IOS_DIR/.build"
PROFILE="${IRIS_IOS_RUST_PROFILE:-debug}"
TARGETS="${IRIS_IOS_RUST_TARGETS:-aarch64-apple-ios aarch64-apple-ios-sim}"

usage() {
  cat <<'EOF'
usage: ./scripts/ios-build <ios-gen-swift|ios-rust|ios-xcframework|ios-xcodeproj|ios-build-sim|ios-test>
EOF
}

target_root() {
  local dir="${CARGO_TARGET_DIR:-}"
  if [[ -z "$dir" ]]; then
    dir="$(
      cargo metadata \
        --manifest-path "$CORE_DIR/Cargo.toml" \
        --format-version 1 \
        --no-deps \
        | python3 -c 'import json, sys; print(json.load(sys.stdin)["target_directory"])'
    )"
  fi
  if [[ "$dir" = /* ]]; then
    printf '%s\n' "$dir"
  else
    printf '%s/%s\n' "$CORE_DIR" "$dir"
  fi
}

host_dynamic_lib() {
  local ext
  case "$(uname -s)" in
    Darwin) ext="dylib" ;;
    Linux) ext="so" ;;
    *) ext="dylib" ;;
  esac
  printf '%s/%s/libiris_chat_core.%s\n' "$(target_root)" "$PROFILE" "$ext"
}

target_static_lib() {
  local target="$1"
  printf '%s/%s/%s/libiris_chat_core.a\n' "$(target_root)" "$target" "$PROFILE"
}

build_host() {
  (
    cd "$CORE_DIR"
    if [[ "$PROFILE" == "release" ]]; then
      cargo build --release
    else
      cargo build
    fi
  )
}

run_ios_gen_swift() {
  local lib_path
  build_host
  lib_path="$(host_dynamic_lib)"
  rm -rf "$IOS_BINDINGS_DIR"
  mkdir -p "$IOS_BINDINGS_DIR"
  (
    cd "$CORE_DIR"
    cargo run -q --manifest-path "$CORE_DIR/uniffi-bindgen/Cargo.toml" -- generate \
      --library "$lib_path" \
      --language swift \
      --out-dir "$IOS_BINDINGS_DIR" \
      --config "$CORE_DIR/uniffi.toml"
  )
}

run_ios_rust() {
  local target
  local dev_dir
  local toolchain_bin
  local cc_bin
  local cxx_bin
  local ar_bin
  local ranlib_bin
  local sdkroot_ios
  local sdkroot_sim
  local sdkroot
  local min_flag
  local min_version

  dev_dir="$(xcode-select -p)"
  toolchain_bin="$dev_dir/Toolchains/XcodeDefault.xctoolchain/usr/bin"
  cc_bin="$toolchain_bin/clang"
  cxx_bin="$toolchain_bin/clang++"
  ar_bin="$toolchain_bin/ar"
  ranlib_bin="$toolchain_bin/ranlib"
  sdkroot_ios="$(xcrun --sdk iphoneos --show-sdk-path)"
  sdkroot_sim="$(xcrun --sdk iphonesimulator --show-sdk-path)"

  (
    cd "$CORE_DIR"
    for target in $TARGETS; do
      case "$target" in
        aarch64-apple-ios)
          sdkroot="$sdkroot_ios"
          min_flag="-miphoneos-version-min=16.0"
          min_version="16.0"
          ;;
        aarch64-apple-ios-sim)
          sdkroot="$sdkroot_sim"
          min_flag="-mios-simulator-version-min=16.0"
          min_version="16.0"
          ;;
        *)
          echo "Unsupported iOS target: $target" >&2
          exit 2
          ;;
      esac
      if [[ "$PROFILE" == "release" ]]; then
        env \
          SDKROOT="$sdkroot" \
          IPHONEOS_DEPLOYMENT_TARGET="$min_version" \
          CC="$cc_bin" \
          CXX="$cxx_bin" \
          AR="$ar_bin" \
          RANLIB="$ranlib_bin" \
          CFLAGS_aarch64_apple_ios="$min_flag" \
          CFLAGS_aarch64_apple_ios_sim="$min_flag" \
          CXXFLAGS_aarch64_apple_ios="$min_flag" \
          CXXFLAGS_aarch64_apple_ios_sim="$min_flag" \
          CARGO_TARGET_AARCH64_APPLE_IOS_LINKER="$cc_bin" \
          CARGO_TARGET_AARCH64_APPLE_IOS_SIM_LINKER="$cc_bin" \
          RUSTFLAGS="-C linker=$cc_bin -C link-arg=$min_flag" \
          IRIS_APP_VERSION="${IRIS_APP_VERSION_NAME:-}" \
          IRIS_BUILD_GIT_SHA="${IRIS_BUILD_GIT_SHA:-}" \
          IRIS_BUILD_TIMESTAMP_UTC="${IRIS_BUILD_TIMESTAMP_UTC:-}" \
          cargo build --release --target "$target"
      else
        env \
          SDKROOT="$sdkroot" \
          IPHONEOS_DEPLOYMENT_TARGET="$min_version" \
          CC="$cc_bin" \
          CXX="$cxx_bin" \
          AR="$ar_bin" \
          RANLIB="$ranlib_bin" \
          CFLAGS_aarch64_apple_ios="$min_flag" \
          CFLAGS_aarch64_apple_ios_sim="$min_flag" \
          CXXFLAGS_aarch64_apple_ios="$min_flag" \
          CXXFLAGS_aarch64_apple_ios_sim="$min_flag" \
          CARGO_TARGET_AARCH64_APPLE_IOS_LINKER="$cc_bin" \
          CARGO_TARGET_AARCH64_APPLE_IOS_SIM_LINKER="$cc_bin" \
          RUSTFLAGS="-C linker=$cc_bin -C link-arg=$min_flag" \
          IRIS_APP_VERSION="${IRIS_APP_VERSION_NAME:-}" \
          IRIS_BUILD_GIT_SHA="${IRIS_BUILD_GIT_SHA:-}" \
          IRIS_BUILD_TIMESTAMP_UTC="${IRIS_BUILD_TIMESTAMP_UTC:-}" \
          cargo build --target "$target"
      fi
    done
  )
}

run_ios_xcframework() {
  local headers_dir="$IOS_BUILD_DIR/headers"
  local output="$IOS_FRAMEWORKS_DIR/IrisChatCore.xcframework"
  local header_path
  local modulemap_path
  local target
  local -a cmd

  run_ios_gen_swift
  run_ios_rust

  header_path="$(find "$IOS_BINDINGS_DIR" -maxdepth 1 -name '*.h' | head -n 1)"
  modulemap_path="$(find "$IOS_BINDINGS_DIR" -maxdepth 1 -name '*.modulemap' | head -n 1)"
  if [[ -z "${header_path:-}" || -z "${modulemap_path:-}" ]]; then
    echo "Missing generated Swift headers/modulemap in $IOS_BINDINGS_DIR" >&2
    exit 1
  fi

  rm -rf "$headers_dir" "$output"
  mkdir -p "$headers_dir" "$IOS_FRAMEWORKS_DIR"
  cp "$header_path" "$headers_dir/"
  cp "$modulemap_path" "$headers_dir/module.modulemap"

  cmd=(xcodebuild -create-xcframework)
  for target in $TARGETS; do
    cmd+=(-library "$(target_static_lib "$target")" -headers "$headers_dir")
  done
  cmd+=(-output "$output")
  "${cmd[@]}"
}

run_ios_xcodeproj() {
  (
    cd "$IOS_DIR"
    xcodegen generate --spec project.yml
  )
}

default_ios_destination() {
  "$ROOT/scripts/ios-simulator-destination"
}

IOS_TEST_SHARD_UDIDS=()

cleanup_ios_test_shards() {
  local index=0
  local shard_count=0
  local udid=""
  set +u
  shard_count="${#IOS_TEST_SHARD_UDIDS[@]}"
  set -u
  for ((index = 0; index < shard_count; index++)); do
    udid="${IOS_TEST_SHARD_UDIDS[$index]}"
    [[ -n "$udid" ]] || continue
    xcrun simctl delete "$udid" >/dev/null 2>&1 || true
  done
  IOS_TEST_SHARD_UDIDS=()
}

ios_build_on_exit() {
  local status=$?
  trap - EXIT
  cleanup_ios_test_shards
  parallel_steps_abort
  exit "$status"
}

trap ios_build_on_exit EXIT

run_ios_build_sim() {
  local destination="${IRIS_IOS_SIM_DESTINATION:-$(default_ios_destination)}"
  TARGETS="${IRIS_IOS_SIM_RUST_TARGETS:-aarch64-apple-ios-sim}"
  run_ios_xcframework
  run_ios_xcodeproj
  xcodebuild \
    -project "$IOS_DIR/IrisChat.xcodeproj" \
    -scheme IrisChat \
    -destination "$destination" \
    build
}

create_ios_test_shards() {
  local source_udid="$1"
  local worker_count="$2"
  local index clone_udid clone_name

  IOS_TEST_SHARD_UDIDS=()
  xcrun simctl shutdown "$source_udid" >/dev/null 2>&1 || true
  for ((index = 1; index <= worker_count; index++)); do
    clone_name="Iris test shard $$-${RANDOM}-${index}"
    clone_udid="$(xcrun simctl clone "$source_udid" "$clone_name")"
    if [[ ! "$clone_udid" =~ ^[0-9A-Fa-f-]{36}$ ]]; then
      echo "Failed to clone iOS test simulator for shard ${index}." >&2
      cleanup_ios_test_shards
      return 1
    fi
    IOS_TEST_SHARD_UDIDS+=("$clone_udid")
    xcrun simctl boot "$clone_udid"
    xcrun simctl bootstatus "$clone_udid" -b
  done
}

run_ios_ui_test_shard() {
  local shard="$1"
  local destination="$2"
  local worker_count="$3"
  local -a tests=()
  local -a command=()
  local test=""
  local status=0
  local shard_udid=""

  case "$worker_count:$shard" in
    1:1)
      tests=(IrisChatUITests)
      ;;
    2:1)
      tests=(IrisChatUITests IrisChatTimelineUITests)
      ;;
    2:2)
      tests=(IrisChatComposerUITests IrisChatFlowUITests ScreenshotTests AppStoreReviewUITests FipsBlePhysicalUITests)
      ;;
    3:1)
      tests=(IrisChatUITests ScreenshotTests AppStoreReviewUITests FipsBlePhysicalUITests)
      ;;
    3:2)
      tests=(IrisChatComposerUITests IrisChatFlowUITests)
      ;;
    3:3)
      tests=(IrisChatTimelineUITests)
      ;;
    4:1)
      tests=(IrisChatUITests)
      ;;
    4:2)
      tests=(IrisChatComposerUITests)
      ;;
    4:3)
      tests=(IrisChatTimelineUITests)
      ;;
    4:4)
      tests=(IrisChatFlowUITests ScreenshotTests AppStoreReviewUITests FipsBlePhysicalUITests)
      ;;
    *)
      echo "Unsupported iOS test shard ${shard}/${worker_count}." >&2
      return 2
      ;;
  esac

  command=(
    xcodebuild
    -project "$IOS_DIR/IrisChat.xcodeproj"
    -scheme IrisChat
    -destination "$destination"
    -parallel-testing-enabled NO
  )
  for test in "${tests[@]}"; do
    command+=("-only-testing:IrisChatUITests/${test}")
  done
  command+=(test-without-building)
  "${command[@]}" || status=$?
  if [[ "$status" -ne 133 ]]; then
    return "$status"
  fi

  echo "Xcode runner crashed with SIGTRAP; resetting and retrying iOS UI shard ${shard}." >&2
  if [[ "$destination" =~ id=([0-9A-Fa-f-]{36}) ]]; then
    shard_udid="${BASH_REMATCH[1]}"
  else
    return "$status"
  fi
  xcrun simctl shutdown "$shard_udid" >/dev/null 2>&1 || true
  xcrun simctl erase "$shard_udid"
  xcrun simctl boot "$shard_udid"
  xcrun simctl bootstatus "$shard_udid" -b
  "${command[@]}"
}

run_ios_test() {
  local parallel_workers="${IRIS_IOS_TEST_PARALLEL_WORKERS:-4}"
  if [[ ! "$parallel_workers" =~ ^[1-4]$ ]]; then
    echo "IRIS_IOS_TEST_PARALLEL_WORKERS must be an integer from 1 to 4." >&2
    exit 2
  fi
  local source_destination="${IRIS_IOS_SIM_DESTINATION:-$(IRIS_IOS_REQUIRE_CLONEABLE=1 default_ios_destination)}"
  local source_udid=""
  if [[ "$source_destination" =~ id=([0-9A-Fa-f-]{36}) ]]; then
    source_udid="${BASH_REMATCH[1]}"
  else
    echo "iOS tests require an explicit simulator id destination, got: ${source_destination}" >&2
    exit 2
  fi
  TARGETS="${IRIS_IOS_TEST_RUST_TARGETS:-aarch64-apple-ios-sim}"
  run_ios_xcframework
  run_ios_xcodeproj

  xcodebuild \
    -project "$IOS_DIR/IrisChat.xcodeproj" \
    -scheme IrisChat \
    -destination "$source_destination" \
    -parallel-testing-enabled NO \
    build-for-testing

  xcodebuild \
    -project "$IOS_DIR/IrisChat.xcodeproj" \
    -scheme IrisChat \
    -destination "$source_destination" \
    -parallel-testing-enabled NO \
    -only-testing:IrisChatTests \
    test-without-building

  create_ios_test_shards "$source_udid" "$parallel_workers"
  local index destination
  for ((index = 1; index <= parallel_workers; index++)); do
    destination="platform=iOS Simulator,id=${IOS_TEST_SHARD_UDIDS[$((index - 1))]}"
    parallel_step_start "iOS UI test shard ${index}/${parallel_workers}" \
      run_ios_ui_test_shard "$index" "$destination" "$parallel_workers"
  done

  local shard_status=0
  parallel_step_wait || shard_status=$?
  cleanup_ios_test_shards
  return "$shard_status"
}

case "${1:-}" in
  ios-gen-swift) run_ios_gen_swift ;;
  ios-rust) run_ios_rust ;;
  ios-xcframework) run_ios_xcframework ;;
  ios-xcodeproj) run_ios_xcodeproj ;;
  ios-build-sim) run_ios_build_sim ;;
  ios-test) run_ios_test ;;
  -h|--help|help) usage ;;
  *) usage >&2; exit 2 ;;
esac
