#!/usr/bin/env bash

set -Eeuo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

if [[ -f "$ROOT/scripts/release_common.sh" ]]; then
  # shellcheck disable=SC1091
  source "$ROOT/scripts/release_common.sh"
  load_release_env "$ROOT"
  resolve_shared_build_metadata "$ROOT"
fi
CORE_DIR="$ROOT/core"
IOS_BINDINGS_DIR="$ROOT/ios/Bindings"
MACOS_DIR="$ROOT/macos"
MACOS_FRAMEWORKS_DIR="$MACOS_DIR/Frameworks"
MACOS_BUILD_DIR="$MACOS_DIR/.build"
MACOS_DERIVED_DATA="$MACOS_BUILD_DIR/DerivedData"
PROFILE="${IRIS_MACOS_RUST_PROFILE:-debug}"
TARGETS="${IRIS_MACOS_RUST_TARGETS:-aarch64-apple-darwin}"
MACOS_DIST_DIR="$ROOT/dist/macos"
MACOS_APP_NAME="${IRIS_MACOS_APP_NAME:-Iris Chat.app}"

usage() {
  cat <<'EOF'
usage: ./scripts/macos-build <macos-gen-swift|macos-rust|macos-xcframework|macos-xcodeproj|macos-build|macos-test|macos-ui-test|macos-app|macos-notarize|macos-dmg|macos-updater-archive>

Signing & notarization (login-keychain mode, recommended):
  MACOS_SIGNING_IDENTITY  e.g. "Developer ID Application: Your Name (TEAMID)"
                          (must be present in login keychain; otherwise unsigned)
  MACOS_NOTARY_PROFILE    notarytool keychain profile name (created via
                          xcrun notarytool store-credentials <name>); skipping
                          notarization is fine for ad-hoc local testing

Focused UI tests:
  IRIS_MACOS_ONLY_TESTING  comma or space separated Xcode test identifiers,
                          e.g. IrisChatMacUITests/IrisChatUITests/testName
EOF
}

extract_team_id() {
  local identity="$1"
  if [[ "$identity" =~ \(([A-Z0-9]{10})\)[[:space:]]*$ ]]; then
    printf '%s\n' "${BASH_REMATCH[1]}"
  fi
}

host_dynamic_lib() {
  local ext
  case "$(uname -s)" in
    Darwin) ext="dylib" ;;
    Linux) ext="so" ;;
    *) ext="dylib" ;;
  esac
  printf '%s/%s/libiris_chat_core.%s\n' "$(target_root)" "$PROFILE" "$ext"
}

target_static_lib() {
  local target="$1"
  printf '%s/%s/%s/libiris_chat_core.a\n' "$(macos_rust_target_root)" "$target" "$PROFILE"
}

target_root() {
  local dir="${CARGO_TARGET_DIR:-}"
  if [[ -z "$dir" ]]; then
    dir="$(
      cargo metadata \
        --manifest-path "$CORE_DIR/Cargo.toml" \
        --format-version 1 \
        --no-deps \
        | python3 -c 'import json, sys; print(json.load(sys.stdin)["target_directory"])'
    )"
  fi
  if [[ "$dir" = /* ]]; then
    printf '%s\n' "$dir"
  else
    printf '%s/%s\n' "$CORE_DIR" "$dir"
  fi
}

macos_rust_target_root() {
  local dir="${IRIS_MACOS_CARGO_TARGET_DIR:-$MACOS_BUILD_DIR/cargo-target}"
  if [[ "$dir" = /* ]]; then
    printf '%s\n' "$dir"
  else
    printf '%s/%s\n' "$ROOT" "$dir"
  fi
}

build_host() {
  (
    cd "$CORE_DIR"
    if [[ "$PROFILE" == "release" ]]; then
      cargo build --release
    else
      cargo build
    fi
  )
}

run_macos_gen_swift() {
  local lib_path
  build_host
  lib_path="$(host_dynamic_lib)"
  rm -rf "$IOS_BINDINGS_DIR"
  mkdir -p "$IOS_BINDINGS_DIR"
  (
    cd "$CORE_DIR"
    cargo run -q --manifest-path "$CORE_DIR/uniffi-bindgen/Cargo.toml" -- generate \
      --library "$lib_path" \
      --language swift \
      --out-dir "$IOS_BINDINGS_DIR" \
      --config "$CORE_DIR/uniffi.toml"
  )
}

run_macos_rust() {
  local target
  local dev_dir
  local toolchain_bin
  local cc_bin
  local cxx_bin
  local ar_bin
  local ranlib_bin
  local sdkroot
  local min_version="14.0"
  local arch_target
  local rustflags_env_var
  local target_rustflags

  dev_dir="$(xcode-select -p)"
  toolchain_bin="$dev_dir/Toolchains/XcodeDefault.xctoolchain/usr/bin"
  cc_bin="$toolchain_bin/clang"
  cxx_bin="$toolchain_bin/clang++"
  ar_bin="$toolchain_bin/ar"
  ranlib_bin="$toolchain_bin/ranlib"
  sdkroot="$(xcrun --sdk macosx --show-sdk-path)"

  (
    cd "$CORE_DIR"
    for target in $TARGETS; do
      case "$target" in
        aarch64-apple-darwin)
          arch_target="arm64-apple-macos${min_version}"
          rustflags_env_var="CARGO_TARGET_AARCH64_APPLE_DARWIN_RUSTFLAGS"
          ;;
        x86_64-apple-darwin)
          arch_target="x86_64-apple-macos${min_version}"
          rustflags_env_var="CARGO_TARGET_X86_64_APPLE_DARWIN_RUSTFLAGS"
          ;;
        *)
          echo "Unsupported macOS target: $target" >&2
          exit 2
          ;;
      esac
      target_rustflags="-C linker=$cc_bin -C link-arg=-target -C link-arg=$arch_target -C link-arg=-mmacosx-version-min=${min_version}"
      if [[ "$PROFILE" == "release" ]]; then
        env \
          SDKROOT="$sdkroot" \
          MACOSX_DEPLOYMENT_TARGET="$min_version" \
          CC="$cc_bin" \
          CXX="$cxx_bin" \
          AR="$ar_bin" \
          RANLIB="$ranlib_bin" \
          CARGO_TARGET_DIR="$(macos_rust_target_root)" \
          CFLAGS_aarch64_apple_darwin="-target arm64-apple-macos${min_version} -mmacosx-version-min=${min_version}" \
          CFLAGS_x86_64_apple_darwin="-target x86_64-apple-macos${min_version} -mmacosx-version-min=${min_version}" \
          CXXFLAGS_aarch64_apple_darwin="-target arm64-apple-macos${min_version} -mmacosx-version-min=${min_version}" \
          CXXFLAGS_x86_64_apple_darwin="-target x86_64-apple-macos${min_version} -mmacosx-version-min=${min_version}" \
          CARGO_TARGET_AARCH64_APPLE_DARWIN_LINKER="$cc_bin" \
          CARGO_TARGET_X86_64_APPLE_DARWIN_LINKER="$cc_bin" \
          "$rustflags_env_var=$target_rustflags" \
          IRIS_APP_VERSION="${IRIS_APP_VERSION_NAME:-}" \
          IRIS_BUILD_GIT_SHA="${IRIS_BUILD_GIT_SHA:-}" \
          IRIS_BUILD_TIMESTAMP_UTC="${IRIS_BUILD_TIMESTAMP_UTC:-}" \
          cargo build --release --target "$target"
      else
        env \
          SDKROOT="$sdkroot" \
          MACOSX_DEPLOYMENT_TARGET="$min_version" \
          CC="$cc_bin" \
          CXX="$cxx_bin" \
          AR="$ar_bin" \
          RANLIB="$ranlib_bin" \
          CARGO_TARGET_DIR="$(macos_rust_target_root)" \
          CFLAGS_aarch64_apple_darwin="-target arm64-apple-macos${min_version} -mmacosx-version-min=${min_version}" \
          CFLAGS_x86_64_apple_darwin="-target x86_64-apple-macos${min_version} -mmacosx-version-min=${min_version}" \
          CXXFLAGS_aarch64_apple_darwin="-target arm64-apple-macos${min_version} -mmacosx-version-min=${min_version}" \
          CXXFLAGS_x86_64_apple_darwin="-target x86_64-apple-macos${min_version} -mmacosx-version-min=${min_version}" \
          CARGO_TARGET_AARCH64_APPLE_DARWIN_LINKER="$cc_bin" \
          CARGO_TARGET_X86_64_APPLE_DARWIN_LINKER="$cc_bin" \
          "$rustflags_env_var=$target_rustflags" \
          IRIS_APP_VERSION="${IRIS_APP_VERSION_NAME:-}" \
          IRIS_BUILD_GIT_SHA="${IRIS_BUILD_GIT_SHA:-}" \
          IRIS_BUILD_TIMESTAMP_UTC="${IRIS_BUILD_TIMESTAMP_UTC:-}" \
          cargo build --target "$target"
      fi
    done
  )
}

run_macos_xcframework() {
  local headers_dir="$MACOS_BUILD_DIR/headers"
  local universal_lib="$MACOS_BUILD_DIR/libiris_chat_core_macos.a"
  local output="$MACOS_FRAMEWORKS_DIR/IrisChatCore.xcframework"
  local header_path
  local modulemap_path

  run_macos_gen_swift
  run_macos_rust

  header_path="$(find "$IOS_BINDINGS_DIR" -maxdepth 1 -name '*.h' | head -n 1)"
  modulemap_path="$(find "$IOS_BINDINGS_DIR" -maxdepth 1 -name '*.modulemap' | head -n 1)"
  if [[ -z "${header_path:-}" || -z "${modulemap_path:-}" ]]; then
    echo "Missing generated Swift headers/modulemap in $IOS_BINDINGS_DIR" >&2
    exit 1
  fi

  rm -rf "$headers_dir" "$universal_lib" "$output"
  mkdir -p "$headers_dir" "$MACOS_FRAMEWORKS_DIR" "$MACOS_BUILD_DIR"
  cp "$header_path" "$headers_dir/"
  cp "$modulemap_path" "$headers_dir/module.modulemap"

  local libs=()
  for target in $TARGETS; do
    libs+=("$(target_static_lib "$target")")
  done

  if [[ "${#libs[@]}" -eq 1 ]]; then
    cp "${libs[0]}" "$universal_lib"
  else
    lipo -create "${libs[@]}" -output "$universal_lib"
  fi

  xcodebuild -create-xcframework \
    -library "$universal_lib" \
    -headers "$headers_dir" \
    -output "$output"
}

run_macos_xcodeproj() {
  (
    cd "$MACOS_DIR"
    xcodegen generate --spec project.yml
  )
}

stop_running_macos_app() {
  killall "${MACOS_APP_NAME%.app}" 2>/dev/null || true
}

run_macos_build() {
  local host_arch
  host_arch="$(uname -m)"
  run_macos_xcframework
  run_macos_xcodeproj
  xcodebuild \
    -project "$MACOS_DIR/IrisChatMac.xcodeproj" \
    -scheme IrisChatMac \
    -derivedDataPath "$MACOS_DERIVED_DATA" \
    -destination "platform=macOS,arch=$host_arch" \
    CODE_SIGNING_ALLOWED=NO \
    ARCHS="$host_arch" \
    VALID_ARCHS="$host_arch" \
    ONLY_ACTIVE_ARCH=YES \
    build
}

run_macos_test() {
  local host_arch
  host_arch="$(uname -m)"
  run_macos_xcframework
  run_macos_xcodeproj
  stop_running_macos_app
  xcodebuild \
    -project "$MACOS_DIR/IrisChatMac.xcodeproj" \
    -scheme IrisChatMac \
    -derivedDataPath "$MACOS_DERIVED_DATA" \
    -destination "platform=macOS,arch=$host_arch" \
    CODE_SIGNING_ALLOWED=NO \
    ARCHS="$host_arch" \
    VALID_ARCHS="$host_arch" \
    ONLY_ACTIVE_ARCH=YES \
    -skip-testing:IrisChatMacUITests \
    test
}

run_macos_ui_test() {
  local host_arch
  local only_testing_args=()
  local raw_only="${IRIS_MACOS_ONLY_TESTING:-}"
  local timeout_secs="${IRIS_MACOS_UI_TEST_XCODEBUILD_TIMEOUT_SECS:-1800}"
  local suspended_runner_timeout_secs="${IRIS_MACOS_UI_TEST_SUSPENDED_RUNNER_TIMEOUT_SECS:-90}"
  local xcode_status=0
  local test_id
  host_arch="$(uname -m)"

  if [[ ! "$timeout_secs" =~ ^[0-9]+$ || "$timeout_secs" -le 0 ]]; then
    echo "IRIS_MACOS_UI_TEST_XCODEBUILD_TIMEOUT_SECS must be a positive integer." >&2
    exit 2
  fi
  if [[ ! "$suspended_runner_timeout_secs" =~ ^[0-9]+$ || "$suspended_runner_timeout_secs" -le 0 ]]; then
    echo "IRIS_MACOS_UI_TEST_SUSPENDED_RUNNER_TIMEOUT_SECS must be a positive integer." >&2
    exit 2
  fi

  raw_only="${raw_only//,/ }"
  for test_id in ${raw_only}; do
    [[ -n "$test_id" ]] || continue
    only_testing_args+=("-only-testing:${test_id}")
  done

  run_macos_xcframework
  run_macos_xcodeproj
  stop_running_macos_app
  local xcode_args=(
    -project "$MACOS_DIR/IrisChatMac.xcodeproj"
    -scheme IrisChatMacUI
    -derivedDataPath "$MACOS_DERIVED_DATA"
    -destination "platform=macOS,arch=$host_arch"
    CODE_SIGNING_ALLOWED=NO
    ARCHS="$host_arch"
    VALID_ARCHS="$host_arch"
    ONLY_ACTIVE_ARCH=YES
  )
  if [[ "${#only_testing_args[@]}" -gt 0 ]]; then
    xcode_args+=("${only_testing_args[@]}")
  fi
  xcode_args+=(
    -test-timeouts-enabled YES
    -default-test-execution-time-allowance 60
    -maximum-test-execution-time-allowance 180
    test
  )
  python3 - "$timeout_secs" "$suspended_runner_timeout_secs" "${xcode_args[@]}" <<'PY' || xcode_status=$?
import os
import signal
import subprocess
import sys
import time

timeout_secs = int(sys.argv[1])
suspended_runner_timeout_secs = int(sys.argv[2])
cmd = ["xcodebuild", *sys.argv[3:]]
proc = subprocess.Popen(cmd, start_new_session=True)


def terminate_process_group(exit_code):
    try:
        os.killpg(proc.pid, signal.SIGTERM)
    except ProcessLookupError:
        pass
    try:
        proc.wait(timeout=15)
    except subprocess.TimeoutExpired:
        try:
            os.killpg(proc.pid, signal.SIGKILL)
        except ProcessLookupError:
            pass
        proc.wait()
    raise SystemExit(exit_code)


def runner_pids():
    try:
        result = subprocess.run(
            ["pgrep", "-f", "IrisChatMacUITests-Runner"],
            capture_output=True,
            text=True,
            timeout=5,
            check=False,
        )
    except (OSError, subprocess.TimeoutExpired):
        return []
    pids = []
    for line in result.stdout.splitlines():
        line = line.strip()
        if line.isdigit():
            pids.append(line)
    return pids


def runner_is_launched_suspended(pid):
    try:
        result = subprocess.run(
            ["vmmap", "-summary", pid],
            capture_output=True,
            text=True,
            timeout=5,
            check=False,
        )
    except (OSError, subprocess.TimeoutExpired):
        return False
    output = result.stdout + result.stderr
    return "Process exists but has not started" in output


def print_runner_diagnostics(pid):
    print(
        "IrisChatMacUITests-Runner stayed launched-suspended "
        f"for {suspended_runner_timeout_secs}s; macOS UI testing is likely "
        "blocked by the VM GUI/session/TCC handoff.",
        file=sys.stderr,
    )
    print(f"suspended_runner_pid={pid}", file=sys.stderr)
    try:
        result = subprocess.run(
            ["ps", "-ax", "-o", "pid,ppid,stat,comm,args"],
            capture_output=True,
            text=True,
            timeout=5,
            check=False,
        )
        for line in result.stdout.splitlines():
            if (
                "xcodebuild" in line
                or "IrisChatMacUITests" in line
                or "testmanagerd" in line
                or "Iris Chat.app" in line
            ):
                print(line, file=sys.stderr)
    except (OSError, subprocess.TimeoutExpired):
        pass


deadline = time.monotonic() + timeout_secs
suspended_since = {}
while True:
    exit_code = proc.poll()
    if exit_code is not None:
        raise SystemExit(exit_code)

    now = time.monotonic()
    if now >= deadline:
        print(f"xcodebuild timed out after {timeout_secs}s", file=sys.stderr)
        terminate_process_group(124)

    for pid in runner_pids():
        if runner_is_launched_suspended(pid):
            suspended_since.setdefault(pid, now)
            if now - suspended_since[pid] >= suspended_runner_timeout_secs:
                print_runner_diagnostics(pid)
                terminate_process_group(125)
        else:
            suspended_since.pop(pid, None)

    time.sleep(min(5, max(0.1, deadline - now)))
PY
  if [[ "$xcode_status" -ne 0 ]]; then
    pkill -f "IrisChatMacUITests-Runner" 2>/dev/null || true
  fi
  return "$xcode_status"
}

run_macos_app() {
  PROFILE="release"
  TARGETS="${IRIS_MACOS_RUST_TARGETS:-aarch64-apple-darwin}"
  export IRIS_MACOS_RUST_PROFILE="release"
  resolve_shared_build_metadata "$ROOT"

  run_macos_xcframework
  run_macos_xcodeproj

  mkdir -p "$MACOS_DIST_DIR"
  local derived="$MACOS_DIST_DIR/.derived"
  rm -rf "$derived"

  local sign_args=()
  local identity="${MACOS_SIGNING_IDENTITY:-}"
  if [[ -n "$identity" ]]; then
    if ! security find-identity -v -p codesigning 2>/dev/null | grep -Fq "$identity"; then
      echo "macos-app: signing identity not found in login keychain: $identity" >&2
      exit 1
    fi
    require_var IRIS_MACOS_PROVISIONING_PROFILE_SPECIFIER
    require_var IRIS_MACOS_SHARE_PROVISIONING_PROFILE_SPECIFIER
    local team_id
    team_id="$(extract_team_id "$identity")"
    sign_args=(
      CODE_SIGN_STYLE=Manual
      CODE_SIGN_IDENTITY="$identity"
      "DEVELOPMENT_TEAM=${team_id}"
      "IRIS_MACOS_PROVISIONING_PROFILE_SPECIFIER=$IRIS_MACOS_PROVISIONING_PROFILE_SPECIFIER"
      "IRIS_MACOS_SHARE_PROVISIONING_PROFILE_SPECIFIER=$IRIS_MACOS_SHARE_PROVISIONING_PROFILE_SPECIFIER"
      ENABLE_HARDENED_RUNTIME=YES
      CODE_SIGN_INJECT_BASE_ENTITLEMENTS=NO
      OTHER_CODE_SIGN_FLAGS="--timestamp"
    )
  else
    sign_args=(
      CODE_SIGN_STYLE=Manual
      CODE_SIGNING_REQUIRED=NO
      CODE_SIGNING_ALLOWED=NO
      CODE_SIGN_IDENTITY=""
      DEVELOPMENT_TEAM=""
    )
  fi

  local xcode_log="$MACOS_DIST_DIR/.macos-app-xcodebuild.log"
  local xcode_attempt=1
  while true; do
    rm -f "$xcode_log"
    set +e
    xcodebuild \
      -project "$MACOS_DIR/IrisChatMac.xcodeproj" \
      -scheme IrisChatMac \
      -configuration Release \
      -derivedDataPath "$derived" \
      -destination 'platform=macOS,arch=arm64' \
      ARCHS=arm64 \
      VALID_ARCHS=arm64 \
      ONLY_ACTIVE_ARCH=NO \
      "MARKETING_VERSION=$(apple_marketing_version "$IRIS_APP_VERSION_NAME")" \
      "CURRENT_PROJECT_VERSION=$IRIS_APP_VERSION_CODE" \
      "${sign_args[@]}" \
      build 2>&1 | tee "$xcode_log"
    local xcode_status="${PIPESTATUS[0]}"
    set -e

    if [[ "$xcode_status" -eq 0 ]]; then
      break
    fi

    if [[ "$xcode_attempt" -lt 3 ]] \
      && [[ -n "$identity" ]] \
      && grep -Fq "A timestamp was expected but was not found" "$xcode_log"; then
      xcode_attempt=$((xcode_attempt + 1))
      echo "macos-app: codesign timestamp was missing; retrying xcodebuild ($xcode_attempt/3)" >&2
      sleep 3
      continue
    fi
    return "$xcode_status"
  done

  local app_src
  app_src="$(find "$derived/Build/Products/Release" -maxdepth 1 -name '*.app' | head -n 1)"
  if [[ -z "${app_src:-}" || ! -d "$app_src" ]]; then
    echo "macos-app: no .app produced under $derived/Build/Products/Release" >&2
    exit 1
  fi

  local dest="$MACOS_DIST_DIR/$MACOS_APP_NAME"
  rm -rf "$dest"
  cp -R "$app_src" "$dest"

  if [[ -n "$identity" ]]; then
    codesign --verify --deep --strict --verbose=2 "$dest"
  fi

  printf '%s\n' "$dest"
}

submit_notarization() {
  local artifact="$1"
  local label="$2"
  local submit_output

  local notary_args=()
  if [[ -n "${IRIS_ASC_AUTH_KEY_PATH:-}" && -n "${IRIS_ASC_AUTH_KEY_ID:-}" && -n "${IRIS_ASC_AUTH_KEY_ISSUER_ID:-}" ]]; then
    notary_args=(
      --key "$IRIS_ASC_AUTH_KEY_PATH"
      --key-id "$IRIS_ASC_AUTH_KEY_ID"
      --issuer "$IRIS_ASC_AUTH_KEY_ISSUER_ID"
    )
  elif [[ -n "${MACOS_NOTARY_PROFILE:-}" ]]; then
    notary_args=(--keychain-profile "$MACOS_NOTARY_PROFILE")
  else
    echo "$label: no notarization credentials configured; skipping notarization" >&2
    return 0
  fi

  if ! submit_output="$(xcrun notarytool submit "$artifact" \
        "${notary_args[@]}" \
        --wait \
        --output-format json 2>&1)"; then
    echo "$submit_output" >&2
    exit 1
  fi

  local status submission_id
  status="$(printf '%s' "$submit_output" | /usr/bin/python3 -c 'import json,sys; print(json.load(sys.stdin).get("status",""))')"
  submission_id="$(printf '%s' "$submit_output" | /usr/bin/python3 -c 'import json,sys; print(json.load(sys.stdin).get("id",""))')"

  if [[ "$status" != "Accepted" ]]; then
    echo "$label: notarization status was '$status' (expected 'Accepted')" >&2
    if [[ -n "$submission_id" ]]; then
      xcrun notarytool log "$submission_id" "${notary_args[@]}" >&2 || true
    fi
    exit 1
  fi
}

has_macos_notary_credentials() {
  [[ -n "${MACOS_NOTARY_PROFILE:-}" ]] || {
    [[ -n "${IRIS_ASC_AUTH_KEY_PATH:-}" && -n "${IRIS_ASC_AUTH_KEY_ID:-}" && -n "${IRIS_ASC_AUTH_KEY_ISSUER_ID:-}" ]]
  }
}

macos_release_tag() {
  local tag="${IRIS_RELEASE_TAG:-}"
  if [[ -z "$tag" ]]; then
    resolve_shared_build_metadata "$ROOT"
    tag="v${IRIS_APP_VERSION_NAME}"
  fi
  printf '%s\n' "${tag:-vdev}"
}

run_macos_notarize() {
  local app="$MACOS_DIST_DIR/$MACOS_APP_NAME"
  if [[ ! -d "$app" ]]; then
    run_macos_app >/dev/null
  fi

  if ! has_macos_notary_credentials; then
    echo "macos-notarize: MACOS_NOTARY_PROFILE not set; skipping notarization (the .app will install but show Gatekeeper warnings)" >&2
    return 0
  fi

  if ! codesign --verify --deep --strict "$app" 2>/dev/null; then
    echo "macos-notarize: $app is not signed; set MACOS_SIGNING_IDENTITY and rebuild before notarizing" >&2
    exit 1
  fi

  local zip
  zip="$(mktemp -t iris-chat-notarize.XXXXXX).zip"
  rm -f "$zip"
  ditto -c -k --sequesterRsrc --keepParent "$app" "$zip"

  submit_notarization "$zip" "macos-notarize"
  rm -f "$zip"

  xcrun stapler staple "$app"
  xcrun stapler validate "$app"
  printf '%s\n' "$app"
}

run_macos_dmg() {
  local app="$MACOS_DIST_DIR/$MACOS_APP_NAME"
  run_macos_app >/dev/null

  if [[ -n "${MACOS_SIGNING_IDENTITY:-}" ]] && has_macos_notary_credentials; then
    if ! xcrun stapler validate "$app" >/dev/null 2>&1; then
      run_macos_notarize >/dev/null
    fi
  fi

  local tag
  tag="$(macos_release_tag)"

  local dmg="$MACOS_DIST_DIR/iris-chat-${tag}-macos-arm64.dmg"
  rm -f "$dmg"

  local stage
  stage="$(mktemp -d "${TMPDIR:-/tmp}/iris-chat-dmg.XXXXXX")"
  cp -R "$app" "$stage/"
  ln -s /Applications "$stage/Applications"

  hdiutil create \
    -volname "Iris Chat" \
    -srcfolder "$stage" \
    -fs HFS+ \
    -format UDZO \
    -ov \
    "$dmg"

  rm -rf "$stage"

  if [[ -n "${MACOS_SIGNING_IDENTITY:-}" ]] && has_macos_notary_credentials; then
    submit_notarization "$dmg" "macos-dmg"
    xcrun stapler staple "$dmg"
    xcrun stapler validate "$dmg"
  fi

  printf '%s\n' "$dmg"
}

run_macos_updater_archive() {
  local app="$MACOS_DIST_DIR/$MACOS_APP_NAME"
  if [[ "${IRIS_MACOS_FORCE_REBUILD_APP:-true}" == "true" || "${IRIS_MACOS_FORCE_REBUILD_APP:-true}" == "1" || ! -d "$app" ]]; then
    run_macos_app >/dev/null
  fi

  if [[ -n "${MACOS_SIGNING_IDENTITY:-}" ]] && has_macos_notary_credentials; then
    if ! xcrun stapler validate "$app" >/dev/null 2>&1; then
      run_macos_notarize >/dev/null
    fi
  fi

  local tag archive
  tag="$(macos_release_tag)"
  archive="$MACOS_DIST_DIR/iris-chat-${tag}-macos-arm64.app.tar.gz"
  rm -f "$archive"
  tar -czf "$archive" -C "$MACOS_DIST_DIR" "$MACOS_APP_NAME"
  printf '%s\n' "$archive"
}

case "${1:-}" in
  macos-gen-swift) run_macos_gen_swift ;;
  macos-rust) run_macos_rust ;;
  macos-xcframework) run_macos_xcframework ;;
  macos-xcodeproj) run_macos_xcodeproj ;;
  macos-build) run_macos_build ;;
  macos-test) run_macos_test ;;
  macos-ui-test) run_macos_ui_test ;;
  macos-app) run_macos_app ;;
  macos-notarize) run_macos_notarize ;;
  macos-dmg) run_macos_dmg ;;
  macos-updater-archive) run_macos_updater_archive ;;
  -h|--help|help) usage ;;
  *) usage >&2; exit 2 ;;
esac
