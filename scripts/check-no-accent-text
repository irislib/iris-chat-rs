#!/usr/bin/env python3

"""Fail-the-gate guard: brand-purple (`palette.accent`,
`palette.bubbleMine`, `IrisPurple`, raw `#702ACE`) is reserved for
surfaces. Text and icons must never sit on top of the chat canvas in
purple — they look like accidental tap targets rather than content.

We grep the platform shells for the obvious offending patterns
(`foregroundStyle(palette.accent)`, `tint = IrisTheme.palette.accent`,
etc.) and exit non-zero when any are found. A few brand surfaces are
allowlisted by file+keyword (the welcome-screen "iris" wordmark, etc.)
so the wordmark itself can stay purple.

The check is intentionally pattern-based instead of AST-aware so
adding a new platform/file doesn't require updating a parser — the
rule is simply "don't pass a purple token as a foreground/text/icon
colour, ever."
"""

import re
import sys
from pathlib import Path


ROOT = Path(__file__).resolve().parents[1]


# Each entry: (glob, [(regex, description)]).
# A line that matches a regex is reported as a violation unless its
# trimmed form appears in `ALLOWLIST` below.
RULES = [
    (
        "ios/Sources/**/*.swift",
        [
            (re.compile(r"foregroundStyle\(\s*palette\.(?:accent|bubbleMine)\b"),
             "SwiftUI text/icon in accent"),
            (re.compile(r"\.tint\(\s*palette\.(?:accent|bubbleMine)\b"),
             "SwiftUI tint in accent"),
        ],
    ),
    (
        "android/app/src/main/**/*.kt",
        [
            (re.compile(r"color\s*=\s*IrisTheme\.palette\.(?:accent|bubbleMine)\b"),
             "Compose text/spinner color in accent"),
            (re.compile(r"tint\s*=\s*IrisTheme\.palette\.(?:accent|bubbleMine)\b"),
             "Compose icon tint in accent"),
            (re.compile(r"contentColor\s*=\s*IrisTheme\.palette\.(?:accent|bubbleMine)\b"),
             "Compose contentColor in accent"),
            (re.compile(r"tint\s*=\s*IrisPurple\b"), "Compose icon tint in IrisPurple"),
            (re.compile(r"color\s*=\s*IrisPurple\b"), "Compose text color in IrisPurple"),
        ],
    ),
    (
        "linux/src/**/*.rs",
        [
            # GTK CSS color hex literal for brand purple. set_text_color
            # / add_css_class("accent") style purple-text rules belong on
            # surfaces only.
            (re.compile(r'"\s*color:\s*#702ACE'),
             "GTK CSS sets text color to brand purple"),
        ],
    ),
]


# Patterns whose appearance within ~3 lines of a violation excuses
# it. Surface backgrounds, glass-material tints, the system-wide
# accent tint, and progress indicators (which historically take the
# brand colour to read as "in progress") are all considered surfaces
# rather than text/icon affordances.
GLOBAL_ALLOWLIST_CONTEXT: list[re.Pattern] = [
    re.compile(r"\bSurface\("),
    re.compile(r"\bCircularProgressIndicator\("),
    re.compile(r"\bLinearProgressIndicator\("),
    re.compile(r"glassEffect\("),
    re.compile(r"\.progressViewStyle\("),
    re.compile(r"// brand-purple ok"),
]


# Per-file phrase allowlist (matched against the violating line and
# the two lines above it).
ALLOWLIST = {
    # iOS welcome wordmark — half of the logotype is intentionally
    # purple ("iris" purple + " chat" textPrimary).
    "ios/Sources/Views.swift": [
        r'Text\("iris"\)',
    ],
    # Android welcome wordmark mirrors iOS.
    "android/app/src/main/java/to/iris/chat/ui/screens/WelcomeScreen.kt": [
        r'text\s*=\s*"iris"',
    ],
    # The chrome-root `IrisTheme` view sets the global SwiftUI tint so
    # built-in system controls (toolbar buttons, sheet "Cancel" etc.)
    # inherit the brand accent. Not a custom text/icon usage.
    "ios/Sources/IrisChrome.swift": [
        r"\.environment\(\\.irisPalette",
    ],
}


def violation_allowed(rel_path: str, lines: list[str], line_index: int) -> bool:
    # Look 6 lines back so multi-line Compose / SwiftUI calls catch
    # the function name on a prior line (Surface(...) with several
    # modifier args before `color =` is the worst offender).
    context = "\n".join(lines[max(0, line_index - 6): line_index + 1])

    for pattern in GLOBAL_ALLOWLIST_CONTEXT:
        if pattern.search(context):
            return True

    patterns = ALLOWLIST.get(rel_path, [])
    for pat in patterns:
        if re.search(pat, context):
            return True
    return False


def main() -> int:
    violations: list[str] = []
    for glob, rules in RULES:
        for path in ROOT.glob(glob):
            try:
                text = path.read_text(encoding="utf-8")
            except OSError:
                continue
            lines = text.splitlines()
            for index, line in enumerate(lines):
                for pattern, label in rules:
                    if not pattern.search(line):
                        continue
                    rel = path.relative_to(ROOT).as_posix()
                    if violation_allowed(rel, lines, index):
                        continue
                    violations.append(f"{rel}:{index + 1}: {label}: {line.strip()}")

    if violations:
        print("Brand purple must not appear as text or icon tint:", file=sys.stderr)
        for entry in violations:
            print(f"  {entry}", file=sys.stderr)
        print(
            "\nFix: use `palette.textPrimary` / `palette.muted` for text and "
            "`MaterialTheme.colorScheme.onBackground` for Compose icons, or "
            "render the affected element on top of a `palette.accent` "
            "surface and switch the foreground to `onAccent`/`onBubbleMine`.",
            file=sys.stderr,
        )
        return 1
    print("No brand-purple text or icon tints found.")
    return 0


if __name__ == "__main__":
    sys.exit(main())
