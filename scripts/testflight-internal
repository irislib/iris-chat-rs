#!/usr/bin/env bash

set -Eeuo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
source "$ROOT/scripts/release_common.sh"

load_release_env "$ROOT"
resolve_shared_build_metadata "$ROOT"

IOS_BUNDLE_ID="${IRIS_IOS_BUNDLE_ID:-to.iris.chat}"
ACTION="${1:-put}"

usage() {
  cat <<'EOF'
usage: ./scripts/testflight-internal <put|attach|wait|status|groups|public|public-submit|public-attach|public-status|public-expire-older>

Commands:
  put      wait for the uploaded build, then attach it to internal TestFlight groups
  attach   attach the already-visible build to internal TestFlight groups
  wait     wait until the uploaded build is visible and valid
  status   print current App Store Connect build/internal-group status
  groups   list TestFlight groups for the app
  public   wait, prepare metadata, submit Beta App Review, and attach external groups
  public-submit
           submit the already-visible build for Beta App Review
  public-attach
           attach the already-visible build to external TestFlight groups
  public-status
           print current public TestFlight status
  public-expire-older
           expire older non-current builds that are still in Beta App Review

Environment:
  IRIS_TESTFLIGHT_GROUPS          optional comma-separated internal group names or IDs
  IRIS_TESTFLIGHT_PUBLIC_GROUPS   optional comma-separated external group names or IDs
  IRIS_TESTFLIGHT_WHATS_NEW       optional "What to Test" text
  IRIS_TESTFLIGHT_RELEASE_NOTES_FILE
                                  optional markdown file used for default "What to Test"
  IRIS_TESTFLIGHT_WAIT_ATTEMPTS   default 20
  IRIS_TESTFLIGHT_WAIT_SECONDS    default 30
  IRIS_ASC_API_IP                 optional api.appstoreconnect.apple.com IP override
  IRIS_ASC_TLS_MAX                optional TLS cap, for example 1.2
EOF
}

case "$ACTION" in
  put|attach|wait|status|groups|public|public-submit|public-attach|public-status|public-expire-older)
    ;;
  -h|--help|help)
    usage
    exit 0
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac

require_var IRIS_ASC_AUTH_KEY_PATH
require_var IRIS_ASC_AUTH_KEY_ID
require_var IRIS_ASC_AUTH_KEY_ISSUER_ID

if [[ ! -f "$IRIS_ASC_AUTH_KEY_PATH" ]]; then
  echo "ASC API key file not found: $IRIS_ASC_AUTH_KEY_PATH" >&2
  exit 1
fi

export IRIS_TESTFLIGHT_ACTION="$ACTION"
export IRIS_IOS_BUNDLE_ID="$IOS_BUNDLE_ID"
export IRIS_REPO_ROOT="$ROOT"

python3 <<'PY'
import base64
import json
import os
import socket
import ssl
import sys
import time
import urllib.error
import urllib.parse
import urllib.request

try:
    from cryptography.hazmat.primitives import hashes, serialization
    from cryptography.hazmat.primitives.asymmetric import ec, utils
except ImportError as exc:
    raise SystemExit(
        "Python package 'cryptography' is required for App Store Connect JWT signing."
    ) from exc


BASE_URL = "https://api.appstoreconnect.apple.com/v1/"
ACTION = os.environ["IRIS_TESTFLIGHT_ACTION"]
BUNDLE_ID = os.environ["IRIS_IOS_BUNDLE_ID"]
VERSION_NAME = os.environ["IRIS_APP_VERSION_NAME"]
BUILD_NUMBER = os.environ["IRIS_APP_VERSION_CODE"]
WAIT_ATTEMPTS = int(os.environ.get("IRIS_TESTFLIGHT_WAIT_ATTEMPTS", "20"))
WAIT_SECONDS = int(os.environ.get("IRIS_TESTFLIGHT_WAIT_SECONDS", "30"))
PUBLIC_ACTIONS = {
    "public",
    "public-submit",
    "public-attach",
    "public-status",
    "public-expire-older",
}

SCRIPTS_DIR = os.path.join(os.environ.get("IRIS_REPO_ROOT", "."), "scripts")
if SCRIPTS_DIR not in sys.path:
    sys.path.insert(0, SCRIPTS_DIR)

from testflight_notes import resolved_what_to_test


def fail(message, code=1):
    print(message, file=sys.stderr)
    raise SystemExit(code)


def b64url(data):
    return base64.urlsafe_b64encode(data).rstrip(b"=").decode("ascii")


def create_token():
    with open(os.environ["IRIS_ASC_AUTH_KEY_PATH"], "rb") as key_file:
        private_key = serialization.load_pem_private_key(key_file.read(), password=None)

    now = int(time.time())
    header = {
        "alg": "ES256",
        "kid": os.environ["IRIS_ASC_AUTH_KEY_ID"],
        "typ": "JWT",
    }
    payload = {
        "iss": os.environ["IRIS_ASC_AUTH_KEY_ISSUER_ID"],
        "iat": now,
        "exp": now + 20 * 60,
        "aud": "appstoreconnect-v1",
    }
    signing_input = (
        f"{b64url(json.dumps(header, separators=(',', ':')).encode())}."
        f"{b64url(json.dumps(payload, separators=(',', ':')).encode())}"
    ).encode("ascii")
    der_signature = private_key.sign(signing_input, ec.ECDSA(hashes.SHA256()))
    r_value, s_value = utils.decode_dss_signature(der_signature)
    signature = r_value.to_bytes(32, "big") + s_value.to_bytes(32, "big")
    return signing_input.decode("ascii") + "." + b64url(signature)


TOKEN = create_token()
ASC_API_HOST = "api.appstoreconnect.apple.com"
ASC_API_IP = os.environ.get("IRIS_ASC_API_IP", "").strip()
ASC_TLS_MAX = os.environ.get("IRIS_ASC_TLS_MAX", "").strip()

if ASC_API_IP:
    original_getaddrinfo = socket.getaddrinfo

    def getaddrinfo_override(host, port, *args, **kwargs):
        if host == ASC_API_HOST:
            return original_getaddrinfo(ASC_API_IP, port, *args, **kwargs)
        return original_getaddrinfo(host, port, *args, **kwargs)

    socket.getaddrinfo = getaddrinfo_override

SSL_CONTEXT = ssl.create_default_context()
if ASC_TLS_MAX in {"1.2", "TLS1.2", "TLSv1.2"}:
    SSL_CONTEXT.maximum_version = ssl.TLSVersion.TLSv1_2


def request(method, path_or_url, params=None, body=None):
    if path_or_url.startswith("https://"):
        url = path_or_url
    else:
        url = BASE_URL + path_or_url
        if params:
            url += "?" + urllib.parse.urlencode(params)

    data = json.dumps(body).encode("utf-8") if body is not None else None
    req = urllib.request.Request(
        url,
        data=data,
        method=method,
        headers={
            "Authorization": f"Bearer {TOKEN}",
            "Content-Type": "application/json",
        },
    )
    try:
        with urllib.request.urlopen(req, timeout=30, context=SSL_CONTEXT) as response:
            raw = response.read().decode("utf-8")
            return response.status, json.loads(raw) if raw else {}
    except urllib.error.HTTPError as error:
        raw = error.read().decode("utf-8", errors="replace")
        try:
            body = json.loads(raw)
        except json.JSONDecodeError:
            body = raw
        return error.code, body


def require_ok(status, body, operation):
    if 200 <= status < 300:
        return body
    fail(f"{operation} failed: HTTP {status}\n{json.dumps(body, indent=2)}")


def get_all(path, params=None):
    status, body = request("GET", path, params)
    body = require_ok(status, body, f"GET {path}")
    data = list(body.get("data", []))
    next_url = body.get("links", {}).get("next")
    while next_url:
        status, body = request("GET", next_url)
        body = require_ok(status, body, f"GET {next_url}")
        data.extend(body.get("data", []))
        next_url = body.get("links", {}).get("next")
    return data


def app_id():
    apps = get_all("apps", {"filter[bundleId]": BUNDLE_ID, "limit": "1"})
    if not apps:
        fail(f"No App Store Connect app found for bundle {BUNDLE_ID}")
    return apps[0]["id"]


APP_ID = app_id()


def find_build():
    builds = get_all(
        "builds",
        {
            "filter[app]": APP_ID,
            "filter[version]": BUILD_NUMBER,
            "limit": "1",
        },
    )
    return builds[0] if builds else None


def wait_for_valid_build():
    for attempt in range(1, WAIT_ATTEMPTS + 1):
        build = find_build()
        if build is not None:
            state = build["attributes"].get("processingState")
            print(
                f"Found TestFlight build {BUILD_NUMBER}: {state} "
                f"(attempt {attempt}/{WAIT_ATTEMPTS})",
                flush=True,
            )
            if state == "VALID":
                return build
            if state in {"FAILED", "INVALID"}:
                fail(f"Build {BUILD_NUMBER} is {state}")
        else:
            print(
                f"Waiting for TestFlight build {BUILD_NUMBER} "
                f"(attempt {attempt}/{WAIT_ATTEMPTS})",
                flush=True,
            )
        if attempt < WAIT_ATTEMPTS:
            time.sleep(WAIT_SECONDS)
    fail(f"Build {BUILD_NUMBER} did not become VALID in time")


def groups():
    return get_all("betaGroups", {"filter[app]": APP_ID, "limit": "200"})


def select_internal_groups(all_groups):
    wanted_raw = os.environ.get("IRIS_TESTFLIGHT_GROUPS", "").strip()
    if not wanted_raw:
        selected = [
            group
            for group in all_groups
            if group.get("attributes", {}).get("isInternalGroup") is True
        ]
    else:
        wanted = {item.strip() for item in wanted_raw.split(",") if item.strip()}
        selected = [
            group
            for group in all_groups
            if group["id"] in wanted or group.get("attributes", {}).get("name") in wanted
        ]
        matched = {
            group["id"] for group in selected
        } | {group.get("attributes", {}).get("name") for group in selected}
        missing = sorted(wanted - matched)
        if missing:
            fail(f"TestFlight group not found: {', '.join(missing)}")
        external = [
            group.get("attributes", {}).get("name", group["id"])
            for group in selected
            if group.get("attributes", {}).get("isInternalGroup") is not True
        ]
        if external and os.environ.get("IRIS_TESTFLIGHT_ALLOW_EXTERNAL") != "true":
            fail(
                "Refusing to attach external TestFlight group(s): "
                + ", ".join(external)
                + ". Set IRIS_TESTFLIGHT_ALLOW_EXTERNAL=true to override."
            )

    if not selected:
        fail("No internal TestFlight groups found")
    return selected


def select_external_groups(all_groups):
    wanted_raw = (
        os.environ.get("IRIS_TESTFLIGHT_PUBLIC_GROUPS", "").strip()
        or os.environ.get("IRIS_TESTFLIGHT_GROUPS", "").strip()
    )
    if not wanted_raw:
        selected = [
            group
            for group in all_groups
            if group.get("attributes", {}).get("isInternalGroup") is not True
        ]
    else:
        wanted = {item.strip() for item in wanted_raw.split(",") if item.strip()}
        selected = [
            group
            for group in all_groups
            if group["id"] in wanted or group.get("attributes", {}).get("name") in wanted
        ]
        matched = {
            group["id"] for group in selected
        } | {group.get("attributes", {}).get("name") for group in selected}
        missing = sorted(wanted - matched)
        if missing:
            fail(f"TestFlight group not found: {', '.join(missing)}")

    external = [
        group
        for group in selected
        if group.get("attributes", {}).get("isInternalGroup") is not True
    ]
    if len(external) != len(selected):
        fail("Refusing to attach internal group(s) in public TestFlight mode")
    if not external:
        fail("No external TestFlight groups found")
    return external


def group_has_build(group_id, build):
    for item in get_all(f"betaGroups/{group_id}/builds", {"limit": "200"}):
        if item["id"] == build["id"]:
            return True
    return False


def group_builds(group_id):
    return get_all(
        f"betaGroups/{group_id}/builds",
        {
            "fields[builds]": "version,expired,uploadedDate,processingState",
            "limit": "200",
        },
    )


def summarize_build(build, selected_groups=None):
    attrs = build["attributes"]
    print(f"Iris Chat {VERSION_NAME} ({BUILD_NUMBER})")
    print(f"Build: {build['id']}")
    print(f"State: {attrs.get('processingState')}")
    print(f"Audience: {attrs.get('buildAudienceType')}")
    print(f"Uploaded: {attrs.get('uploadedDate')}")

    all_groups = groups()
    selected = selected_groups or select_internal_groups(all_groups)
    print("Internal TestFlight groups:")
    for group in selected:
        attrs = group.get("attributes", {})
        attached = group_has_build(group["id"], build)
        print(f"  - {attrs.get('name', group['id'])}: {'attached' if attached else 'not attached'}")


def summarize_public_build(build, selected_groups):
    attrs = build["attributes"]
    print(f"Iris Chat {VERSION_NAME} ({BUILD_NUMBER})")
    print(f"Build: {build['id']}")
    print(f"State: {attrs.get('processingState')}")
    print(f"Audience: {attrs.get('buildAudienceType')}")
    print(f"Uploaded: {attrs.get('uploadedDate')}")
    print(f"Beta review: {beta_review_state(build)}")
    print("External TestFlight groups:")
    for group in selected_groups:
        attrs = group.get("attributes", {})
        attached = group_has_build(group["id"], build)
        link = attrs.get("publicLink")
        suffix = f" {link}" if link else ""
        print(f"  - {attrs.get('name', group['id'])}: {'attached' if attached else 'not attached'}{suffix}")


def attach_build(build, selected_groups):
    body = {
        "data": [
            {"type": "betaGroups", "id": group["id"]}
            for group in selected_groups
        ]
    }
    status, response_body = request(
        "POST",
        f"builds/{build['id']}/relationships/betaGroups",
        body=body,
    )
    if not (200 <= status < 300 or status == 409):
        fail(f"Attach failed: HTTP {status}\n{json.dumps(response_body, indent=2)}")

    failures = [
        group.get("attributes", {}).get("name", group["id"])
        for group in selected_groups
        if not group_has_build(group["id"], build)
    ]
    if failures:
        fail("Build was not found in group(s) after attach: " + ", ".join(failures))

    print(f"Attached build {BUILD_NUMBER} to internal TestFlight group(s):")
    for group in selected_groups:
        print(f"  - {group.get('attributes', {}).get('name', group['id'])}")


def attach_public_build(build, selected_groups):
    body = {
        "data": [
            {"type": "betaGroups", "id": group["id"]}
            for group in selected_groups
        ]
    }
    status, response_body = request(
        "POST",
        f"builds/{build['id']}/relationships/betaGroups",
        body=body,
    )
    if not (200 <= status < 300 or status == 409):
        fail(f"Attach failed: HTTP {status}\n{json.dumps(response_body, indent=2)}")

    print(f"Attached build {BUILD_NUMBER} to external TestFlight group(s):")
    for group in selected_groups:
        print(f"  - {group.get('attributes', {}).get('name', group['id'])}")


def ensure_public_build(build):
    state = build["attributes"].get("processingState")
    if state != "VALID":
        fail(f"Build {BUILD_NUMBER} is {state}, not VALID")
    if build["attributes"].get("buildAudienceType") == "INTERNAL_ONLY":
        fail(
            f"Build {BUILD_NUMBER} is INTERNAL_ONLY. Upload a new build with "
            "IRIS_IOS_INTERNAL_ONLY=false before public TestFlight submission."
        )


def beta_review_detail():
    status, body = request("GET", f"apps/{APP_ID}/betaAppReviewDetail")
    return require_ok(status, body, "Read beta app review detail").get("data")


def beta_app_localizations():
    return get_all(f"apps/{APP_ID}/betaAppLocalizations", {"limit": "200"})


def ensure_public_metadata():
    detail = beta_review_detail()
    attrs = detail.get("attributes", {}) if detail else {}
    required = ["contactFirstName", "contactLastName", "contactPhone", "contactEmail", "notes"]
    missing = [name for name in required if not attrs.get(name)]
    if attrs.get("demoAccountRequired") and not (
        attrs.get("demoAccountName") and attrs.get("demoAccountPassword")
    ):
        missing.append("demoAccountName/demoAccountPassword")

    localizations = beta_app_localizations()
    if not localizations:
        missing.append("betaAppLocalization")
    else:
        localization = localizations[0].get("attributes", {})
        for name in ["description", "feedbackEmail", "privacyPolicyUrl"]:
            if not localization.get(name):
                missing.append(name)

    if missing:
        fail("Missing TestFlight review metadata: " + ", ".join(missing))


def beta_build_localizations(build):
    return get_all(f"builds/{build['id']}/betaBuildLocalizations", {"limit": "200"})


def upsert_what_to_test(build):
    whats_new = resolved_what_to_test(
        VERSION_NAME,
        os.environ.get("IRIS_REPO_ROOT", "."),
        explicit=os.environ.get("IRIS_TESTFLIGHT_WHATS_NEW", ""),
        release_notes_file=os.environ.get(
            "IRIS_TESTFLIGHT_RELEASE_NOTES_FILE",
            "ZAPSTORE_RELEASE_NOTES.md",
        ),
    )
    locale = os.environ.get("IRIS_TESTFLIGHT_LOCALE", "en-US")
    existing = None
    for item in beta_build_localizations(build):
        if item.get("attributes", {}).get("locale") == locale:
            existing = item
            break

    if existing:
        status, body = request(
            "PATCH",
            f"betaBuildLocalizations/{existing['id']}",
            body={
                "data": {
                    "type": "betaBuildLocalizations",
                    "id": existing["id"],
                    "attributes": {"whatsNew": whats_new},
                }
            },
        )
        require_ok(status, body, "Update What to Test")
    else:
        status, body = request(
            "POST",
            "betaBuildLocalizations",
            body={
                "data": {
                    "type": "betaBuildLocalizations",
                    "attributes": {
                        "locale": locale,
                        "whatsNew": whats_new,
                    },
                    "relationships": {
                        "build": {
                            "data": {
                                "type": "builds",
                                "id": build["id"],
                            }
                        }
                    },
                }
            },
        )
        require_ok(status, body, "Create What to Test")
    print(f"Updated What to Test for {locale}")


def beta_review_state(build):
    status, body = request("GET", f"builds/{build['id']}/betaAppReviewSubmission")
    if status == 404:
        return "not submitted"
    if not (200 <= status < 300):
        return f"unknown (HTTP {status})"
    data = body.get("data")
    if not data:
        return "not submitted"
    return data.get("attributes", {}).get("betaReviewState") or data.get("attributes", {}).get("state") or "submitted"


def build_app_id(build_id):
    status, body = request("GET", f"builds/{build_id}/relationships/app")
    data = require_ok(status, body, f"Read app relationship for build {build_id}").get("data")
    return data.get("id") if data else None


def expire_build(build, reason):
    status, body = request(
        "PATCH",
        f"builds/{build['id']}",
        body={
            "data": {
                "type": "builds",
                "id": build["id"],
                "attributes": {"expired": True},
            }
        },
    )
    require_ok(status, body, f"Expire build {build['attributes'].get('version', build['id'])}")
    print(
        "Expired TestFlight build "
        f"{build['attributes'].get('version', build['id'])}: {reason}"
    )


def expire_older_public_review_builds(current_build):
    current_id = current_build["id"]
    expired = 0
    builds = get_all(
        "builds",
        {
            "filter[app]": APP_ID,
            "fields[builds]": "version,expired,uploadedDate,processingState",
            "limit": "200",
        },
    )
    for build in builds:
        if build["id"] == current_id:
            continue
        attrs = build.get("attributes", {})
        if attrs.get("expired"):
            continue
        state = beta_review_state(build)
        if state not in {"WAITING_FOR_REVIEW", "IN_REVIEW"}:
            continue
        expire_build(
            build,
            f"older Beta App Review submission was {state}; current build is {BUILD_NUMBER}",
        )
        expired += 1
    if expired == 0:
        print("No older Beta App Review builds needed expiring.")


def expire_older_external_group_builds(current_build, selected_groups):
    current_id = current_build["id"]
    expired = 0
    seen = set()
    for group in selected_groups:
        group_name = group.get("attributes", {}).get("name", group["id"])
        for build in group_builds(group["id"]):
            if build["id"] == current_id or build["id"] in seen:
                continue
            seen.add(build["id"])
            attrs = build.get("attributes", {})
            if attrs.get("expired"):
                continue
            expire_build(
                build,
                f"replaced by public TestFlight build {BUILD_NUMBER} in {group_name}",
            )
            expired += 1
    if expired == 0:
        print("No older external TestFlight group builds needed expiring.")


def expire_older_public_builds(current_build, selected_groups):
    expire_older_external_group_builds(current_build, selected_groups)
    expire_older_public_review_builds(current_build)


def submit_beta_review(build):
    state = beta_review_state(build)
    if state not in {"not submitted", "REJECTED"}:
        print(f"Beta App Review already submitted: {state}")
        return

    status, body = request(
        "POST",
        "betaAppReviewSubmissions",
        body={
            "data": {
                "type": "betaAppReviewSubmissions",
                "relationships": {
                    "build": {
                        "data": {
                            "type": "builds",
                            "id": build["id"],
                        }
                    }
                },
            }
        },
    )
    if status == 409:
        print("Beta App Review submission already exists")
        return
    # Apple serializes Beta App Review by "train" (major.minor.patch). When
    # we ship multiple builds for the same train (a v2026.5.10.5 right after
    # v2026.5.10.1 — both strip to 2026.5.10), the second submit returns
    # 422 ENTITY_UNPROCESSABLE.ANOTHER_BUILD_IN_REVIEW until the prior one
    # clears review. Treat it as a soft skip so the rest of the release
    # pipeline (htree publish, Homebrew tap) keeps going. The build is
    # already attached to internal groups; resubmit with `testflight-public
    # submit` once Apple finishes the prior review.
    if status == 422 and any(
        error.get("code") == "ENTITY_UNPROCESSABLE.ANOTHER_BUILD_IN_REVIEW"
        for error in body.get("errors", [])
    ):
        print(
            "Another build in this train is still in review; expiring older "
            "Beta App Review builds and retrying submission."
        )
        expire_older_public_review_builds(build)
        status, body = request(
            "POST",
            "betaAppReviewSubmissions",
            body={
                "data": {
                    "type": "betaAppReviewSubmissions",
                    "relationships": {
                        "build": {
                            "data": {
                                "type": "builds",
                                "id": build["id"],
                            }
                        }
                    },
                }
            },
        )
        if status == 409:
            print("Beta App Review submission already exists")
            return
    require_ok(status, body, "Submit Beta App Review")
    data = body.get("data", {})
    review_state = data.get("attributes", {}).get("betaReviewState") or "submitted"
    print(f"Submitted build {BUILD_NUMBER} for Beta App Review: {review_state}")


if ACTION == "groups":
    print(f"TestFlight groups for {BUNDLE_ID}:")
    for group in groups():
        attrs = group.get("attributes", {})
        kind = "internal" if attrs.get("isInternalGroup") else "external"
        print(f"  - {attrs.get('name', group['id'])} [{kind}] {group['id']}")
    raise SystemExit(0)

if ACTION in {"put", "wait", "public"}:
    build = wait_for_valid_build()
else:
    build = find_build()
    if build is None:
        fail(f"Build {BUILD_NUMBER} is not visible in App Store Connect yet")
    if ACTION in {"attach", "public-submit", "public-attach"} and build["attributes"].get("processingState") != "VALID":
        fail(f"Build {BUILD_NUMBER} is {build['attributes'].get('processingState')}, not VALID")

if ACTION in PUBLIC_ACTIONS:
    selected_groups = select_external_groups(groups())
    ensure_public_build(build)
    if ACTION == "public-expire-older":
        expire_older_public_builds(build, selected_groups)
        raise SystemExit(0)
    if ACTION in {"public", "public-submit"}:
        ensure_public_metadata()
        upsert_what_to_test(build)
        submit_beta_review(build)
    if ACTION in {"public", "public-attach"}:
        attach_public_build(build, selected_groups)
    if ACTION == "public":
        expire_older_public_builds(build, selected_groups)
    if ACTION == "public-status":
        summarize_public_build(build, selected_groups)
    raise SystemExit(0)

selected_groups = select_internal_groups(groups())
if ACTION in {"put", "attach"}:
    upsert_what_to_test(build)
    attach_build(build, selected_groups)
else:
    summarize_build(build, selected_groups)
PY
