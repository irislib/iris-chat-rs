#!/usr/bin/env bash

set -Eeuo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
source "$ROOT/scripts/release_common.sh"
# shellcheck disable=SC1091
source "$ROOT/scripts/docker_stage_common.sh"

load_release_env "$ROOT"
resolve_shared_build_metadata "$ROOT"

usage() {
  cat <<'EOF'
usage: ./scripts/cli-release <target> [target...]

Build and package one or more iris CLI targets:
  aarch64-apple-darwin
  x86_64-apple-darwin
  x86_64-unknown-linux-gnu
EOF
}

write_installer() {
  local path="$1"
  cat > "$path" <<'EOF'
#!/bin/sh
set -eu

default_install_dir() {
  if [ "$(id -u)" -eq 0 ]; then
    printf '%s\n' /usr/local/bin
  elif [ -n "${XDG_BIN_HOME:-}" ]; then
    printf '%s\n' "$XDG_BIN_HOME"
  elif [ -n "${HOME:-}" ]; then
    printf '%s\n' "$HOME/.local/bin"
  else
    printf '%s\n' /usr/local/bin
  fi
}

path_contains() {
  target="$1"
  old_ifs="$IFS"
  IFS=:
  for entry in ${PATH:-}; do
    if [ "$entry" = "$target" ]; then
      IFS="$old_ifs"
      return 0
    fi
  done
  IFS="$old_ifs"
  return 1
}

existing_parent_dir() {
  dir="$1"
  while [ ! -e "$dir" ]; do
    dir="$(dirname "$dir")"
  done
  printf '%s\n' "$dir"
}

script_dir="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
INSTALL_DIR="${1:-$(default_install_dir)}"

echo "Installing iris to $INSTALL_DIR"

if [ ! -d "$INSTALL_DIR" ]; then
  parent="$(existing_parent_dir "$INSTALL_DIR")"
  if [ -w "$parent" ]; then
    mkdir -p "$INSTALL_DIR"
  else
    echo "Need sudo to create $INSTALL_DIR"
    sudo mkdir -p "$INSTALL_DIR"
  fi
fi

if [ ! -w "$INSTALL_DIR" ]; then
  echo "Need sudo to install to $INSTALL_DIR"
  sudo install -m 755 "$script_dir/iris" "$INSTALL_DIR/"
else
  install -m 755 "$script_dir/iris" "$INSTALL_DIR/"
fi

echo "Installed iris"
if ! path_contains "$INSTALL_DIR"; then
  echo
  echo "Add $INSTALL_DIR to your PATH, for example:"
  echo "  export PATH=\"$INSTALL_DIR:\$PATH\""
fi
echo
echo "Try:"
echo "  iris --help"
EOF
  chmod +x "$path"
}

write_readme() {
  cat > "$1" <<'EOF'
iris command line app
=====================

Quick install:
  ./install.sh
  ./install.sh /usr/local/bin

The iris command can create or restore a profile, send messages, search local
messages, and listen for new messages.

Examples:
  iris account create --name Alice
  iris whoami
  iris send <user-id-or-chat-id> "hello"
  iris listen

Use --json when another program is reading the output.
EOF
}

package_target() {
  local target="$1"
  local binary="$2"
  local stage package archive

  [[ -x "$binary" ]] || { echo "Missing CLI binary: $binary" >&2; return 1; }
  mkdir -p "$ROOT/dist/cli"
  stage="$(mktemp -d)"
  trap 'rm -rf "${stage:-}"' RETURN
  package="$stage/iris"
  archive="$ROOT/dist/cli/iris-${target}.tar.gz"
  mkdir -p "$package"
  install -m 755 "$binary" "$package/iris"
  write_installer "$package/install.sh"
  write_readme "$package/README.txt"
  case "$(uname -m):$target" in
    arm64:aarch64-*|aarch64:aarch64-*|x86_64:x86_64-*|amd64:x86_64-*)
      "$package/iris" --version
      ;;
    *)
      file "$package/iris"
      ;;
  esac
  tar -czf "$archive" -C "$stage" iris
  rm -rf "$stage"
  trap - RETURN
  printf '%s\n' "$archive"
}

build_macos() {
  local target="$1"
  local target_dir="$ROOT/target/cli-release"
  [[ "$(uname -s)" == Darwin ]] || { echo "$target requires a macOS host" >&2; return 1; }
  rustup target add "$target" >/dev/null
  CARGO_TARGET_DIR="$target_dir" \
    cargo build --manifest-path "$ROOT/core/Cargo.toml" --release --bin iris --target "$target" --locked
  package_target "$target" "$target_dir/$target/release/iris"
}

build_linux_native() {
  local target="$1"
  local target_dir="$ROOT/target/cli-release/linux-x64"
  rustup target add "$target" >/dev/null
  CARGO_TARGET_DIR="$target_dir" \
    cargo build --manifest-path "$ROOT/core/Cargo.toml" --release --bin iris --target "$target" --locked
  package_target "$target" "$target_dir/$target/release/iris"
}

build_linux_docker() {
  local target="$1"
  local target_dir="$ROOT/target/cli-release/linux-x64"
  local image="${IRIS_CLI_LINUX_BUILD_IMAGE:-$(docker_rust_build_image)}"
  local platform="${IRIS_CLI_LINUX_DOCKER_PLATFORM:-$(docker_default_platform)}"
  local repo_basename
  repo_basename="$(basename "$ROOT")"

  mkdir -p "$target_dir"
  docker run \
    --platform "$platform" \
    --rm \
    -v "$ROOT/..:/workspace:cached" \
    -w "/workspace/$repo_basename/core" \
    -e CARGO_TARGET_DIR="/workspace/$repo_basename/target/cli-release/linux-x64" \
    -e IRIS_APP_VERSION_NAME \
    -e IRIS_APP_VERSION_CODE \
    -e IRIS_BUILD_GIT_SHA \
    -e IRIS_BUILD_TIMESTAMP_UTC \
    --entrypoint /bin/bash \
    "$image" -c '
      set -Eeuo pipefail
      export DEBIAN_FRONTEND=noninteractive
      export PATH="/usr/local/cargo/bin:$PATH"
      apt-get update >/dev/null
      apt-get install -y --no-install-recommends libclang-dev libdbus-1-dev pkg-config >/dev/null
      rm -rf /var/lib/apt/lists/*
      cargo build --release --bin iris --locked
    '
  package_target "$target" "$target_dir/release/iris"
}

build_target() {
  case "$1" in
    aarch64-apple-darwin|x86_64-apple-darwin)
      build_macos "$1"
      ;;
    x86_64-unknown-linux-gnu)
      if [[ "$(uname -s)" == Linux && "$(uname -m)" =~ ^(x86_64|amd64)$ ]]; then
        build_linux_native "$1"
      else
        command -v docker >/dev/null || { echo "Docker is required to build $1 on this host" >&2; return 1; }
        build_linux_docker "$1"
      fi
      ;;
    *)
      echo "Unsupported CLI target: $1" >&2
      return 2
      ;;
  esac
}

[[ $# -gt 0 ]] || { usage >&2; exit 2; }
case "${1:-}" in
  -h|--help|help) usage; exit 0 ;;
esac

for target in "$@"; do
  build_target "$target"
done
