#!/usr/bin/env bash

set -Eeuo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SERIAL="${IRIS_ANDROID_SERIAL:-}"
DEFAULT_AVD="${IRIS_ANDROID_DEFAULT_AVD:-Medium_Phone_API_36.1}"
BOOT_MODE="${IRIS_ANDROID_BOOT_MODE:-headless}"
LOCAL_PROPERTIES="$ROOT/android/local.properties"
SDK_DIR="${ANDROID_HOME:-${ANDROID_SDK_ROOT:-}}"
APP_PACKAGE="${IRIS_ANDROID_APP_PACKAGE:-to.iris.chat.debug}"
MAIN_ACTIVITY="${IRIS_ANDROID_MAIN_ACTIVITY:-to.iris.chat.MainActivity}"
MODE="all"

if [[ -z "${SDK_DIR}" && -f "${LOCAL_PROPERTIES}" ]]; then
  SDK_DIR="$(
    awk -F= '
      $1 == "sdk.dir" {
        value = substr($0, index($0, "=") + 1)
        gsub(/\\:/, ":", value)
        gsub(/\\\\/, "\\", value)
        print value
      }
    ' "${LOCAL_PROPERTIES}" | tail -n 1
  )"
fi

if [[ -n "${ADB:-}" ]]; then
  :
elif command -v adb >/dev/null 2>&1; then
  ADB="$(command -v adb)"
elif [[ -n "${SDK_DIR:-}" && -x "${SDK_DIR}/platform-tools/adb" ]]; then
  ADB="${SDK_DIR}/platform-tools/adb"
else
  ADB=""
fi

if [[ -z "${ADB:-}" || ! -x "${ADB}" ]]; then
  echo "adb not found. Set ANDROID_HOME/ANDROID_SDK_ROOT or android/local.properties." >&2
  exit 1
fi

usage() {
  cat <<'EOF'
usage: ./tools/run-android [--all|--single] [--serial <adb-serial>] [--list-targets]
EOF
}

first_online_device() {
  "$ADB" devices | awk 'NR>1 && $2=="device" { print $1; exit }'
}

online_devices() {
  "$ADB" devices | awk 'NR>1 && $2=="device" { print $1 }'
}

ensure_single_device() {
  if [[ -z "${SERIAL:-}" ]]; then
    SERIAL="$(first_online_device)"
  fi

  if [[ -z "${SERIAL:-}" ]]; then
    emulator_args=()
    if [[ "$BOOT_MODE" == "headless" ]]; then
      emulator_args+=(--headless)
    fi
    SERIAL="$("$ROOT/scripts/run_android_emulators.sh" "${emulator_args[@]}" "$DEFAULT_AVD" | awk 'END { print $2 }')"
  fi

  if [[ -n "${SERIAL:-}" ]]; then
    if ! "$ADB" -s "$SERIAL" get-state >/dev/null 2>&1; then
      echo "Android target $SERIAL is not online." >&2
      exit 1
    fi
  fi

  if [[ -z "${SERIAL:-}" ]]; then
    echo "No Android device or emulator available." >&2
    exit 1
  fi
}

install_and_launch() {
  local serial="$1"
  local apk="$2"

  "$ADB" -s "$serial" install -r "$apk" >/dev/null
  "$ADB" -s "$serial" shell am start -n "${APP_PACKAGE}/${MAIN_ACTIVITY}" >/dev/null
  echo "Android app launched on $serial"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --all)
      MODE="all"
      shift
      ;;
    --single)
      MODE="single"
      shift
      ;;
    --serial)
      SERIAL="$2"
      MODE="single"
      shift 2
      ;;
    --list-targets)
      exec "$ROOT/tools/ndr-run" android list-targets
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

APK="$ROOT/android/app/build/outputs/apk/debug/app-debug.apk"
if [[ "$MODE" == "single" ]]; then
  ensure_single_device
  "$ROOT/scripts/android-build" android-assemble
  install_and_launch "$SERIAL" "$APK"
else
  DEVICES=()
  while IFS= read -r device; do
    [[ -n "$device" ]] && DEVICES+=("$device")
  done < <(online_devices)
  if [[ "${#DEVICES[@]}" -eq 0 ]]; then
    echo "No connected Android devices found." >&2
    exit 1
  fi
  "$ROOT/scripts/android-build" android-assemble
  for SERIAL in "${DEVICES[@]}"; do
    install_and_launch "$SERIAL" "$APK"
  done
  echo "Installed Android app on ${#DEVICES[@]} device(s)."
fi
