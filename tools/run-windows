#!/usr/bin/env bash
#
# Build and launch the Windows app inside the Parallels VM.
# Mirrors tools/run-ios and tools/run-macos.

set -Eeuo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      echo "usage: ./tools/run-windows"
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      exit 2
      ;;
  esac
done

"$ROOT/scripts/windows-build" windows-build
"$ROOT/scripts/windows-build" windows-run
