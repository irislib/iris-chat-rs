#!/usr/bin/env bash

set -Eeuo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SIMULATOR_NAME="${IRIS_IOS_SIMULATOR_NAME:-Iris Chat iPhone}"
DESTINATION="${IRIS_IOS_SIM_DESTINATION:-platform=iOS Simulator,name=${SIMULATOR_NAME}}"
BUNDLE_ID="${IRIS_IOS_BUNDLE_ID:-to.iris.chat}"
DEVELOPMENT_TEAM="${IRIS_IOS_DEVELOPMENT_TEAM:-J8PPJKD7TA}"
IOS_PROJECT="$ROOT/ios/IrisChat.xcodeproj"
IOS_SCHEME="IrisChat"
MODE="devices"

usage() {
  cat <<'EOF'
usage: ./tools/run-ios [--devices|--simulator|--list-targets]
EOF
}

destination_name() {
  python3 - "$DESTINATION" <<'PY'
import sys

destination = sys.argv[1]
for part in destination.split(","):
    part = part.strip()
    if part.startswith("name="):
        print(part.split("=", 1)[1])
        break
PY
}

resolve_udid() {
  local devices_json
  devices_json="$(xcrun simctl list -j devices available)"
  SIMCTL_DEVICES_JSON="$devices_json" python3 - "$DESTINATION" <<'PY'
import json
import os
import sys

destination = sys.argv[1]
fields = {}
for part in destination.split(","):
    part = part.strip()
    if "=" in part:
        key, value = part.split("=", 1)
        fields[key.strip()] = value.strip()

if "id" in fields:
    print(fields["id"])
    raise SystemExit(0)

name = fields.get("name")
if not name:
    raise SystemExit(1)

devices = json.loads(os.environ["SIMCTL_DEVICES_JSON"]).get("devices", {})
booted = []
available = []
for runtime_devices in devices.values():
    for device in runtime_devices:
        if not device.get("isAvailable", True):
            continue
        if device.get("name") != name:
            continue
        if device.get("state") == "Booted":
            booted.append(device["udid"])
        else:
            available.append(device["udid"])

for candidate in booted + available:
    print(candidate)
    raise SystemExit(0)

raise SystemExit(1)
PY
}

resolve_app_path() {
  local settings
  local target_build_dir
  local wrapper_name

  settings="$(
    xcodebuild \
      -project "$IOS_PROJECT" \
      -scheme "$IOS_SCHEME" \
      -destination "$DESTINATION" \
      -showBuildSettings 2>/dev/null
  )"
  target_build_dir="$(awk -F' = ' '/^[[:space:]]*TARGET_BUILD_DIR = / { print $2; exit }' <<<"$settings")"
  wrapper_name="$(awk -F' = ' '/^[[:space:]]*WRAPPER_NAME = / { print $2; exit }' <<<"$settings")"
  if [[ -n "${target_build_dir:-}" && -n "${wrapper_name:-}" ]]; then
    printf '%s/%s\n' "$target_build_dir" "$wrapper_name"
    return 0
  fi

  python3 - "$HOME/Library/Developer/Xcode/DerivedData" <<'PY'
from pathlib import Path
import sys

root = Path(sys.argv[1])
candidates = sorted(
    root.glob("**/Debug-iphonesimulator/IrisChat.app"),
    key=lambda path: path.stat().st_mtime,
    reverse=True,
)
if candidates:
    print(candidates[0])
PY
}

connected_device_ids() {
  xcrun devicectl list devices 2>/dev/null |
    awk '
      NR > 2 && $0 ~ /connected|available \(paired\)/ {
        for (i = 1; i <= NF; i++) {
          if ($i ~ /^[0-9A-Fa-f-]{36}$/) {
            print $i
            break
          }
        }
      }
    '
}

device_app_path() {
  local settings
  local target_build_dir
  local wrapper_name

  settings="$(
    xcodebuild \
      -project "$IOS_PROJECT" \
      -scheme "$IOS_SCHEME" \
      -configuration Debug \
      -destination "generic/platform=iOS" \
      -showBuildSettings 2>/dev/null
  )"
  target_build_dir="$(awk -F' = ' '/^[[:space:]]*TARGET_BUILD_DIR = / { print $2; exit }' <<<"$settings")"
  wrapper_name="$(awk -F' = ' '/^[[:space:]]*WRAPPER_NAME = / { print $2; exit }' <<<"$settings")"
  if [[ -n "${target_build_dir:-}" && -n "${wrapper_name:-}" ]]; then
    printf '%s/%s\n' "$target_build_dir" "$wrapper_name"
  fi
}

build_device_app() {
  IRIS_IOS_RUST_TARGETS="${IRIS_IOS_RUST_TARGETS:-aarch64-apple-ios}" "$ROOT/scripts/ios-build" ios-xcframework
  "$ROOT/scripts/ios-build" ios-xcodeproj
  xcodebuild \
    -project "$IOS_PROJECT" \
    -scheme "$IOS_SCHEME" \
    -configuration Debug \
    -destination "generic/platform=iOS" \
    -allowProvisioningUpdates \
    DEVELOPMENT_TEAM="$DEVELOPMENT_TEAM" \
    CODE_SIGN_STYLE=Automatic \
    build
}

run_devices() {
  local -a devices
  local app_path
  local device
  local installed=0

  while IFS= read -r device; do
    [[ -n "$device" ]] && devices+=("$device")
  done < <(connected_device_ids)
  if [[ "${#devices[@]}" -eq 0 ]]; then
    echo "No connected iOS devices found." >&2
    exit 1
  fi

  build_device_app
  app_path="$(device_app_path)"
  if [[ -z "${app_path:-}" || ! -d "$app_path" ]]; then
    echo "Built iOS device app not found." >&2
    exit 1
  fi

  for device in "${devices[@]}"; do
    echo "Installing iOS app on $device"
    xcrun devicectl device install app --device "$device" "$app_path"
    if xcrun devicectl device process launch --device "$device" "$BUNDLE_ID" >/tmp/iris-chat-ios-launch-"$device".log 2>&1; then
      echo "iOS app launched on $device"
    else
      echo "iOS app installed on $device; launch failed or app was already running." >&2
    fi
    installed=$((installed + 1))
  done

  echo "Installed iOS app on $installed device(s)."
}

run_simulator() {
  if simulator_name="$(destination_name)"; [[ -n "${simulator_name:-}" ]]; then
    "$ROOT/scripts/run_ios_simulators.sh" --no-open "$simulator_name" >/dev/null
  fi

  IRIS_IOS_SIM_DESTINATION="$DESTINATION" "$ROOT/scripts/ios-build" ios-build-sim
  UDID="$(resolve_udid)"
  APP_PATH="$(resolve_app_path)"
  if [[ -z "${UDID:-}" || -z "${APP_PATH:-}" ]]; then
    echo "Built simulator app not found." >&2
    exit 1
  fi
  xcrun simctl install "$UDID" "$APP_PATH" >/dev/null
  xcrun simctl launch "$UDID" "$BUNDLE_ID" >/tmp/iris-chat-ios-launch.log 2>&1 || true
  open -a Simulator >/dev/null 2>&1 || true
  echo "iOS app launched on $UDID"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --devices)
      MODE="devices"
      shift
      ;;
    --simulator)
      MODE="simulator"
      shift
      ;;
    --list-targets)
      exec "$ROOT/tools/ndr-run" ios list-targets
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

case "$MODE" in
  devices) run_devices ;;
  simulator) run_simulator ;;
esac
